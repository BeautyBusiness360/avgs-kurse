---
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  module: string;  // service slug, e.g. "microblading-masterclass"
  limit?: number;
}

const { module: serviceSlug, limit = 6 } = Astro.props;

const GALLERY_FOLDERS: Record<string, string> = {
  'powderbrows-ombrebrows-masterclass': 'powderbrows-ombrebrows',
  'velvet-lips-lipstick-masterclass':   'velvet-lips-lipstick',
  'microblading-masterclass':           'microblading',
  'wimpernverlaengerung-masterclass':   'wimpernverlaengerung',
  'camouflage-removal-masterclass':     'camouflage-removal',
};

const GALLERY_DESC: Record<string, string> = {
  'powderbrows-ombrebrows-masterclass': 'PowderBrows & OmbreBrows – pudrig-weiche, definierte Augenbrauen. Ergebnisse aus unseren Trainings.',
  'velvet-lips-lipstick-masterclass':   'Velvet Lips & LipStick Effekt – natürlich-definierte Lippen mit gleichmäßiger Farbe. Ergebnisse aus unseren Trainings.',
  'microblading-masterclass':           'Microblading – haarfeine Striche für natürlich wirkende, dicht definierte Augenbrauen. Ergebnisse aus unseren Trainings.',
  'wimpernverlaengerung-masterclass':   'Wimpernverlängerung (1:1 & Volumen) – längere, dichtere Wimpern. Ergebnisse aus unseren Trainings.',
  'camouflage-removal-masterclass':     'Camouflage & Tattoo Removal – gezieltes Überdecken oder Entfernen unerwünschter Pigmentierungen. Ergebnisse aus unseren Trainings.',
};

const folder = GALLERY_FOLDERS[serviceSlug];
const desc   = GALLERY_DESC[serviceSlug] ?? null;

let images: string[] = [];

if (folder) {
  const folderAbs = path.join(process.cwd(), 'public', 'images', 'Modul-Bilder', folder);
  if (fs.existsSync(folderAbs)) {
    images = fs.readdirSync(folderAbs)
      .filter(f => /\.webp$/i.test(f) && f !== 'hero.webp')
      .sort((a, b) => {
        const na = parseInt(a.match(/\d+/)?.[0] ?? '0');
        const nb = parseInt(b.match(/\d+/)?.[0] ?? '0');
        return na - nb;
      })
      .slice(0, limit)
      .map(f => `/images/Modul-Bilder/${folder}/${f}`);
  }
}

const trackId = `gg-track-${serviceSlug}`;
const dotsId  = `gg-dots-${serviceSlug}`;
---

{images.length > 0 && (
  <section class="gg-section">
    <h2 class="gg-title">Beispiel-Ergebnisse</h2>
    {desc && <p class="gg-desc">{desc}</p>}
    <div class="gg-carousel-wrap">
      <button class="gg-btn gg-prev" aria-label="Zurück">&#8592;</button>
      <div class="gg-track" id={trackId}>
        {images.map((src, i) => (
          <div class="gg-slide">
            <img
              src={src}
              alt={`Beispielergebnis ${i + 1}`}
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
              width="400"
              height="400"
            />
          </div>
        ))}
      </div>
      <button class="gg-btn gg-next" aria-label="Weiter">&#8594;</button>
      <div class="gg-dots" id={dotsId} aria-hidden="true"></div>
    </div>
  </section>
)}

<script define:vars={{ trackId, dotsId }} is:inline>
  (function () {
    const track    = document.getElementById(trackId);
    const dotsWrap = document.getElementById(dotsId);
    if (!track) return;

    const prev   = track.closest('.gg-carousel-wrap')?.querySelector('.gg-prev');
    const next   = track.closest('.gg-carousel-wrap')?.querySelector('.gg-next');
    const slides = Array.from(track.querySelectorAll('.gg-slide'));
    const step   = () => (slides[0]?.offsetWidth ?? 0) + 12;

    // Build dots
    const dots = slides.map((_, i) => {
      const d = document.createElement('button');
      d.className = 'gg-dot' + (i === 0 ? ' active' : '');
      d.setAttribute('aria-label', 'Bild ' + (i + 1));
      d.addEventListener('click', () =>
        track.scrollTo({ left: step() * i, behavior: 'smooth' })
      );
      dotsWrap?.appendChild(d);
      return d;
    });

    const updateDots = () => {
      const idx = Math.round(track.scrollLeft / (step() || 1));
      dots.forEach((d, i) => d.classList.toggle('active', i === idx));
    };

    track.addEventListener('scroll', updateDots, { passive: true });
    prev?.addEventListener('click', () => track.scrollBy({ left: -step() * 3, behavior: 'smooth' }));
    next?.addEventListener('click', () => track.scrollBy({ left:  step() * 3, behavior: 'smooth' }));
  })();
</script>

<style>
.gg-section {
  margin-bottom: 56px;
  border-top: 1px solid rgba(0,0,0,.08);
  padding-top: 36px;
}
.gg-title {
  font-family: var(--serif, 'Cormorant Garamond', Georgia, serif);
  font-size: 28px;
  font-weight: 600;
  color: var(--black, #111111);
  margin: 0 0 10px;
}
.gg-desc {
  font-family: var(--sans, 'Inter', system-ui, sans-serif);
  font-size: 13px;
  color: rgba(17,17,17,.5);
  margin: 0 0 24px;
  line-height: 1.6;
}
.gg-carousel-wrap {
  position: relative;
}
.gg-track {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  scrollbar-width: none;
}
.gg-track::-webkit-scrollbar { display: none; }
.gg-slide {
  flex: 0 0 calc((100% - 24px) / 3);
  scroll-snap-align: start;
  border-radius: 12px;
  overflow: hidden;
}
.gg-slide img {
  width: 100%;
  aspect-ratio: 1;
  object-fit: cover;
  display: block;
  transition: transform .5s ease;
}
.gg-slide:hover img { transform: scale(1.04); }
.gg-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: white;
  border: 1px solid rgba(0,0,0,.12);
  box-shadow: 0 2px 8px rgba(0,0,0,.10);
  cursor: pointer;
  font-size: 18px;
  line-height: 1;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: box-shadow .2s;
}
.gg-btn:hover { box-shadow: 0 4px 16px rgba(0,0,0,.15); }
.gg-prev { left: -20px; }
.gg-next { right: -20px; }
.gg-dots {
  display: none;
  justify-content: center;
  gap: 8px;
  margin-top: 12px;
}
.gg-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  border: 1.5px solid #C8962E;
  background: transparent;
  cursor: pointer;
  padding: 0;
  transition: background .2s;
}
.gg-dot.active { background: #C8962E; }
@media (max-width: 640px) {
  .gg-slide { flex: 0 0 100%; }
  .gg-btn   { display: none; }
  .gg-dots  { display: flex; }
}
</style>
