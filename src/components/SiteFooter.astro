---
interface Props {
  variant?: 'full' | 'lean';
  activeCity?: string;
}

const { variant = 'full', activeCity } = Astro.props;

const cities = [
  { slug: 'berlin',  name: 'Berlin' },
  { slug: 'essen',   name: 'Essen' },
  { slug: 'hamburg', name: 'Hamburg' },
  { slug: 'mainz',   name: 'Mainz' },
  { slug: 'ulm',     name: 'Ulm' },
];
---

{variant === 'full' ? (
<footer class="sf sf--full">
  <div class="sf-w">

    <div class="sf-grid">

      <!-- 1) Marke -->
      <div class="sf-col sf-col--brand">
        <a href="/" class="sf-logo-link" aria-label="BeautyBusiness360 Startseite">
          <img
            src="/images/logo/logo-weiss.webp"
            alt="BeautyBusiness360"
            width="160" height="48"
            loading="lazy"
          />
        </a>
        <p class="sf-brand-text">
          BeautyBusiness360 verbindet Kosmetikstudios, Fachdozentinnen und Bildungspartner
          zu einem bundesweiten Netzwerk für staatlich geförderte Beauty-Weiterbildungen.
        </p>
      </div>

      <!-- 2) Standorte -->
      <div class="sf-col">
        <h3 class="sf-col-title">Kurse in deiner Stadt</h3>
        <nav class="sf-link-list" aria-label="Städteseiten">
          {cities.map(c => (
            <a
              href={`/${c.slug}/`}
              class={`sf-link${activeCity === c.slug ? ' sf-link--active' : ''}`}
            >
              {c.name}
            </a>
          ))}
        </nav>
      </div>

      <!-- 3) Weitere Angebote -->
      <div class="sf-col">
        <h3 class="sf-col-title">Weitere Angebote</h3>
        <nav class="sf-link-list" aria-label="Weitere Angebote">
          <a href="/fachdozentin-werden" class="sf-link sf-link--cta">
            Fachdozentin werden
          </a>
          <a href="https://www.dozentenschein.de" class="sf-link sf-link--ext" target="_blank" rel="noopener">
            Dozentenschein (Train-the-Trainer)
          </a>
          <a href="https://www.azav-experten.de" class="sf-link sf-link--ext" target="_blank" rel="noopener">
            AZAV-Zulassung &amp; QM-Beratung
          </a>
        </nav>
      </div>

      <!-- 4) Kontakt -->
      <div class="sf-col">
        <h3 class="sf-col-title">Kontakt</h3>
        <nav class="sf-link-list" aria-label="Kontakt">
          <a href="https://wa.me/message/YA4T7XURCU7WJ1" class="sf-link sf-link--icon" target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
          <a href="mailto:info@dein-beauty-kurs.de" class="sf-link sf-link--icon">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            info@dein-beauty-kurs.de
          </a>
        </nav>
      </div>

    </div>

    <div class="sf-divider"></div>

    <!-- Bottom bar -->
    <div class="sf-bottom">
      <div class="sf-legal">
        <a href="/impressum/" class="sf-legal-link">Impressum</a>
        <a href="/datenschutz/" class="sf-legal-link">Datenschutzerklärung</a>
      </div>
      <div class="sf-social" aria-label="Social Media">
        <a href="https://www.instagram.com/beautybusiness360/" class="sf-social-link" target="_blank" rel="noopener" aria-label="Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r=".8" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a href="https://www.facebook.com/BeautyBusiness360/" class="sf-social-link" target="_blank" rel="noopener" aria-label="Facebook">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a href="https://wa.me/message/YA4T7XURCU7WJ1" class="sf-social-link" target="_blank" rel="noopener" aria-label="WhatsApp">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
      </div>
      <span class="sf-copy">© 2026 BeautyBusiness360</span>
    </div>

  </div>
</footer>
) : (
<footer class="sf sf--lean">
  <div class="sf-w">
    <div class="sf-bottom">
      <span class="sf-copy">© 2026 BeautyBusiness360</span>
      <div class="sf-legal">
        <a href="/impressum/" class="sf-legal-link">Impressum</a>
        <a href="/datenschutz/" class="sf-legal-link">Datenschutzerklärung</a>
      </div>
    </div>
  </div>
</footer>
)}

<style>
/* ── shared tokens ────────────────────────────────────────────── */
.sf {
  background: var(--black, #111111);
  font-family: var(--sans, 'Inter', system-ui, sans-serif);
  -webkit-font-smoothing: antialiased;
}
.sf-w {
  max-width: 1120px;
  margin: 0 auto;
  padding: 0 40px;
}
@media (max-width: 640px) { .sf-w { padding: 0 22px; } }

/* ── full variant ─────────────────────────────────────────────── */
.sf--full { border-top: 1px solid rgba(255,255,255,.06); padding: 64px 0 0; }

.sf-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 40px 48px;
}
@media (max-width: 960px) {
  .sf-grid { grid-template-columns: 1fr 1fr; gap: 36px 40px; }
  .sf-col--brand { grid-column: 1 / -1; }
}
@media (max-width: 540px) {
  .sf-grid { grid-template-columns: 1fr; gap: 32px; }
  .sf-col--brand { grid-column: auto; }
}

.sf-logo-link { display: inline-block; margin-bottom: 16px; }
.sf-logo-link img { display: block; height: 120px; width: auto; }
@media (max-width: 640px) { .sf-logo-link img { height: 72px; } }
.sf-brand-text {
  font-size: 13px;
  line-height: 1.75;
  color: rgba(255,255,255,.38);
  max-width: 320px;
}

.sf-col-title {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--gold, #C8962E);
  margin-bottom: 16px;
}

.sf-link-list { display: flex; flex-direction: column; gap: 10px; }
.sf-link {
  font-size: 13px;
  color: rgba(255,255,255,.45);
  text-decoration: none;
  transition: color .2s;
  line-height: 1.5;
}
.sf-link:hover { color: rgba(255,255,255,.85); }
.sf-link--active {
  color: var(--gold-lt, #D4AF7A) !important;
  font-weight: 500;
}
.sf-link--icon { display: flex; align-items: center; gap: 8px; }
.sf-link--icon svg { flex-shrink: 0; opacity: .6; }
.sf-link--ext::after { content: ' ↗'; font-size: 11px; opacity: .55; }
.sf-link--cta { color: #C8962E !important; }
.sf-link--cta:hover { color: #D4AF7A !important; text-decoration: underline; }

.sf-divider { margin-top: 52px; border-top: 1px solid rgba(255,255,255,.06); }

/* ── bottom bar ──────────────────────────────────────────────── */
.sf--full .sf-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px 24px;
  padding: 20px 0 28px;
}
.sf--lean {
  border-top: 1px solid rgba(255,255,255,.06);
  padding: 32px 0;
}
.sf--lean .sf-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16px;
}

.sf-copy { font-size: 12px; color: rgba(255,255,255,.25); }

.sf-legal { display: flex; flex-wrap: wrap; gap: 8px 20px; align-items: center; }
.sf-legal-link {
  font-size: 12px;
  color: rgba(255,255,255,.30);
  text-decoration: none;
  transition: color .2s;
}
.sf-legal-link:hover { color: rgba(255,255,255,.70); }

.sf-social { display: flex; gap: 16px; }
.sf-social-link {
  color: rgba(255,255,255,.30);
  transition: color .2s;
  display: flex; align-items: center;
}
.sf-social-link:hover { color: rgba(255,255,255,.80); }

@media (max-width: 540px) {
  .sf--full .sf-bottom { flex-direction: column; align-items: flex-start; gap: 16px; }
  .sf--lean .sf-bottom { flex-direction: column; align-items: flex-start; }
}
</style>
