---
interface Props {
  variant?: 'linked' | 'brand-only';
}
const { variant = 'linked' } = Astro.props;
---

<header class="sh">
  <div class="sh-w">
    {variant === 'linked' ? (
      <a href="/" class="sh-logo" aria-label="BeautyBusiness360 – Startseite">
        <img src="/images/logo/logo-weiss.png" alt="BeautyBusiness360" width="120" height="36" />
      </a>
    ) : (
      <span class="sh-logo" aria-label="BeautyBusiness360">
        <img src="/images/logo/logo-weiss.png" alt="BeautyBusiness360" width="120" height="36" />
      </span>
    )}
  </div>
</header>

<style>
.sh {
  background: var(--black, #111111);
  border-bottom: 1px solid rgba(255,255,255,.05);
  padding: 14px 0;
}
.sh-w {
  max-width: 1120px;
  margin: 0 auto;
  padding: 0 40px;
  display: flex;
  align-items: center;
}
@media (max-width: 640px) { .sh-w { padding: 0 22px; } }

.sh-logo {
  display: inline-flex;
  align-items: center;
  text-decoration: none;
  line-height: 0;
}
.sh-logo img {
  display: block;
  height: 30px;
  width: auto;
}
@media (max-width: 640px) { .sh-logo img { height: 24px; } }
</style>
