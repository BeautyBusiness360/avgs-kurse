---
import SEOLayout from '../layouts/SEOLayout.astro';
import DozentinInfoBox from '../components/DozentinInfoBox.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { CITY_DISPLAY } from '../data/location-overrides';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { supabase } from '../lib/supabase';
import fs from 'node:fs';
import path from 'node:path';

export const prerender = true;

// ── Dozentinnen für Netzwerk-Sektion ────────────────────────────────────────
const { data: dozRaw } = await supabase
  .from('dozentinnen')
  .select(`
    slug, first_name, last_name, image_url,
    cities(slug, name),
    dozentin_services(services(name))
  `)
  .eq('active', true)
  .order('last_name');

const dozentinnen = (dozRaw ?? [])
  .map((d: any) => {
    const city = Array.isArray(d.cities) ? d.cities[0] : d.cities;
    const citySlug = city?.slug ?? '';
    const localSlug = d.slug.replace(new RegExp(`-${citySlug}$`), '');
    const rel = `/images/dozentinnen/${localSlug}/${localSlug}.webp`;
    const hasLocalImg = fs.existsSync(path.join(process.cwd(), 'public', rel));
    const profileImg = hasLocalImg ? rel : (d.image_url ?? null);
    const services = (Array.isArray(d.dozentin_services) ? d.dozentin_services : [])
      .map((ds: any) => Array.isArray(ds?.services) ? ds.services[0] : ds?.services)
      .filter(Boolean);
    return { ...d, city, localSlug, profileImg, services };
  })
  .filter((d: any) => d.profileImg)
  .slice(0, 18)
  .map((d: any, i: number) => ({
    ...d,
    regNr: `BB360-FD-${String(i + 1).padStart(3, '0')}`,
  }));

const founderImgPath = '/images/dozentinnen/walid-regaia/walid-regaia-profilbild.webp';
const founderImgExists = fs.existsSync(
  path.join(process.cwd(), 'public', founderImgPath),
);

const seo = {
  title:
    'Fachdozentin werden – geförderte Perfektionstrainings ohne eigene AZAV-Zulassung | BeautyBusiness360',
  description:
    'Werde Fachdozentin im bundesweiten BeautyBusiness360-Netzwerk: bis zu 1.500 € Vergütung pro Teilnehmerin, staatlich gefördert über die Agentur für Arbeit – ohne eigene AZAV-Zulassung. Jetzt kostenfreien Webinar-Platz sichern.',
  canonical: 'https://dein-beauty-kurs.de/fachdozentin-werden',
};

const problemItems = [
  'Zu wenig neue Teilnehmer-Anfragen',
  'Privatzahler können sich Schulungen oft nicht leisten',
  'Gute Schulungen bleiben ungebucht',
  'Umsatz schwankt von Monat zu Monat',
  'Werbung kostet viel und bringt wenig',
  'Hohe Konkurrenz in fast jeder Stadt',
];

const solutionItems = [
  'Anerkennung als Fachdozentin inkl. offiziellem Dozentenschein',
  '1:1-Perfektionstraining (nur Dozentin & Teilnehmerin)',
  'Förderung durch Agentur für Arbeit, Teilnehmer zahlen nichts',
  'Bis zu 1.500 € Vergütung pro Teilnehmerin (3 Tage Unterricht)',
  'Keine eigene AZAV-Zulassung notwendig',
];

const infoCards = [
  {
    title: 'Wie das Partner-Modell funktioniert',
    text:  'Wie die Zusammenarbeit aufgebaut ist, wie der Ablauf aussieht und wie die Vergütung geregelt ist.',
  },
  {
    title: 'Welche Voraussetzungen notwendig sind',
    text:  'Welche fachlichen und pädagogischen Voraussetzungen für eine Zusammenarbeit notwendig sind und für wen eine Zusammenarbeit infrage kommt.',
  },
  {
    title: 'Wie du ohne eigene AZAV-Zulassung startest',
    text:  'Warum du keine eigene AZAV-Zulassung brauchst und wie eine Zusammenarbeit trotzdem möglich ist.',
  },
  {
    title: 'Staatliche Förderung (Agentur für Arbeit)',
    text:  'Wie deine Teilnehmer kostenfrei an den Perfektionstrainings teilnehmen können.',
  },
];
---

<SEOLayout title={seo.title} description={seo.description} canonical={seo.canonical}>

<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%"   stop-color="#F9E29C"/>
      <stop offset="35%"  stop-color="#E6B84F"/>
      <stop offset="65%"  stop-color="#C8962E"/>
      <stop offset="100%" stop-color="#9A6E1E"/>
    </linearGradient>
  </defs>
</svg>

<style>
:root {
  --cream:   #FAF8F5;
  --cream-d: #F3EEE8;
  --black:   #111111;
  --gold:    #C8962E;
  --gold-lt: #D4AF7A;
  --gold-bg: #FBF6EE;
  --rose:    #E8C4B8;
  --muted:   #555250;
  --border:  #E8E2D9;
  --white:   #FFFFFF;
  --serif:   'Cormorant Garamond', Georgia, 'Times New Roman', serif;
  --sans:    'Inter', system-ui, sans-serif;
  --radius:  3px;
  --shadow:  0 8px 40px rgba(184,150,90,.10);
}

*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }
html { scroll-behavior:smooth; }
body {
  background:var(--cream);
  color:var(--black);
  font-family:var(--sans);
  font-size:16px; font-weight:400; line-height:1.75;
  -webkit-font-smoothing:antialiased;
}

/* ─── LAYOUT ─────────────────────────── */
.w { max-width:1120px; margin:0 auto; padding:0 40px; }
@media(max-width:640px){ .w { padding:0 22px; } }

/* ─── BUTTONS ────────────────────────── */
.cta-gold {
  display:inline-block;
  background:var(--gold); color:var(--white);
  font-family:var(--sans); font-size:12px; font-weight:600;
  letter-spacing:.14em; text-transform:uppercase;
  padding:14px 34px; border:none; border-radius:var(--radius);
  text-decoration:none; cursor:pointer;
  transition:background .25s, transform .2s, box-shadow .25s;
  box-shadow:0 4px 18px rgba(184,150,90,.25);
}
.cta-gold:hover { background:var(--gold-lt); transform:translateY(-2px); box-shadow:0 8px 28px rgba(184,150,90,.35); }
.cta-white {
  display:inline-block;
  background:var(--white); color:var(--black);
  font-family:var(--sans); font-size:12px; font-weight:600;
  letter-spacing:.14em; text-transform:uppercase;
  padding:14px 34px; border-radius:var(--radius);
  text-decoration:none; cursor:pointer;
  transition:opacity .2s, transform .2s;
  box-shadow:0 4px 20px rgba(0,0,0,.15);
}
.cta-white:hover { opacity:.9; transform:translateY(-1px); }

/* ─── SHARED SECTION LABELS ──────────── */
.section-eye {
  display:inline-block;
  font-size:11px; font-weight:500; letter-spacing:.22em; text-transform:uppercase;
  color:var(--gold); margin-bottom:18px;
}
.section-title {
  font-family:var(--serif);
  font-size:clamp(36px, 5vw, 60px);
  font-weight:600; line-height:1.08; color:var(--black); margin-bottom:18px;
}
.section-title em { font-style:italic; color:var(--gold); }
.section-desc {
  font-size:16px; font-weight:400; line-height:1.85; color:var(--muted);
}

/* ══════════════════════════════════════
   HERO
══════════════════════════════════════ */
.hero {
  background:var(--black);
  position:relative; overflow:hidden;
  padding:33px 0 96px;
  text-align:center;
}
@media(max-width:640px){ .hero { padding-top:70px; } }
.hero::before {
  content:''; position:absolute; inset:0;
  background:
    radial-gradient(ellipse at 18% 65%, rgba(184,150,90,.16) 0%, transparent 55%),
    radial-gradient(ellipse at 82% 22%, rgba(232,196,184,.08) 0%, transparent 55%);
  pointer-events:none;
}
.hero > .w { position:relative; }
.hero-eye { color:var(--gold); }
.hero-h1 {
  font-family:var(--serif);
  font-size:clamp(38px, 5.5vw, 70px);
  font-weight:600; line-height:1.08;
  color:var(--white); letter-spacing:-.02em;
  max-width:840px; margin:0 auto 28px;
}
.hero-h1 em { font-style:italic; color:var(--gold-lt); }
.hero-sub {
  font-size:17px; font-weight:400; line-height:1.85;
  color:rgba(255,255,255,.5);
  max-width:640px; margin:0 auto 52px;
}
.hero-bullets {
  display:flex; flex-direction:column; align-items:center;
  max-width:480px; margin:0 auto 52px;
}
.hero-bullet {
  display:flex; align-items:flex-start; gap:12px;
  width:100%; padding:14px 0;
  border-top:1px solid rgba(255,255,255,.08);
  font-size:14px; font-weight:500; color:rgba(255,255,255,.78);
  text-align:left;
}
.hero-bullet:last-child { border-bottom:1px solid rgba(255,255,255,.08); }
.hero-bullet-diamond { color:var(--gold); flex-shrink:0; font-size:10px; margin-top:3px; }
.hero-note {
  margin-top:16px;
  font-size:12px; color:rgba(255,255,255,.28);
}

/* ══════════════════════════════════════
   PROBLEM | LÖSUNG
══════════════════════════════════════ */
.pl-section { padding:80px 0; }
.pl-grid {
  display:grid; grid-template-columns:1fr 1fr;
  gap:28px; align-items:stretch;
}
@media(max-width:860px){ .pl-grid { grid-template-columns:1fr; } }

/* Problem (dark card) */
.problem-card {
  background:var(--black);
  border-radius:var(--radius);
  overflow:hidden; position:relative;
  display:flex; flex-direction:column;
}
.problem-card::before {
  content:''; position:absolute; inset:0;
  background:radial-gradient(ellipse at 0% 100%, rgba(184,150,90,.12) 0%, transparent 60%);
  pointer-events:none;
}
.problem-card-accent { height:3px; background:linear-gradient(90deg, #9A6E1E, var(--gold)); }
.problem-card-body { padding:44px 40px; flex:1; display:flex; flex-direction:column; position:relative; }
.problem-card-eye { color:var(--gold); margin-bottom:20px; }
.problem-h2 {
  font-family:var(--serif);
  font-size:clamp(24px, 2.8vw, 36px);
  font-weight:600; line-height:1.18;
  color:var(--white); margin-bottom:36px;
}
.problem-list { list-style:none; flex:1; display:flex; flex-direction:column; gap:14px; }
.problem-item {
  display:flex; gap:12px; align-items:flex-start;
  font-size:15px; line-height:1.6; color:rgba(255,255,255,.68);
}
.problem-icon {
  flex-shrink:0; margin-top:1px;
  width:20px; height:20px; border-radius:50%;
  background:rgba(255,100,100,.12); border:1px solid rgba(255,100,100,.22);
  display:flex; align-items:center; justify-content:center;
  font-size:11px; font-weight:700; color:#ff7070;
}
.problem-cta-wrap { margin-top:44px; }
.problem-note { margin-top:14px; font-size:12px; color:rgba(255,255,255,.25); }

/* Lösung (light card) */
.solution-card {
  background:var(--white);
  border:1px solid var(--border);
  border-radius:var(--radius);
  overflow:hidden;
  display:flex; flex-direction:column;
  box-shadow:var(--shadow);
}
.solution-card-accent { height:3px; background:linear-gradient(90deg, var(--gold), var(--rose)); flex-shrink:0; }
.solution-card-body { padding:44px 40px; flex:1; display:flex; flex-direction:column; }
.solution-card-eye { color:var(--gold); margin-bottom:20px; }
.solution-h2 {
  font-family:var(--serif);
  font-size:clamp(24px, 2.8vw, 36px);
  font-weight:600; line-height:1.18;
  color:var(--black); margin-bottom:16px;
}
.solution-intro {
  font-size:15px; line-height:1.8; color:var(--muted); margin-bottom:28px;
}
.solution-list { list-style:none; display:flex; flex-direction:column; gap:13px; margin-bottom:28px; }
.solution-item {
  display:flex; gap:12px; align-items:flex-start;
  font-size:15px; line-height:1.6; color:var(--black);
}
.solution-check {
  flex-shrink:0; margin-top:1px;
  width:20px; height:20px; border-radius:50%;
  background:var(--gold-bg); border:1px solid #E8D9C4;
  display:flex; align-items:center; justify-content:center;
  font-size:10px; color:var(--gold);
}

/* Unterrichtsort-Callout */
.location-callout {
  background:var(--gold-bg); border:1px solid #E8D9C4;
  border-radius:var(--radius); padding:18px 20px; margin-bottom:36px;
}
.location-callout-label {
  display:flex; align-items:center; gap:8px;
  font-size:10px; font-weight:700; letter-spacing:.16em; text-transform:uppercase;
  color:#7A5C2E; margin-bottom:10px;
}
.location-callout-text { font-size:14px; line-height:1.75; color:var(--muted); }
.solution-cta-wrap { margin-top:auto; }
.solution-note { margin-top:14px; font-size:12px; color:rgba(85,82,80,.4); }

/* ══════════════════════════════════════
   NETZWERK-CAROUSEL
══════════════════════════════════════ */
.net-section {
  padding:96px 0;
  background:var(--cream-d);
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
}
.net-header { text-align:center; margin-bottom:64px; }
.net-header .section-desc { max-width:640px; margin:0 auto; }

.net-carousel-wrap { position:relative; }
.net-track {
  display:flex; gap:24px;
  overflow-x:auto; scroll-snap-type:x mandatory; scroll-behavior:smooth;
  scrollbar-width:none; padding-bottom:4px;
}
.net-track::-webkit-scrollbar { display:none; }
.net-slide {
  flex:0 0 calc((100% - 48px) / 3);
  scroll-snap-align:start;
}
@media(max-width:860px){ .net-slide { flex:0 0 calc((100% - 24px) / 2); } }
@media(max-width:540px){ .net-slide { flex:0 0 100%; } }

.net-card {
  background:var(--white);
  border:1px solid var(--border); border-radius:var(--radius);
  overflow:hidden; box-shadow:0 2px 16px rgba(0,0,0,.04);
}
.net-img-wrap { position:relative; aspect-ratio:1; overflow:hidden; background:var(--cream-d); }
.net-img-wrap img { width:100%; height:100%; object-fit:cover; display:block; }
/* .net-card-body styles live in DozentinInfoBox.astro */

/* Carousel controls */
.carousel-btn {
  position:absolute; top:38%;
  width:40px; height:40px; border-radius:50%;
  background:var(--white); border:1px solid var(--border);
  box-shadow:0 2px 8px rgba(0,0,0,.10);
  cursor:pointer; font-size:16px;
  display:flex; align-items:center; justify-content:center;
  z-index:2; transition:box-shadow .2s;
  color:var(--black);
}
.carousel-btn:hover { box-shadow:0 4px 16px rgba(0,0,0,.15); }
.carousel-prev { left:-20px; }
.carousel-next { right:-20px; }
@media(max-width:860px){ .carousel-btn { display:none; } }
.carousel-dots { display:flex; justify-content:center; gap:8px; margin-top:24px; }
.carousel-dot {
  width:8px; height:8px; border-radius:50%;
  border:1.5px solid var(--muted); background:transparent;
  cursor:pointer; padding:0;
  transition:background .2s, border-color .2s;
}
.carousel-dot.active { background:var(--gold); border-color:var(--gold); }

/* ══════════════════════════════════════
   GRÜNDER
══════════════════════════════════════ */
.founder-section {
  padding:96px 0;
  border-top:1px solid var(--border);
}
.founder-grid {
  display:grid; grid-template-columns:1fr 380px;
  gap:80px; align-items:center;
}
@media(max-width:860px){
  .founder-grid { grid-template-columns:1fr; gap:48px; }
  .founder-photo { order:-1; }
}
.founder-eye { color:var(--gold); margin-bottom:16px; }
.founder-name {
  font-family:var(--serif);
  font-size:clamp(36px, 4.5vw, 56px);
  font-weight:600; line-height:1.06; color:var(--black); margin-bottom:6px;
}
.founder-role {
  font-size:14px; color:var(--muted); font-weight:400; margin-bottom:36px;
}
.founder-p {
  font-size:16px; font-weight:400; line-height:1.9; color:var(--muted); margin-bottom:20px;
}
.founder-quote {
  border-left:3px solid var(--gold); padding-left:24px; margin-top:32px;
  font-family:var(--serif);
  font-size:clamp(18px, 2.2vw, 24px);
  font-weight:600; line-height:1.45; color:var(--black);
}
.founder-photo-frame {
  width:100%; aspect-ratio:3/4;
  border-radius:var(--radius); overflow:hidden;
  background:var(--cream-d); box-shadow:var(--shadow);
}
.founder-photo-frame img { width:100%; height:100%; object-fit:cover; object-position:90% center; display:block; }
.founder-ph {
  width:100%; height:100%;
  display:flex; align-items:center; justify-content:center;
  font-family:var(--serif); font-size:80px; color:rgba(184,150,90,.15);
}

/* ══════════════════════════════════════
   INFO-VERANSTALTUNG
══════════════════════════════════════ */
.info-section {
  padding:96px 0;
  background:var(--cream-d);
  border-top:1px solid var(--border);
}
.info-header { text-align:center; margin-bottom:64px; }
.info-header .section-desc { max-width:640px; margin:0 auto; }
.info-grid {
  display:grid; grid-template-columns:repeat(2, 1fr);
  gap:24px; margin-bottom:64px;
}
@media(max-width:640px){ .info-grid { grid-template-columns:1fr; } }
.info-card {
  background:var(--white);
  border:1px solid var(--border); border-radius:var(--radius);
  overflow:hidden; box-shadow:0 2px 16px rgba(0,0,0,.04);
}
.info-card-accent { height:3px; background:linear-gradient(90deg, var(--gold), var(--rose)); }
.info-card-content { padding:32px 28px; display:flex; flex-direction:column; gap:12px; }
.info-card-num {
  font-family:var(--serif);
  font-size:40px; font-weight:600; line-height:1; color:var(--gold); opacity:.28;
}
.info-card-title {
  font-family:var(--serif);
  font-size:22px; font-weight:600; line-height:1.2; color:var(--black);
}
.info-card-text { font-size:14px; color:var(--muted); line-height:1.8; }
.info-cta-wrap { text-align:center; }

/* ══════════════════════════════════════
   WEBINAR MODAL
══════════════════════════════════════ */
.wb-modal[hidden]{ display:none; }
.wb-modal{
  position:fixed; inset:0; z-index:9998;
  display:flex; align-items:center; justify-content:center;
  padding:16px;
}
.wb-modal__backdrop{
  position:absolute; inset:0;
  background:rgba(17,17,17,.65);
}
.wb-modal__card{
  position:relative; z-index:1;
  width:100%; max-width:600px; max-height:92vh; overflow-y:auto;
  background:var(--gold-bg);
  border:1px solid rgba(200,150,46,.4);
  border-top:4px solid var(--gold);
  border-radius:18px;
  padding:32px 28px 24px;
  text-align:center;
  box-shadow:0 24px 80px rgba(0,0,0,.35);
}
.wb-modal__close{
  position:absolute; top:14px; right:14px;
  width:38px; height:38px; border-radius:50%;
  border:0; background:var(--white); color:var(--black);
  font-size:22px; line-height:1; cursor:pointer;
  transition:background .2s, color .2s;
}
.wb-modal__close:hover{ background:var(--gold); color:var(--white); }
.wb-modal__eyebrow{
  margin:0 0 6px;
  font-size:12px; letter-spacing:.06em;
  color:var(--gold); font-weight:500;
}
.wb-modal__title{
  font-family:var(--serif);
  margin:0 0 6px;
  color:var(--black);
  font-size:clamp(22px,4vw,27px); line-height:1.25; font-weight:600;
}
.wb-modal__sub{
  margin:0 auto 18px; max-width:42ch;
  color:var(--muted); font-size:15px;
}
.wb-modal__form{
  display:flex; justify-content:center;
  background:var(--white);
  border:1px solid var(--border);
  border-radius:12px; padding:8px;
}
.wb-modal__form iframe{ width:100%; max-width:538px; border:0; display:block; height:700px; }
.wb-modal__trust{ margin:16px 0 2px; font-size:12.5px; color:rgba(85,82,80,.55); }
@media(max-width:480px){
  .wb-modal__card{ padding:26px 16px 18px; border-radius:16px; }
}

</style>


<SiteHeader variant="brand-only" />

<Breadcrumbs trail={[
  { label: 'Startseite', href: '/' },
  { label: 'Fachdozentin werden' },
]} />

<main>

<!-- ══════════════════════════════════
     HERO
══════════════════════════════════ -->
<section class="hero">
  <div class="w">
    <span class="section-eye hero-eye">Für Beauty-Profis</span>
    <h1 class="hero-h1">
      Mehr Umsatz mit staatlich geförderten Perfektionstrainings,
      <em>ohne eigene AZAV-Zulassung</em>
    </h1>
    <p class="hero-sub">
      In dieser kostenfreien Info-Veranstaltung erfährst du, wie du als PMU-,
      Microblading- oder Wimpern-Artistin staatlich geförderte Perfektionstrainings
      anbieten kannst – mit flexibler Umsetzung, freier Terminplanung und ohne
      eigene AZAV-Zulassung.
    </p>
    <div class="hero-bullets">
      <div class="hero-bullet">
        <span class="hero-bullet-diamond">◆</span>
        Bis zu 1.500 € Vergütung pro Teilnehmerin (3 Tage Unterricht)
      </div>
      <div class="hero-bullet">
        <span class="hero-bullet-diamond">◆</span>
        Keine eigene AZAV-Zulassung notwendig
      </div>
      <div class="hero-bullet">
        <span class="hero-bullet-diamond">◆</span>
        Staatlich geförderte Perfektionstrainings – auch ohne eigenes Studio
      </div>
    </div>
    <button class="cta-white js-webinar-cta">Zur kostenfreien Info-Veranstaltung anmelden</button>
    <p class="hero-note">Kostenfreie Online Info-Veranstaltung · 4× täglich verfügbar</p>
  </div>
</section>


<!-- ══════════════════════════════════
     PROBLEM | LÖSUNG
══════════════════════════════════ -->
<section class="pl-section">
  <div class="w">
