<!-- ══════════════════════════════════
     WEBINAR MODAL
══════════════════════════════════ -->
<div id="webinar-modal" class="wb-modal" hidden>
  <div class="wb-modal__backdrop" data-wb-close></div>
  <div class="wb-modal__card" role="dialog" aria-modal="true" aria-labelledby="wb-modal-title">
    <button class="wb-modal__close" type="button" data-wb-close aria-label="Schließen">&times;</button>
    <p class="wb-modal__eyebrow">Kostenlose Online-Info-Veranstaltung</p>
    <h2 id="wb-modal-title" class="wb-modal__title">Sichere dir deinen kostenfreien Platz</h2>
    <p class="wb-modal__sub">Wähle einfach einen passenden Termin – 100 % kostenlos und unverbindlich.</p>

    <div class="wb-modal__form">
      <iframe
        id="wbn-29241-iframe"
        title="Info-Veranstaltung: Fachdozentin für Perfektionstrainings"
        frameborder="0"
        allowfullscreen
        height="688"
        data-src="https://21656.webinaris.co/customer/registration/viewer/29241/21656?form=iframe&v=4&mode=N"></iframe>
    </div>

    <p class="wb-modal__trust">Mehrere Termine täglich · Bestätigung &amp; Zugangslink per E-Mail</p>
  </div>
</div>


<script>
  // ── Webinar Modal ──────────────────────────────────────────────────────────
  (() => {
    const modal = document.getElementById('webinar-modal');
    if (!modal) return;
    const iframe = document.getElementById('wbn-29241-iframe') as HTMLIFrameElement | null;
    let loaded = false;
    const open = () => {
      (modal as HTMLElement & { hidden: boolean }).hidden = false;
      document.documentElement.style.overflow = 'hidden';
      if (!loaded && iframe) {
        iframe.src = (iframe as HTMLIFrameElement & { dataset: DOMStringMap }).dataset.src ?? '';
        const s = document.createElement('script');
        s.src = 'https://21656.webinaris.co/iframe/quellcode?v=4';
        s.onload = () => {
          try { (window as any).wbnIframe.getInstance().init('wbn-29241-iframe'); }
          catch (e) { console.warn('Webinaris init', e); }
        };
        document.body.appendChild(s);
        loaded = true;
      }
    };
    const close = () => {
      (modal as HTMLElement & { hidden: boolean }).hidden = true;
      document.documentElement.style.overflow = '';
    };
    document.querySelectorAll('.js-webinar-cta').forEach((b) => b.addEventListener('click', open));
    modal.querySelectorAll('[data-wb-close]').forEach((el) => el.addEventListener('click', close));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !(modal as any).hidden) close(); });
  })();

  // ── Netzwerk-Carousel ──────────────────────────────────────────────────────
  (function () {
    const track    = document.getElementById('net-track') as HTMLElement | null;
    const dotsWrap = document.getElementById('net-dots')  as HTMLElement | null;
    if (!track) return;

    const prev   = document.getElementById('net-prev');
    const next   = document.getElementById('net-next');
    const slides = Array.from(track.querySelectorAll<HTMLElement>('.net-slide'));
    const gap    = 24;
    const step   = () => (slides[0]?.offsetWidth ?? 0) + gap;

    const dots: HTMLButtonElement[] = slides.map((_, i) => {
      const d = document.createElement('button');
      d.className = 'carousel-dot' + (i === 0 ? ' active' : '');
      d.setAttribute('aria-label', `Karte ${i + 1}`);
      d.addEventListener('click', () =>
        track.scrollTo({ left: step() * i, behavior: 'smooth' }),
      );
      dotsWrap?.appendChild(d);
      return d;
    });

    const updateDots = () => {
      const idx = Math.round(track.scrollLeft / (step() || 1));
      dots.forEach((d, i) => d.classList.toggle('active', i === idx));
    };

    track.addEventListener('scroll', updateDots, { passive: true });
    prev?.addEventListener('click', () =>
      track.scrollBy({ left: -step() * 3, behavior: 'smooth' }),
    );
    next?.addEventListener('click', () =>
      track.scrollBy({ left: step() * 3, behavior: 'smooth' }),
    );
  })();
</script>

