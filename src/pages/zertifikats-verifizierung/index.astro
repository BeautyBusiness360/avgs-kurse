---
import SEOLayout from '../../layouts/SEOLayout.astro';
---
<SEOLayout
  title="Zertifikat verifizieren – BeautyBusiness360"
  description="Überprüfen Sie die Echtheit eines BeautyBusiness360-Zertifikats."
  canonical="https://dein-beauty-kurs.de/zertifikats-verifizierung/"
>
<style>
  .verify-page{max-width:1000px;margin:0 auto;padding:3rem 1.5rem 5rem;min-height:60vh;background:#111111;color:#FAF8F5}
  .cert-layout{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;align-items:start;width:100%}
  @media(max-width:680px){.cert-layout{grid-template-columns:1fr}}
  .cert-preview img{width:100%;border-radius:.5rem;box-shadow:0 8px 40px rgba(0,0,0,.5);display:block}
  .cert-info{display:flex;flex-direction:column;gap:1.2rem}
  .status-badge{display:inline-flex;align-items:center;gap:.5rem;padding:.55rem 1.3rem;border-radius:2rem;font-family:var(--sans);font-size:.9rem;font-weight:600;letter-spacing:.03em}
  .status-badge.valid   {background:rgba(6,95,70,.3);color:#6ee7b7;border:1.5px solid #6ee7b7}
  .status-badge.revoked {background:rgba(153,27,27,.3);color:#fca5a5;border:1.5px solid #fca5a5}
  .status-badge.notfound{background:rgba(255,255,255,.06);color:#FAF8F5;border:1.5px solid rgba(255,255,255,.2)}
  .cert-card{background:#1a1a1a;border:1px solid rgba(200,150,46,.3);border-top:3px solid #C8962E;border-radius:1rem;padding:2rem}
  .cert-title{font-family:var(--serif);font-size:1.4rem;color:#FAF8F5;margin:0 0 1.5rem;padding-bottom:1rem;border-bottom:1px solid rgba(255,255,255,.1)}
  .cert-meta{display:flex;flex-direction:column;gap:1.1rem}
  .meta-item{display:flex;flex-direction:column;gap:.15rem}
  .meta-item .label{font-family:var(--sans);font-size:.7rem;color:#C8962E;text-transform:uppercase;letter-spacing:.07em}
  .meta-item strong{font-family:var(--sans);font-size:1rem;color:#FAF8F5;font-weight:600}
  .meta-item code{font-family:monospace;font-size:.75rem;color:rgba(255,255,255,.5);word-break:break-all}
  .spinner{width:34px;height:34px;border:3px solid rgba(255,255,255,.1);border-top-color:#C8962E;border-radius:50%;animation:spin .8s linear infinite}
  @keyframes spin{to{transform:rotate(360deg)}}
  .state-center{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:50vh;gap:1.5rem}
  .state-text{font-family:var(--sans);font-size:.9rem;color:rgba(255,255,255,.6);text-align:center;max-width:420px;line-height:1.6}
</style>

<main class="verify-page">

  <div id="state-loading" class="state-center">
    <div class="spinner"></div>
    <p class="state-text">Zertifikat wird geprüft…</p>
  </div>

  <div id="state-valid" style="display:none">
    <div class="cert-layout">
      <div id="cert-preview-wrap" class="cert-preview">
        <img id="cert-img" src="" alt="Zertifikat">
      </div>
      <div class="cert-info">
        <span class="status-badge valid">✓ Erfolgreich validiert</span>
        <div class="cert-card">
          <h1 id="cert-title" class="cert-title"></h1>
          <div class="cert-meta">
            <div class="meta-item">
              <span class="label">Ausgestellt für</span>
              <strong id="cert-name"></strong>
            </div>
            <div class="meta-item">
              <span class="label">Ausgestellt am</span>
              <strong id="cert-datum"></strong>
            </div>
            <div class="meta-item">
              <span class="label">Ausgestellt von</span>
              <strong>BeautyBusiness360</strong>
            </div>
            <div class="meta-item">
              <span class="label">Link zur Webseite</span>
              <strong><a href="https://dein-beauty-kurs.de" style="color:var(--gold)">dein-beauty-kurs.de</a></strong>
            </div>
            <div class="meta-item">
              <span class="label">Identifikationsnummer</span>
              <code id="cert-id"></code>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="state-revoked" style="display:none;flex-direction:column;align-items:center;gap:1.5rem">
    <span class="status-badge revoked">✗ Zertifikat widerrufen</span>
    <div class="cert-card" style="max-width:520px;width:100%">
      <div class="cert-meta">
        <div class="meta-item"><span class="label">Name</span><strong id="rev-name"></strong></div>
        <div class="meta-item"><span class="label">Kurs</span><strong id="rev-kurs"></strong></div>
      </div>
      <p class="state-text" style="margin-top:1.2rem;text-align:left">Dieses Zertifikat wurde widerrufen und ist nicht mehr gültig.</p>
    </div>
  </div>

  <div id="state-notfound" style="display:none;flex-direction:column;align-items:center;gap:1.5rem;min-height:50vh;justify-content:center">
    <span class="status-badge notfound">Zertifikat nicht gefunden</span>
    <p class="state-text">Diese Identifikationsnummer ist unbekannt. Bitte prüfen Sie den QR-Code oder wenden Sie sich an info@dein-beauty-kurs.de.</p>
  </div>

</main>

<script>
  import { createClient } from '@supabase/supabase-js';
  const sb = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);
  function show(id) {
    ['loading','valid','revoked','notfound'].forEach(s => {
      const el = document.getElementById('state-'+s);
      if (el) el.style.display = s===id ? (s==='valid'?'block':'flex') : 'none';
    });
  }
  function formatDate(str) {
    if (!str) return '';
    return new Date(str+'T00:00:00').toLocaleDateString('de-DE',{day:'numeric',month:'long',year:'numeric'});
  }
  async function verify() {
    const credential = new URLSearchParams(window.location.search).get('credential');
    if (!credential) { show('notfound'); return; }
    try {
      const { data, error } = await sb.from('certificates').select('*').eq('id',credential).maybeSingle();
      if (error||!data) { show('notfound'); return; }
      if (data.status==='widerrufen') {
        document.getElementById('rev-name').textContent = data.vorname+' '+data.nachname;
        document.getElementById('rev-kurs').textContent = data.kurs;
        show('revoked'); return;
      }
      document.getElementById('cert-title').textContent = data.kurs;
      document.getElementById('cert-name').textContent  = data.vorname+' '+data.nachname;
      document.getElementById('cert-datum').textContent = formatDate(data.datum);
      document.getElementById('cert-id').textContent    = data.id;
      const wrap = document.getElementById('cert-preview-wrap');
      if (data.png_url) {
        document.getElementById('cert-img').src = data.png_url;
        wrap.style.display = 'block';
      } else {
        wrap.style.display = 'none';
      }
      show('valid');
    } catch(e) { show('notfound'); }
  }
  verify();
</script>

</SEOLayout>
