---
import SEOLayout from '../../layouts/SEOLayout.astro';
import { supabase } from '../../lib/supabase';
import fs from 'node:fs';
import path from 'node:path';

const { data: allDoz } = await supabase
  .from('dozentinnen')
  .select(`
    slug, first_name, last_name,
    cities(slug, name),
    dozentin_services(services(slug, name, avgs_eligible))
  `)
  .eq('active', true);

const gridDozentinnen = (allDoz ?? [])
  .map((d: any) => {
    const localSlug = d.slug.replace(/-(?:hamburg|berlin|essen|mainz|ulm|elmshorn|wedel)$/, '');
    const rel = `/images/dozentinnen/${localSlug}/${localSlug}.webp`;
    const hasImg = fs.existsSync(path.join(process.cwd(), 'public', rel));
    const profileImg = hasImg ? rel : (d.image_url ?? null);
    return { ...d, localSlug, profileImg };
  })
  .filter((d: any) => d.profileImg);
---
<SEOLayout
  title="Zertifikat verifizieren – BeautyBusiness360"
  description="Prüfen Sie die Echtheit eines BeautyBusiness360-Zertifikats anhand von Name oder Identifikationsnummer."
  canonical="https://dein-beauty-kurs.de/zertifikats-verifizierung/"
>

<style>
  /* Layout */
  .w { max-width:1120px; margin:0 auto; padding:0 40px; }
  @media(max-width:640px){ .w { padding:0 22px; } }

  /* Hero */
  .vf-hero{background:#111111;padding:120px 0 80px;color:#FAF8F5}
  .vf-hero .section-eye{color:#C8962E;font-family:var(--sans);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.15em;display:block;margin-bottom:16px}
  .vf-h1{font-family:var(--serif);font-size:clamp(40px,5vw,72px);color:#FAF8F5;margin:0 0 1rem;line-height:1.1}
  .vf-h1 em{color:#C8962E;font-style:italic}
  .vf-sub{color:rgba(255,255,255,.7);font-family:var(--sans);font-size:1.1rem;max-width:560px;line-height:1.7;margin:16px 0 0}

  /* Search */
  .vf-search-section{background:var(--cream);padding:80px 0}
  .vf-form-card{background:#fff;border-radius:20px;padding:48px;box-shadow:0 4px 32px rgba(0,0,0,.08);max-width:680px;margin:0 auto}
  .vf-form-title{font-family:var(--serif);font-size:1.8rem;color:#111;margin:0 0 32px}
  .vf-fields-row{display:flex;gap:16px}
  .vf-input{border:1.5px solid rgba(0,0,0,.12);border-radius:10px;padding:14px 18px;font-size:15px;font-family:var(--sans);width:100%;box-sizing:border-box;color:var(--black)}
  .vf-input:focus{outline:none;border-color:#C8962E;box-shadow:0 0 0 3px rgba(200,150,46,.15)}
  .vf-input--full{width:100%}
  .vf-or-divider{display:flex;align-items:center;gap:12px;margin:24px 0;color:#999;font-size:13px;font-family:var(--sans)}
  .vf-or-divider::before,.vf-or-divider::after{content:'';flex:1;height:1px;background:rgba(0,0,0,.1)}
  .vf-btn{background:#C8962E;color:#fff;border:none;padding:16px;border-radius:10px;font-size:13px;font-family:var(--sans);font-weight:600;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;margin-top:24px;width:100%}
  .vf-btn:hover{background:#b5831f}

  /* Result */
  .vf-result-section{background:#111111;padding:80px 0}
  .vf-badge{display:inline-flex;align-items:center;padding:10px 24px;border-radius:2rem;font-size:14px;font-family:var(--sans);font-weight:600;margin-bottom:32px}
  .vf-badge--valid{background:rgba(6,95,70,.3);color:#6ee7b7;border:1.5px solid #6ee7b7}
  .vf-badge--revoked{background:rgba(153,27,27,.3);color:#fca5a5;border:1.5px solid #fca5a5}
  .vf-badge--notfound{background:rgba(255,255,255,.06);color:#FAF8F5;border:1.5px solid rgba(255,255,255,.2)}
  .vf-cert-layout{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
  .vf-cert-img img{width:100%;border-radius:16px;box-shadow:0 8px 40px rgba(0,0,0,.5);display:block}
  .vf-cert-card{background:#1a1a1a;border:1px solid rgba(200,150,46,.3);border-top:3px solid #C8962E;border-radius:16px;padding:32px}
  .vf-cert-card__bar{width:40px;height:3px;background:#C8962E;margin-bottom:20px;display:none}
  .vf-cert-title{color:#FAF8F5;font-family:var(--serif);font-size:1.3rem;margin:0 0 1.4rem;padding-bottom:1rem;border-bottom:1px solid rgba(255,255,255,.1)}
  .vf-meta{display:flex;flex-direction:column;gap:1rem}
  .vf-meta-item{display:flex;flex-direction:column;gap:.15rem}
  .vf-label{color:#C8962E;font-family:var(--sans);font-size:11px;text-transform:uppercase;letter-spacing:.07em}
  .vf-meta-item strong{color:#FAF8F5;font-family:var(--sans);font-size:1rem;font-weight:600}
  .vf-meta-item code{color:rgba(255,255,255,.5);font-family:monospace;font-size:12px;word-break:break-all}
  .vf-state-center{display:flex;flex-direction:column;align-items:center;gap:20px;padding:40px 0;color:#FAF8F5;font-family:var(--sans)}
  .vf-state-text{color:rgba(255,255,255,.6);text-align:center;max-width:480px;font-family:var(--sans);font-size:.9rem;line-height:1.7;margin:0}
  .vf-spinner{width:36px;height:36px;border:3px solid rgba(255,255,255,.1);border-top-color:#C8962E;border-radius:50%;animation:vf-spin .8s linear infinite}
  @keyframes vf-spin{to{transform:rotate(360deg)}}

  /* Dozentinnen */
  .vf-doz-section{background:var(--cream);padding:80px 0}
  .vf-doz-section .section-eye,.vf-doz-section .section-title{text-align:left}

  /* Karussell */
  .net-carousel-wrap{position:relative}
  .net-track{display:flex;gap:24px;overflow-x:auto;scroll-snap-type:x mandatory;scroll-behavior:smooth;scrollbar-width:none;padding-bottom:4px}
  .net-track::-webkit-scrollbar{display:none}
  .net-slide{flex:0 0 calc((100% - 48px) / 3);scroll-snap-align:start}
  @media(max-width:860px){.net-slide{flex:0 0 calc((100% - 24px) / 2)}}
  @media(max-width:540px){.net-slide{flex:0 0 100%}}
  .net-card{background:#111111;border:1px solid rgba(255,255,255,.08);border-radius:12px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,.04);display:flex;flex-direction:column;text-decoration:none;color:inherit;transition:box-shadow .3s,transform .25s}
  .net-card:hover{transform:translateY(-4px);box-shadow:0 8px 32px rgba(0,0,0,.1)}
  .net-img-wrap{aspect-ratio:1;overflow:hidden;background:#f0ede8}
  .net-img-wrap img{width:100%;height:100%;object-fit:cover;display:block}
  .net-card-name{display:block;padding:12px 20px 4px;font-size:16px;font-weight:600;color:#FAF8F5;font-family:var(--sans);line-height:1.3}
  .net-card-cta{display:block;padding:0 20px 18px;font-size:11px;font-weight:600;letter-spacing:.10em;text-transform:uppercase;color:#C8962E}
  .carousel-btn{position:absolute;top:38%;width:40px;height:40px;border-radius:50%;background:#fff;border:1px solid var(--border,#e5e0d8);box-shadow:0 2px 8px rgba(0,0,0,.10);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;z-index:2;transition:box-shadow .2s;color:#111}
  .carousel-btn:hover{box-shadow:0 4px 16px rgba(0,0,0,.15)}
  .carousel-prev{left:-20px}
  .carousel-next{right:-20px}
  @media(max-width:860px){.carousel-btn{display:none}}
  .carousel-dots{display:flex;justify-content:center;gap:8px;margin-top:24px}
  @media(max-width:640px){.carousel-dots{flex-wrap:wrap;max-width:100%;box-sizing:border-box}}
  .carousel-dot{width:8px;height:8px;border-radius:50%;border:1.5px solid #888;background:transparent;cursor:pointer;padding:0;transition:background .2s,border-color .2s}
  .carousel-dot.active{background:#C8962E;border-color:#C8962E}

  /* CTA */
  .vf-cta-section{background:#111111;padding:100px 0;text-align:left}
  .vf-cta-h2{color:#FAF8F5;font-family:var(--serif);font-size:clamp(36px,4vw,60px);margin:0 0 .5rem;line-height:1.1}
  .vf-cta-h2 em{color:#C8962E;font-style:normal}
  .vf-cta-sub{color:rgba(255,255,255,.6);font-family:var(--sans);font-size:1rem;margin:16px 0 32px;line-height:1.7}
  .vf-cta-section .cta-gold{background:#C8962E;color:#fff;padding:16px 40px;border-radius:8px;display:inline-block;text-decoration:none;font-size:13px;font-family:var(--sans);font-weight:600;letter-spacing:.1em;text-transform:uppercase}
  .vf-cta-section .cta-gold:hover{background:#b5831f}

  /* Mobile */
  @media(max-width:680px){
    .vf-fields-row{flex-direction:column}
    .vf-cert-layout{grid-template-columns:1fr}
    .vf-form-card{padding:32px 24px}
  }
</style>

<!-- 1. Hero -->
<section class="vf-hero">
  <div class="w">
    <span class="section-eye">ZERTIFIKAT-PRÜFUNG</span>
    <h1 class="vf-h1">Zertifikat <em>verifizieren</em></h1>
    <p class="vf-sub">Geben Sie Name oder Identifikationsnummer ein, um die Echtheit eines BeautyBusiness360-Zertifikats zu prüfen.</p>
  </div>
</section>

<!-- 2. Suchformular -->
<section class="vf-search-section">
  <div class="w">
    <div class="vf-form-card">
      <h2 class="vf-form-title">Zertifikat prüfen</h2>
      <div class="vf-fields-row">
        <input type="text" id="inp-vorname" placeholder="Vorname" class="vf-input" />
        <input type="text" id="inp-nachname" placeholder="Nachname" class="vf-input" />
      </div>
      <div class="vf-or-divider"><span>oder</span></div>
      <input type="text" id="inp-id" placeholder="Identifikationsnummer (UUID)" class="vf-input vf-input--full" />
      <button id="vf-btn" class="vf-btn">Prüfen</button>
    </div>
  </div>
</section>

<!-- 3. Ergebnis -->
<section id="vf-result" class="vf-result-section" style="display:none">
  <div class="w">
    <div id="vf-loading" class="vf-state-center">
      <div class="vf-spinner"></div>
      <p>Zertifikat wird geprüft…</p>
    </div>
    <div id="vf-valid" style="display:none">
      <span class="vf-badge vf-badge--valid">✓ Erfolgreich validiert</span>
      <div class="vf-cert-layout">
        <div id="vf-img-wrap" class="vf-cert-img">
          <img id="vf-img" src="" alt="Zertifikat" />
        </div>
        <div class="vf-cert-card">
          <div class="vf-cert-card__bar"></div>
          <h2 id="vf-kurs" class="vf-cert-title"></h2>
          <div class="vf-meta">
            <div class="vf-meta-item"><span class="vf-label">Ausgestellt für</span><strong id="vf-name"></strong></div>
            <div class="vf-meta-item"><span class="vf-label">Ausgestellt am</span><strong id="vf-datum"></strong></div>
            <div class="vf-meta-item"><span class="vf-label">Ausgestellt von</span><strong>BeautyBusiness360</strong></div>
            <div class="vf-meta-item"><span class="vf-label">Identifikationsnummer</span><code id="vf-cert-id"></code></div>
          </div>
        </div>
      </div>
    </div>
    <div id="vf-revoked" style="display:none" class="vf-state-center">
      <span class="vf-badge vf-badge--revoked">✗ Zertifikat widerrufen</span>
      <p class="vf-state-text">Dieses Zertifikat wurde widerrufen und ist nicht mehr gültig.</p>
    </div>
    <div id="vf-notfound" style="display:none" class="vf-state-center">
      <span class="vf-badge vf-badge--notfound">Zertifikat nicht gefunden</span>
      <p class="vf-state-text">Diese Angaben konnten keinem gültigen Zertifikat zugeordnet werden. Bitte prüfen Sie den QR-Code oder wenden Sie sich an info@dein-beauty-kurs.de.</p>
    </div>
  </div>
</section>

<!-- 4. Dozentinnen -->
<section class="vf-doz-section">
  <div class="w">
    <span class="section-eye">NETZWERK</span>
    <h2 class="section-title">Unsere zertifizierten <em>Fachdozentinnen</em></h2>
    <div class="net-carousel-wrap">
      <button class="carousel-btn carousel-prev" id="vf-net-prev" aria-label="Vorherige Karte">&#8592;</button>
      <div class="net-track" id="vf-net-track">
        {gridDozentinnen.map((d: any) => (
          <div class="net-slide">
            <a href={`/dozentinnen/${d.slug}/`} class="net-card">
              <div class="net-img-wrap">
                <img
                  src={d.profileImg}
                  alt={`Fachdozentin ${d.first_name} ${d.last_name}`}
                  width="320" height="320"
                  loading="lazy"
                />
              </div>
              <span class="net-card-name">{d.first_name} {d.last_name}</span>
              <span class="net-card-cta">Profil ansehen →</span>
            </a>
          </div>
        ))}
      </div>
      <button class="carousel-btn carousel-next" id="vf-net-next" aria-label="Nächste Karte">&#8594;</button>
    </div>
    <div class="carousel-dots" id="vf-net-dots" aria-hidden="true"></div>
  </div>
</section>

<!-- 5. CTA -->
<section class="vf-cta-section">
  <div class="w">
    <h2 class="vf-cta-h2">Selbst <em>Fachdozentin</em> werden?</h2>
    <p class="vf-cta-sub">Biete staatlich geförderte Perfektionstrainings an – ohne eigene AZAV-Zulassung.</p>
    <a href="/fachdozentin-werden/" class="cta-gold">Jetzt informieren</a>
  </div>
</section>

<script>
  import { createClient } from '@supabase/supabase-js';
  const sb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  function formatDate(str: string): string {
    if (!str) return '';
    return new Date(str + 'T00:00:00').toLocaleDateString('de-DE', {
      day: 'numeric', month: 'long', year: 'numeric'
    });
  }

  function showState(state: 'loading' | 'valid' | 'revoked' | 'notfound') {
    const result = document.getElementById('vf-result')!;
    result.style.display = 'block';
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
    ['loading', 'valid', 'revoked', 'notfound'].forEach(s => {
      const el = document.getElementById('vf-' + s)!;
      el.style.display = s === state ? (s === 'valid' ? 'block' : 'flex') : 'none';
    });
  }

  async function search() {
    const vn = (document.getElementById('inp-vorname') as HTMLInputElement).value.trim();
    const nn = (document.getElementById('inp-nachname') as HTMLInputElement).value.trim();
    const credId = (document.getElementById('inp-id') as HTMLInputElement).value.trim();

    if (!credId && !vn && !nn) return;

    showState('loading');

    try {
      let data: any = null;

      if (credId) {
        const res = await sb.from('certificates').select('*').eq('id', credId).maybeSingle();
        data = res.data;
      } else {
        const q = sb.from('certificates').select('*');
        if (vn) q.ilike('vorname', vn);
        if (nn) q.ilike('nachname', nn);
        const res = await q.maybeSingle();
        data = res.data;
      }

      if (!data) { showState('notfound'); return; }

      if (data.status === 'widerrufen') { showState('revoked'); return; }

      (document.getElementById('vf-kurs') as HTMLElement).textContent = data.kurs;
      (document.getElementById('vf-name') as HTMLElement).textContent = data.vorname + ' ' + data.nachname;
      (document.getElementById('vf-datum') as HTMLElement).textContent = formatDate(data.datum);
      (document.getElementById('vf-cert-id') as HTMLElement).textContent = data.id;

      const imgWrap = document.getElementById('vf-img-wrap')!;
      if (data.png_url) {
        (document.getElementById('vf-img') as HTMLImageElement).src = data.png_url;
        imgWrap.style.display = 'block';
      } else {
        imgWrap.style.display = 'none';
      }

      showState('valid');
    } catch (e) {
      showState('notfound');
    }
  }

  document.getElementById('vf-btn')!.addEventListener('click', search);

  document.getElementById('inp-id')!.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter') search();
  });

  // Auto-search on page load if ?credential=UUID is present
  const credential = new URLSearchParams(window.location.search).get('credential');
  if (credential) {
    (document.getElementById('inp-id') as HTMLInputElement).value = credential;
    search();
  }
</script>

<script>
  (function () {
    const track    = document.getElementById('vf-net-track') as HTMLElement | null;
    const dotsWrap = document.getElementById('vf-net-dots')  as HTMLElement | null;
    if (!track) return;
    const prev   = document.getElementById('vf-net-prev');
    const next   = document.getElementById('vf-net-next');
    const slides = Array.from(track.querySelectorAll<HTMLElement>('.net-slide'));
    const gap    = 24;
    const step   = () => (slides[0]?.offsetWidth ?? 0) + gap;
    const dots: HTMLButtonElement[] = slides.map((_, i) => {
      const d = document.createElement('button');
      d.className = 'carousel-dot' + (i === 0 ? ' active' : '');
      d.setAttribute('aria-label', `Karte ${i + 1}`);
      d.addEventListener('click', () =>
        track.scrollTo({ left: step() * i, behavior: 'smooth' })
      );
      dotsWrap?.appendChild(d);
      return d;
    });
    const updateDots = () => {
      const idx = Math.round(track.scrollLeft / (step() || 1));
      dots.forEach((d, i) => d.classList.toggle('active', i === idx));
    };
    track.addEventListener('scroll', updateDots, { passive: true });
    prev?.addEventListener('click', () =>
      track.scrollBy({ left: -step() * 3, behavior: 'smooth' })
    );
    next?.addEventListener('click', () =>
      track.scrollBy({ left: step() * 3, behavior: 'smooth' })
    );
  })();
</script>

</SEOLayout>
