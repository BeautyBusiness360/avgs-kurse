---
import SEOLayout from '../layouts/SEOLayout.astro';
---

<SEOLayout
  title="Impressum – BeautyBusiness360"
  description="Impressum der Website dein-beauty-kurs.de – ein Projekt der Northpoint Consulting FZ-LLC unter der Marke BeautyBusiness360."
  canonical="https://dein-beauty-kurs.de/impressum/"
>

<style>
:root {
  --cream:  #FAF8F5;
  --black:  #111111;
  --gold:   #C8962E;
  --muted:  #555250;
  --border: #E8E2D9;
  --serif:  'Cormorant Garamond', Georgia, 'Times New Roman', serif;
  --sans:   'Inter', system-ui, sans-serif;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--cream);
  color: var(--black);
  font-family: var(--sans);
  font-size: 16px;
  line-height: 1.75;
  -webkit-font-smoothing: antialiased;
}
.page-header {
  border-bottom: 1px solid var(--border);
  padding: 24px 40px;
}
.page-header a {
  font-family: var(--sans);
  font-size: 13px;
  font-weight: 600;
  color: var(--black);
  text-decoration: none;
  letter-spacing: .06em;
}
.page-header a:hover { color: var(--gold); }
.page-wrap {
  max-width: 720px;
  margin: 0 auto;
  padding: 72px 40px 96px;
}
@media (max-width: 640px) {
  .page-header { padding: 20px 22px; }
  .page-wrap { padding: 48px 22px 72px; }
}
h1 {
  font-family: var(--serif);
  font-size: clamp(36px, 5vw, 52px);
  font-weight: 600;
  line-height: 1.08;
  color: var(--black);
  margin-bottom: 48px;
}
h2 {
  font-family: var(--sans);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--gold);
  margin-top: 48px;
  margin-bottom: 16px;
}
p {
  font-size: 15px;
  color: var(--muted);
  line-height: 1.9;
  margin-bottom: 8px;
}
.site-footer {
  background: var(--black);
  border-top: 1px solid rgba(255,255,255,.06);
  padding: 32px 40px;
}
@media (max-width: 640px) { .site-footer { padding: 32px 22px; } }
.footer-inner {
  max-width: 1120px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16px;
}
.footer-copy { font-size: 12px; color: rgba(255,255,255,.25); }
.footer-links { display: flex; gap: 24px; }
.footer-links a {
  font-size: 12px;
  color: rgba(255,255,255,.35);
  text-decoration: none;
  transition: color .2s;
}
.footer-links a:hover { color: rgba(255,255,255,.75); }
</style>

<header class="page-header">
