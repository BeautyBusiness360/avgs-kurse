---
import SEOLayout from '../../layouts/SEOLayout.astro';
import { supabase } from '../../lib/supabase';

export const prerender = true;

export async function getStaticPaths() {
  const { data: dozentinnen, error } = await supabase
    .from('dozentinnen')
    .select(`
      slug,
      first_name,
      last_name,
      bio_short,
      rating,
      review_count,
      avgs_certified,
      jotform_id,
      image_url,
      logo_url,
      gallery_images,
      languages,
      cities(slug, name),
      dozentin_services(
        services(slug, name, avgs_eligible, description_template)
      )
    `)
    .eq('active', true)
    .order('last_name', { ascending: true });

  if (error) {
    console.error('[getStaticPaths] Supabase error:', error.message);
    return [];
  }

  if (!dozentinnen || dozentinnen.length === 0) {
    console.error('[getStaticPaths] Keine Dozentinnen gefunden');
    return [];
  }

  console.log(`[getStaticPaths] ${dozentinnen.length} Dozentinnen geladen`);

  const paths = [];

  for (const d of dozentinnen) {
    if (!d.slug || typeof d.slug !== 'string') {
      console.warn('[getStaticPaths] Ungültiger slug:', d);
      continue;
    }

    const city = Array.isArray(d.cities) ? d.cities[0] : d.cities;
    if (!city || !city.slug) {
      console.warn('[getStaticPaths] Fehlende City für:', d.slug);
      continue;
    }

    const services = Array.isArray(d.dozentin_services)
      ? d.dozentin_services.map(ds => ds?.services ?? null).filter(Boolean)
      : [];

    console.log(`[getStaticPaths] ✓ ${d.slug} (${services.length} Services)`);

    paths.push({
      params: { slug: d.slug },
      props: {
        dozentin: {
          ...d,
          services
        }
      }
    });
  }

  console.log(`[getStaticPaths] ${paths.length} Seiten werden gebaut`);
  return paths;
}

const { dozentin } = Astro.props;
const city     = Array.isArray(dozentin.cities) ? dozentin.cities[0] : dozentin.cities;
const services = dozentin.services ?? [];

const hasImage    = !!dozentin.image_url;
const hasRating   = (dozentin.review_count ?? 0) > 0;
const hasServices = services.length > 0;
const hasBio      = !!dozentin.bio_short;
const hasForm     = !!dozentin.jotform_id;
const fullName    = `${dozentin.first_name} ${dozentin.last_name}`;

const primaryService = services[0]?.name ?? 'Beauty Kurs';

const seo = {
  title:
    `${fullName} – ${primaryService} ${city.name} | AVGS gefördert`,
  description:
    dozentin.bio_short ??
    `${primaryService} Einzelcoaching in ${city.name} ` +
    `mit ${fullName}. Staatlich gefördert über AVGS. ` +
    `Jetzt kostenlos starten.`,
  canonical:
    `https://dein-beauty-kurs.de/dozentinnen/${dozentin.slug}/`
};

const schema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": `${fullName} – Beauty Kurse`,
  "url": seo.canonical,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": city.name,
    "addressCountry": "DE"
  },
  ...(hasRating && {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": dozentin.rating,
      "reviewCount": dozentin.review_count
    }
  }),
  ...(hasServices && {
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Kurse",
      "itemListElement": services.map((s: any) => ({
        "@type": "Course",
        "name": s.name,
        "provider": {
          "@type": "Person",
          "name": fullName
        }
      }))
    }
  })
};
---

<SEOLayout title={seo.title} description={seo.description}
           canonical={seo.canonical} schema={schema}>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<style>
/* ── Design tokens (HOA Academy) ─────────────────────────── */
:root {
  --key1:   #6D6FFB;
  --key1-dk:#5254d4;
  --key2:   #131B3C;
  --dark:   #07071A;
  --light:  #F7F7F7;
  --muted:  #6B7280;
  --white:  #FFFFFF;
  --font:   'Manrope', system-ui, sans-serif;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body {
  background: var(--white);
  color: var(--dark);
  font-family: var(--font);
  font-size: 16px;
  line-height: 1.5;
}

/* ── Wrapper ─────────────────────────────────────────────── */
.w {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 40px;
}
@media (max-width: 640px) { .w { padding: 0 20px; } }

/* ── HEADER ──────────────────────────────────────────────── */
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--white);
  border-bottom: 1px solid #E5E7EB;
}
.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
}
.brand {
  font-size: 18px;
  font-weight: 700;
  color: var(--dark);
  text-decoration: none;
  letter-spacing: -0.3px;
}
.btn-key1 {
  display: inline-block;
  background: var(--key1);
  color: var(--white);
  font-family: var(--font);
  font-size: 14px;
  font-weight: 600;
  padding: 10px 24px;
  border-radius: 6px;
  text-decoration: none;
  transition: background 0.2s;
}
.btn-key1:hover { background: var(--key1-dk); }
.btn-outline {
  display: inline-block;
  border: 2px solid var(--key1);
  color: var(--key1);
  font-family: var(--font);
  font-size: 14px;
  font-weight: 600;
  padding: 10px 24px;
  border-radius: 6px;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}
.btn-outline:hover { background: var(--key1); color: var(--white); }

/* ── HERO SECTION ────────────────────────────────────────── */
.hero-section {
  padding: 80px 0 0;
}
.hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: start;
}
@media (max-width: 900px) {
  .hero-grid { grid-template-columns: 1fr; gap: 48px; }
}
/* Left column */
.hero-left {}
.hero-h1 {
  font-size: clamp(28px, 4vw, 44px);
  font-weight: 800;
  line-height: 1.15;
  color: var(--dark);
  margin-bottom: 24px;
  letter-spacing: -0.5px;
}
.hero-intro {
  font-size: 16px;
  font-weight: 400;
  color: var(--muted);
  line-height: 1.7;
  margin-bottom: 20px;
}
.hero-bullets {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 20px;
}
.hero-bullets li {
  font-size: 15px;
  font-weight: 500;
  color: var(--dark);
  padding-left: 20px;
  position: relative;
}
.hero-bullets li::before {
  content: '–';
  position: absolute;
  left: 0;
  color: var(--key1);
}
.hero-note {
  font-size: 14px;
  font-weight: 500;
  color: var(--dark);
  margin-bottom: 32px;
  line-height: 1.6;
}
.hero-cta-row {
  margin-bottom: 32px;
}
.hero-badges {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
.hero-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--light);
  border: 1px solid #E5E7EB;
  border-radius: 20px;
  padding: 6px 14px;
  font-size: 13px;
  font-weight: 600;
  color: var(--dark);
}
.hero-badge::before {
  content: '✓';
  color: var(--key1);
  font-weight: 700;
}
/* Right column */
.hero-right {}
.hero-img {
  width: 100%;
  height: 400px;
  object-fit: cover;
  border-radius: 8px;
  display: block;
}
.hero-img-placeholder {
  width: 100%;
  height: 400px;
  background: linear-gradient(135deg, #E8E8FF, #D4D4FF);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--key1);
  font-size: 48px;
}
.hero-pathways {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 24px;
}
@media (max-width: 640px) { .hero-pathways { grid-template-columns: 1fr; } }
.pathway-box {
  background: var(--key2);
  border-radius: 8px;
  padding: 20px;
  text-decoration: none;
  display: block;
  transition: opacity 0.2s;
}
.pathway-box:hover { opacity: 0.9; }
.pathway-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 8px;
  line-height: 1.3;
}
.pathway-desc {
  font-size: 12px;
  font-weight: 400;
  color: rgba(255,255,255,0.65);
  line-height: 1.5;
}

/* ── COURSES SECTION ──────────────────────────────────────── */
.courses-section {
  padding: 80px 0;
  border-top: 1px solid #E5E7EB;
}
.section-title-row {
  margin-bottom: 48px;
}
.section-h2 {
  font-size: clamp(22px, 3vw, 34px);
  font-weight: 800;
  color: var(--dark);
  line-height: 1.2;
  letter-spacing: -0.4px;
  margin-bottom: 12px;
}
.section-intro {
  font-size: 16px;
  font-weight: 400;
  color: var(--muted);
  line-height: 1.7;
  max-width: 640px;
}
.courses-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 24px;
}
@media (max-width: 700px) { .courses-grid { grid-template-columns: 1fr; } }
/* Course card */
.course-card {
  background: var(--white);
  border: 1px solid #E5E7EB;
  border-radius: 10px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.25s;
}
.course-card:hover { box-shadow: 0 8px 32px rgba(109,111,251,0.12); }
.course-img {
  width: 100%;
  height: 200px;
  object-fit: cover;
  display: block;
}
.course-img-ph {
  width: 100%;
  height: 200px;
  background: linear-gradient(135deg, #EBEBFF, #D8D9FF);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36px;
  color: var(--key1);
}
.course-body {
  padding: 24px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.course-name {
  font-size: 18px;
  font-weight: 700;
  color: var(--dark);
  line-height: 1.3;
}
.course-level {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.06em;
  padding: 4px 10px;
  border-radius: 20px;
  background: rgba(109,111,251,0.1);
  color: var(--key1);
}
.course-specs {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid #E5E7EB;
  border-radius: 6px;
  overflow: hidden;
}
.spec-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 14px;
  border-bottom: 1px solid #E5E7EB;
  gap: 8px;
}
.spec-row:last-child { border-bottom: none; }
.spec-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--muted);
  flex-shrink: 0;
}
.spec-val {
  font-size: 12px;
  font-weight: 600;
  color: var(--dark);
  text-align: right;
}
.course-foot {
  padding: 16px 24px;
  border-top: 1px solid #E5E7EB;
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}
.btn-ghost {
  flex: 1;
  display: inline-block;
  text-align: center;
  background: var(--light);
  color: var(--dark);
  font-family: var(--font);
  font-size: 13px;
  font-weight: 600;
  padding: 10px 16px;
  border-radius: 6px;
  text-decoration: none;
  transition: background 0.2s;
  min-width: 0;
}
.btn-ghost:hover { background: #E5E7EB; }
.btn-primary-sm {
  flex: 1;
  display: inline-block;
  text-align: center;
  background: var(--key1);
  color: var(--white);
  font-family: var(--font);
  font-size: 13px;
  font-weight: 600;
  padding: 10px 16px;
  border-radius: 6px;
  text-decoration: none;
  transition: background 0.2s;
  min-width: 0;
}
.btn-primary-sm:hover { background: var(--key1-dk); }

/* ── GALLERY SECTION ──────────────────────────────────────── */
.gallery-section {
  padding: 80px 0;
  border-top: 1px solid #E5E7EB;
}
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin-top: 32px;
}
@media (max-width: 640px) { .gallery-grid { grid-template-columns: repeat(2, 1fr); } }
.gallery-cell {
  border-radius: 8px;
  overflow: hidden;
  aspect-ratio: 1;
}
.gallery-cell img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}
.gallery-cell:hover img { transform: scale(1.04); }
.gallery-ph {
  aspect-ratio: 1;
  background: linear-gradient(135deg, #EBEBFF, #D8D9FF);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--key1);
  font-size: 28px;
}

/* ── FINAL CTA SECTION ────────────────────────────────────── */
.final-section {
  padding: 80px 0;
  background: var(--key2);
  border-top: 1px solid #E5E7EB;
}
.final-inner { text-align: center; }
.final-eyebrow {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--key1);
  display: block;
  margin-bottom: 16px;
}
.final-h2 {
  font-size: clamp(26px, 4vw, 44px);
  font-weight: 800;
  color: var(--white);
  line-height: 1.15;
  letter-spacing: -0.4px;
  margin-bottom: 16px;
}
.final-sub {
  font-size: 16px;
  font-weight: 400;
  color: rgba(255,255,255,0.6);
  line-height: 1.7;
  max-width: 520px;
  margin: 0 auto 40px;
}
.final-form {}

/* ── FOOTER ──────────────────────────────────────────────── */
.site-footer {
  background: var(--dark);
  padding: 28px 0;
}
.footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16px;
}
.footer-copy {
  font-size: 13px;
  color: rgba(255,255,255,0.3);
}
.footer-links {
  display: flex;
  gap: 24px;
}
.footer-links a {
  font-size: 13px;
  color: rgba(255,255,255,0.4);
  text-decoration: none;
  transition: color 0.2s;
}
.footer-links a:hover { color: rgba(255,255,255,0.8); }
</style>

<!-- ══════════════════════════════════════════════
     HEADER
══════════════════════════════════════════════ -->
<header class="site-header">
  <div class="w">
    <div class="header-inner">
      <a href="/" class="brand">BeautyBusiness360</a>
      <a href="/fachdozentin-werden/" class="btn-key1">Fachdozentin werden</a>
    </div>
  </div>
</header>

<main>

<!-- ══════════════════════════════════════════════
     HERO
══════════════════════════════════════════════ -->
<section class="hero-section">
  <div class="w">
    <div class="hero-grid">

      <!-- LEFT: text + CTA -->
      <div class="hero-left">
        <h1 class="hero-h1">
          Kostenfreie 1:1&#8209;Perfektionstrainings mit {fullName} in {city.name} (AVGS)
        </h1>

        <p class="hero-intro">
          Ob du neu in die Beauty&#8209;Branche einsteigst oder bereits als Kosmetikerin
          arbeitest: Bei {fullName} kannst du staatlich geförderte Beauty&#8209;Schulungen
          kostenfrei absolvieren.
        </p>

        <ul class="hero-bullets">
          <li>Basisschulungen für Anfängerinnen</li>
          <li>Perfektionstrainings für Fortgeschrittene</li>
        </ul>

        <p class="hero-note">
          Alle Maßnahmen sind AZAV&#8209;zertifiziert und zu 100&thinsp;% förderfähig
          über der Agentur für Arbeit
        </p>

        <div class="hero-cta-row">
          <a href="#anmeldung" class="btn-key1">Kostenfreie Anmeldung starten</a>
        </div>

        <div class="hero-badges">
          <span class="hero-badge">100&thinsp;% kostenfrei bei Bewilligung</span>
          <span class="hero-badge">AZAV - zertifizierte Schulungen</span>
        </div>
      </div>

      <!-- RIGHT: image + pathway boxes -->
      <div class="hero-right">
        {hasImage
          ? <img
              class="hero-img"
              src={dozentin.image_url}
              alt={`${fullName} – ${primaryService} Dozentin in ${city.name}`}
              width="600" height="400"
              loading="eager"
            />
          : <div class="hero-img-placeholder">✦</div>
        }

        <div class="hero-pathways">
          <a href="#anmeldung" class="pathway-box">
            <div class="pathway-title">Fachkosmetikerin werden</div>
            <div class="pathway-desc">
              100&thinsp;% förderfähig mit Bildungsgutschein
              (für Teilnehmende ohne Vorkenntnisse)
            </div>
          </a>
          <a href="#anmeldung" class="pathway-box">
            <div class="pathway-title">Master Class - Next Level</div>
            <div class="pathway-desc">
              Für Fortgeschrittene – 100&thinsp;% kostenfrei
              (Perfektionstraining mit AVGS&#8209;Gutschein)
            </div>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ══════════════════════════════════════════════
     KURSE / COURSE CARDS
══════════════════════════════════════════════ -->
{hasServices && (
  <section class="courses-section">
    <div class="w">
      <div class="section-title-row">
        <h2 class="section-h2">
          Kostenlose Beauty- &amp; Kosmetik-Weiterbildungen in {city.name} mit {fullName}
        </h2>
        <p class="section-intro">
          Ob Einstieg oder Weiterentwicklung: Bei {fullName} kannst du staatlich
          geförderte Beauty- &amp; Kosmetik-Weiterbildungen kostenfrei absolvieren.
        </p>
      </div>

      <div class="courses-grid">
        {services.map((s: any) => {
          const isAvgs = !!s.avgs_eligible;
          const level  = isAvgs
            ? 'Perfektionstraining für Fortgeschrittene (AVGS)'
            : 'Intensive Weiterbildung für Anfängerinnen';
          const dauer  = isAvgs ? '40 U. Stunden' : '350 U. Stunden';
          const zeiten = isAvgs ? 'Nach Vereinbarung' : '09:00 - 17:00 Uhr';
          const foerd  = isAvgs ? 'Kostenfrei mit AVGS - Gutschein' : 'Kostenfrei mit Bildungsgutschein';
          const begin  = isAvgs ? 'Ab sofort' : 'Nächster Termin auf Anfrage';
          return (
            <div class="course-card">
              {hasImage
                ? <img
                    class="course-img"
                    src={dozentin.image_url}
                    alt={`${s.name} – ${city.name}`}
                    width="400" height="200"
                    loading="lazy"
                  />
                : <div class="course-img-ph">✦</div>
              }
              <div class="course-body">
                <h3 class="course-name">{s.name}</h3>
                <span class="course-level">{level}</span>
                <div class="course-specs">
                  <div class="spec-row">
                    <span class="spec-label">Dauer Einsteigerkurs:</span>
                    <span class="spec-val">{dauer}</span>
                  </div>
                  <div class="spec-row">
                    <span class="spec-label">Unterrichtszeiten:</span>
                    <span class="spec-val">{zeiten}</span>
                  </div>
                  <div class="spec-row">
                    <span class="spec-label">Unterrichtsform:</span>
                    <span class="spec-val">Hybridunterricht</span>
                  </div>
                  <div class="spec-row">
                    <span class="spec-label">Förderung:</span>
                    <span class="spec-val">{foerd}</span>
                  </div>
                  <div class="spec-row">
                    <span class="spec-label">Kursbeginn:</span>
                    <span class="spec-val">{begin}</span>
                  </div>
                </div>
              </div>
              <div class="course-foot">
                <a href="#anmeldung" class="btn-ghost">Kostenfreie Unterlagen erhalten</a>
                <a href="#anmeldung" class="btn-primary-sm">Start in deine Weiterbildung</a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
)}


<!-- ══════════════════════════════════════════════
     GALERIE
══════════════════════════════════════════════ -->
<section class="gallery-section">
  <div class="w">
    <div class="section-title-row">
      <h2 class="section-h2">
        Ergebnisse &amp; Arbeiten – Galerie von {fullName}
      </h2>
      <p class="section-intro">
        Eine Auswahl realer Arbeiten und Ergebnisse aus der Praxis.
      </p>
    </div>

    {(() => {
      const gallery = Array.isArray(dozentin.gallery_images)
        ? dozentin.gallery_images.filter(Boolean).slice(0, 9)
        : [];
      return (
        <div class="gallery-grid">
          {gallery.length > 0
            ? gallery.map((img: string, i: number) => (
                <div class="gallery-cell">
                  <img
                    src={img}
                    alt={`${fullName} – Arbeitsprobe ${i + 1}`}
                    width="360" height="360"
                    loading="lazy"
                  />
                </div>
              ))
            : [1,2,3,4,5,6].map((n: number) => (
                <div class="gallery-ph">✦</div>
              ))
          }
        </div>
      );
    })()}
  </div>
</section>


<!-- ══════════════════════════════════════════════
     FINAL CTA / FORM
══════════════════════════════════════════════ -->
