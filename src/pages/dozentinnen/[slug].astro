                <span class="mc-icon">{icon}</span>
                <span class="mc-name">{s.name}</span>
                <span class="mc-tagline">
                  1:1 Coaching · {city.name}
                </span>
              </div>

              <div class="mc-body">
                <div class="mc-specs">
                  <div class="mc-spec">
                    <span class="mc-spec-label">Umfang</span>
                    <span class="mc-spec-val">40 UE</span>
                  </div>
                  <div class="mc-spec">
                    <span class="mc-spec-label">Format</span>
                    <span class="mc-spec-val">Präsenz</span>
                  </div>
                  <div class="mc-spec">
                    <span class="mc-spec-label">Kosten</span>
                    <span class="mc-spec-val">100% AVGS</span>
                  </div>
                  <div class="mc-spec">
                    <span class="mc-spec-label">Zertifikat</span>
                    <span class="mc-spec-val">Inkl.</span>
                  </div>
                </div>

                <ul class="mc-highlights">
                  {highlights.map(h => <li>{h}</li>)}
