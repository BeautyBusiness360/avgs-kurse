          function preload() {
            var lb = document.querySelector('.lightbox-' + jfid);
            if (lb) {
              var iframe = document.getElementById(jfid);
              if (iframe && !iframe.src) {
                iframe.src = 'https://form.jotform.com/' + jfid;
              }
            }
          }
          if ('requestIdleCallback' in window) {
            requestIdleCallback(preload, { timeout: 3000 });
          } else {
