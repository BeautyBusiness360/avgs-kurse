---
import SEOLayout from '../../layouts/SEOLayout.astro';
import { supabase } from '../../lib/supabase';

export const prerender = true;

export async function getStaticPaths() {
  const { data: dozentinnen, error } = await supabase
    .from('dozentinnen')
    .select(`
      slug,
      first_name,
      last_name,
      bio_short,
      rating,
      review_count,
      avgs_certified,
      jotform_id,
      image_url,
      logo_url,
      gallery_images,
      languages,
      cities(slug, name),
      dozentin_services(
        services(slug, name, avgs_eligible, description_template)
      )
    `)
    .eq('active', true)
    .order('last_name', { ascending: true });

  if (error) {
    console.error('[getStaticPaths] Supabase error:', error.message);
    return [];
  }

  if (!dozentinnen || dozentinnen.length === 0) {
    console.error('[getStaticPaths] Keine Dozentinnen gefunden');
    return [];
  }

  console.log(`[getStaticPaths] ${dozentinnen.length} Dozentinnen geladen`);

  const paths = [];

  for (const d of dozentinnen) {
    if (!d.slug || typeof d.slug !== 'string') {
      console.warn('[getStaticPaths] Ungültiger slug:', d);
      continue;
    }

    const city = Array.isArray(d.cities) ? d.cities[0] : d.cities;
    if (!city || !city.slug) {
      console.warn('[getStaticPaths] Fehlende City für:', d.slug);
      continue;
    }

    const services = Array.isArray(d.dozentin_services)
      ? d.dozentin_services.map(ds => ds?.services ?? null).filter(Boolean)
      : [];

    console.log(`[getStaticPaths] ✓ ${d.slug} (${services.length} Services)`);

    paths.push({
      params: { slug: d.slug },
      props: {
        dozentin: {
          ...d,
          services
        }
      }
    });
  }

  console.log(`[getStaticPaths] ${paths.length} Seiten werden gebaut`);
  return paths;
}

const { dozentin } = Astro.props;
const city     = Array.isArray(dozentin.cities) ? dozentin.cities[0] : dozentin.cities;
const services = dozentin.services ?? [];

const hasImage    = !!dozentin.image_url;
const hasRating   = (dozentin.review_count ?? 0) > 0;
const hasServices = services.length > 0;
const hasBio      = !!dozentin.bio_short;
const hasForm     = !!dozentin.jotform_id;
const fullName    = `${dozentin.first_name} ${dozentin.last_name}`;

const primaryService = services[0]?.name ?? 'Beauty Kurs';

const seo = {
  title:
    `${fullName} – ${primaryService} ${city.name} | AVGS gefördert`,
  description:
    dozentin.bio_short ??
    `${primaryService} Einzelcoaching in ${city.name} ` +
    `mit ${fullName}. Staatlich gefördert über AVGS. ` +
    `Jetzt kostenlos starten.`,
  canonical:
    `https://dein-beauty-kurs.de/dozentinnen/${dozentin.slug}/`
};

const schema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": `${fullName} – Beauty Kurse`,
  "url": seo.canonical,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": city.name,
    "addressCountry": "DE"
  },
  ...(hasRating && {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": dozentin.rating,
      "reviewCount": dozentin.review_count
    }
  }),
  ...(hasServices && {
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Kurse",
      "itemListElement": services.map((s: any) => ({
        "@type": "Course",
        "name": s.name,
        "provider": {
          "@type": "Person",
          "name": fullName
        }
      }))
    }
  })
};
---

<SEOLayout title={seo.title} description={seo.description}
           canonical={seo.canonical} schema={schema}>

<style>
*,*::before,*::after{box-sizing:border-box;}

.pw{max-width:1080px;margin:0 auto;padding:0 24px 80px;font-family:'Inter',system-ui,sans-serif;}

.hero{
  display:grid;
  grid-template-columns:1fr 440px;
  gap:48px;
  align-items:center;
  padding:48px 0 56px;
}
@media(max-width:860px){
  .hero{grid-template-columns:1fr;gap:32px;}
}
.hero-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:#f0fdf4;border:1px solid #bbf7d0;
  color:#15803d;font-size:12px;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;
  padding:7px 16px;border-radius:100px;margin-bottom:22px;
}
.hero-h1{
  font-size:clamp(28px,4vw,46px);font-weight:900;
  line-height:1.1;color:#111;margin:0 0 16px;
}
.hero-sub{
  font-size:17px;color:#555;line-height:1.7;
  margin:0 0 24px;max-width:480px;
}
.hero-rating{
  display:flex;align-items:center;gap:10px;margin-bottom:28px;
}
.stars{color:#f59e0b;font-size:20px;letter-spacing:1px;}
.rnum{font-size:16px;font-weight:800;color:#111;}
.rcnt{font-size:14px;color:#999;}
.hero-cta-row{display:flex;gap:12px;flex-wrap:wrap;align-items:center;}
.btn-gold{
  display:inline-block;
  background:linear-gradient(135deg,#b45309,#d97706);
  color:#fff;padding:16px 32px;border-radius:10px;
  font-weight:800;font-size:15px;text-decoration:none;
  transition:opacity .2s,transform .15s;
}
.btn-gold:hover{opacity:.88;transform:translateY(-2px);}
.btn-ghost{
  display:inline-block;
  border:1.5px solid #d1d5db;color:#374151;
  padding:15px 24px;border-radius:10px;
  font-weight:600;font-size:15px;text-decoration:none;
  transition:border-color .2s;
}
.btn-ghost:hover{border-color:#9ca3af;}
.hero-img-wrap{
  position:relative;border-radius:20px;overflow:hidden;
  box-shadow:0 20px 60px rgba(0,0,0,.13);
}
.hero-img-wrap img{
  width:100%;aspect-ratio:3/4;object-fit:cover;display:block;
}
.hero-img-placeholder{
  width:100%;aspect-ratio:3/4;min-height:360px;
  background:linear-gradient(160deg,#f3f4f6,#e5e7eb);
  display:flex;align-items:center;justify-content:center;
  font-size:80px;color:#d1d5db;
}
.hero-img-badge{
  position:absolute;bottom:16px;left:16px;right:16px;
  background:rgba(0,0,0,.72);backdrop-filter:blur(8px);
  border-radius:10px;padding:12px 16px;color:#fff;
  display:flex;align-items:center;justify-content:space-between;
}
.hib-label{font-size:12px;color:rgba(255,255,255,.6);}
.hib-val{font-size:14px;font-weight:700;}

.sh{margin-bottom:36px;}
.sh-eye{
  font-size:11px;font-weight:800;letter-spacing:.15em;
  text-transform:uppercase;color:#b45309;display:block;
  margin-bottom:8px;
}
.sh-title{
  font-size:clamp(22px,3vw,32px);font-weight:900;
  color:#111;margin:0 0 8px;line-height:1.2;
}
.sh-sub{font-size:15px;color:#666;line-height:1.7;margin:0;max-width:560px;}

.module-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
  gap:20px;margin-bottom:72px;
}
.mc{
  background:#fff;border:1.5px solid #e5e7eb;
  border-radius:16px;padding:0;overflow:hidden;
  text-decoration:none;color:inherit;
  transition:border-color .2s,box-shadow .2s,transform .15s;
  display:flex;flex-direction:column;
}
.mc:hover{
  border-color:#d97706;
  box-shadow:0 8px 32px rgba(217,119,6,.12);
  transform:translateY(-3px);
}
.mc-head{
  background:linear-gradient(135deg,#fffbeb,#fef3c7);
  padding:22px 24px 18px;
  border-bottom:1px solid #fde68a;
}
.mc-icon{font-size:28px;margin-bottom:8px;display:block;}
.mc-name{
  font-size:18px;font-weight:900;color:#111;
  margin:0 0 4px;display:block;
}
.mc-tagline{font-size:13px;color:#92400e;font-weight:600;}
.mc-body{padding:20px 24px;flex:1;display:flex;flex-direction:column;gap:14px;}
.mc-specs{
  display:grid;grid-template-columns:1fr 1fr;gap:8px;
}
.mc-spec{
  background:#f9fafb;border-radius:8px;
  padding:10px 12px;
}
.mc-spec-label{
  font-size:10px;font-weight:700;letter-spacing:.08em;
  text-transform:uppercase;color:#9ca3af;display:block;margin-bottom:3px;
}
.mc-spec-val{font-size:13px;font-weight:700;color:#111;}
.mc-highlights{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:6px;}
.mc-highlights li{
  font-size:13px;color:#374151;padding-left:18px;position:relative;line-height:1.5;
}
.mc-highlights li::before{
  content:'✓';position:absolute;left:0;
  color:#15803d;font-weight:700;font-size:12px;
}
.mc-outcome{
  background:#f0fdf4;border:1px solid #bbf7d0;
  border-radius:8px;padding:12px 14px;
  font-size:13px;color:#166534;font-weight:600;
  line-height:1.5;
}
.mc-foot{
  padding:16px 24px;border-top:1px solid #f3f4f6;
  display:flex;align-items:center;justify-content:space-between;
}
.mc-avgs{
  background:#f0fdf4;color:#15803d;
  font-size:11px;font-weight:700;
  padding:4px 10px;border-radius:100px;
}
.mc-arrow{font-size:13px;font-weight:700;color:#d97706;}

.cta-stripe{
  background:linear-gradient(135deg,#111827 0%,#1f2937 100%);
  border-radius:20px;padding:52px 48px;
  position:relative;overflow:hidden;
  margin-bottom:64px;text-align:center;
}
.cta-stripe::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(circle at 15% 50%,rgba(217,119,6,.15) 0%,transparent 50%),
    radial-gradient(circle at 85% 30%,rgba(52,211,153,.07) 0%,transparent 50%);
  pointer-events:none;
}
@media(max-width:600px){.cta-stripe{padding:36px 24px;}}
.cta-stripe h2{
  font-size:clamp(22px,4vw,36px);font-weight:900;
  color:#fff;margin:0 0 12px;position:relative;
}
.cta-stripe p{
  color:rgba(255,255,255,.55);font-size:15px;
  margin:0 auto 32px;max-width:500px;
  line-height:1.7;position:relative;
}
.cta-row{
  display:flex;gap:12px;justify-content:center;
  flex-wrap:wrap;position:relative;
}
.btn-gold-lg{
  display:inline-block;
  background:linear-gradient(135deg,#b45309,#d97706);
  color:#fff;padding:18px 40px;border-radius:12px;
  font-weight:900;font-size:17px;text-decoration:none;
  transition:opacity .2s,transform .15s;
}
.btn-gold-lg:hover{opacity:.88;transform:translateY(-2px);}
.btn-wh{
  display:inline-block;
  border:1.5px solid rgba(255,255,255,.2);
  color:rgba(255,255,255,.8);
  padding:17px 28px;border-radius:12px;
  font-weight:600;font-size:15px;text-decoration:none;
  transition:border-color .2s;
}
.btn-wh:hover{border-color:rgba(255,255,255,.5);}

.gallery-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:12px;margin-bottom:72px;
}
@media(max-width:600px){.gallery-grid{grid-template-columns:repeat(2,1fr);}}
.gallery-grid img{
  width:100%;aspect-ratio:1;object-fit:cover;
  border-radius:12px;display:block;
  transition:opacity .2s,transform .2s;
}
.gallery-grid img:hover{opacity:.88;transform:scale(1.02);}
.gallery-ph{
  aspect-ratio:1;background:linear-gradient(135deg,#f9fafb,#f3f4f6);
  border-radius:12px;display:flex;align-items:center;
  justify-content:center;font-size:28px;color:#d1d5db;
}

.bio-grid{
  display:grid;grid-template-columns:1fr 360px;
  gap:48px;align-items:start;margin-bottom:72px;
}
@media(max-width:840px){.bio-grid{grid-template-columns:1fr;}}
.bio-body p{
  font-size:16px;line-height:1.85;color:#374151;margin:0 0 16px;
}
.bio-meta-card{
  background:#f9fafb;border:1px solid #e5e7eb;
  border-radius:16px;padding:24px;
}
.bm-row{
  display:flex;gap:14px;align-items:flex-start;
  padding:14px 0;border-bottom:1px solid #e5e7eb;
}
.bm-row:first-child{padding-top:0;}
.bm-row:last-child{border-bottom:none;padding-bottom:0;}
.bm-icon{font-size:20px;flex-shrink:0;margin-top:1px;}
.bm-label{
  font-size:10px;font-weight:700;letter-spacing:.08em;
  text-transform:uppercase;color:#9ca3af;display:block;margin-bottom:3px;
}
.bm-val{font-size:14px;font-weight:700;color:#111;}

.bc{
  padding-top:20px;font-size:13px;color:#9ca3af;
  display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-bottom:0;
}
.bc a{color:#9ca3af;text-decoration:none;}
.bc a:hover{color:#374151;}

.dv{height:1px;background:linear-gradient(90deg,transparent,#e5e7eb,transparent);margin:56px 0;}
</style>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300..800;1,14..32,300..800&display=swap" rel="stylesheet" />

<div class="pw">

  <nav class="bc">
    <a href={`/${city.slug}/`}>{city.name}</a>
    {hasServices && (
      <>
        <span>›</span>
        <a href={`/${city.slug}/${services[0].slug}/`}>{services[0].name}</a>
      </>
    )}
    <span>›</span>
    <span style="color:#374151;">{fullName}</span>
  </nav>

  <div class="hero">
    <div class="hero-text">
      <div class="hero-badge">
        <span>✓</span> AVGS förderbar · 100 % kostenlos
      </div>

      <h1 class="hero-h1">
        {hasServices
          ? `${primaryService} in ${city.name}`
          : `Beauty Kurs in ${city.name}`
        }
      </h1>

      <p class="hero-sub">
        Zertifiziertes 1:1 Einzelcoaching mit <strong>{fullName}</strong>
        in {city.name} – staatlich anerkannt, gefördert über die
        Arbeitsagentur, kein Eigenanteil.
      </p>

      {hasRating && (
        <div class="hero-rating">
          <span class="stars">★★★★★</span>
          <span class="rnum">{dozentin.rating}/5</span>
          <span class="rcnt">({dozentin.review_count} Bewertungen)</span>
        </div>
      )}

      <div class="hero-cta-row">
        <a href="#kurs-starten" class="btn-gold">
          Jetzt kostenlos starten
        </a>
        <a href={`/${city.slug}/`} class="btn-ghost">
          Alle Kurse in {city.name}
        </a>
      </div>
    </div>

    <div class="hero-img-wrap">
      {hasImage
        ? <img
            src={dozentin.image_url}
            alt={`${fullName} – ${primaryService} Dozentin in ${city.name}`}
            width="440" height="587"
            loading="eager"
          />
        : <div class="hero-img-placeholder">✦</div>
      }
      <div class="hero-img-badge">
        <div>
          <div class="hib-label">Standort</div>
          <div class="hib-val">{city.name}</div>
        </div>
        <div style="text-align:right;">
          <div class="hib-label">Format</div>
          <div class="hib-val">1:1 Coaching</div>
        </div>
      </div>
    </div>
  </div>

  <div class="cta-stripe" id="kurs-starten">
    <h2>Jetzt kostenlos starten</h2>
    <p>
      Lade deine Unterlagen für die Arbeitsagentur herunter und
      starte deinen AVGS-geförderten Kurs bei {fullName} – ohne
      Eigenanteil, ohne Wartezeit.
    </p>
    {hasForm
      ? <div style="position:relative;z-index:1;">
          <script
            src={`https://form.jotform.com/jsform/${dozentin.jotform_id}`}
          />
        </div>
      : <div class="cta-row">
          <a href={`/${city.slug}/`} class="btn-gold-lg">
            Alle Kurse in {city.name} →
          </a>
        </div>
    }
  </div>

  {hasServices && (
    <section style="margin-bottom:72px;">
      <div class="sh">
        <span class="sh-eye">Kurse & Module</span>
        <h2 class="sh-title">
          Angebotene Ausbildungen in {city.name}
        </h2>
        <p class="sh-sub">
          Alle Module als 1:1 Einzelcoaching – AVGS-förderbar,
          staatlich anerkannt, zertifiziert.
        </p>
      </div>

      <div class="module-grid">
        {services.map((s: any, i: number) => {
          const icons   = ['💄','✏️','👁️','🌿','✨','🎨'];
          const icon    = icons[i % icons.length];
          const rawDesc = (s.description_template ?? '').replace('{city}', city.name);
          const highlights = [
            'Intensives 1:1 Einzelcoaching',
            'Direktes Feedback & Korrekturen',
            'Staatlich anerkanntes Zertifikat',
          ];
          return (
            <a href={`/${city.slug}/${s.slug}/`} class="mc">
