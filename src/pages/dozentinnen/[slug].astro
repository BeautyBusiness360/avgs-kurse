---
import SEOLayout from '../../layouts/SEOLayout.astro';
import { supabase } from '../../lib/supabase';

export const prerender = true;

export async function getStaticPaths() {
  const { data: dozentinnen, error } = await supabase
    .from('dozentinnen')
    .select(`
      slug,
      first_name,
      last_name,
      bio_short,
      rating,
      review_count,
      avgs_certified,
      jotform_id,
      image_url,
      logo_url,
      gallery_images,
      languages,
      cities(slug, name),
      dozentin_services(
        services(slug, name, avgs_eligible, description_template)
      )
    `)
    .eq('active', true)
    .order('last_name', { ascending: true });

  if (error) {
    console.error('[getStaticPaths] Supabase error:', error.message);
    return [];
  }

  if (!dozentinnen || dozentinnen.length === 0) {
    console.error('[getStaticPaths] Keine Dozentinnen gefunden');
    return [];
  }

  console.log(`[getStaticPaths] ${dozentinnen.length} Dozentinnen geladen`);

  const paths = [];

  for (const d of dozentinnen) {
    if (!d.slug || typeof d.slug !== 'string') {
      console.warn('[getStaticPaths] Ungültiger slug:', d);
      continue;
    }

    const city = Array.isArray(d.cities) ? d.cities[0] : d.cities;
    if (!city || !city.slug) {
      console.warn('[getStaticPaths] Fehlende City für:', d.slug);
      continue;
    }

    const services = Array.isArray(d.dozentin_services)
      ? d.dozentin_services.map(ds => ds?.services ?? null).filter(Boolean)
      : [];

    console.log(`[getStaticPaths] ✓ ${d.slug} (${services.length} Services)`);

    paths.push({
      params: { slug: d.slug },
      props: {
        dozentin: {
          ...d,
          services
        }
      }
    });
  }

  console.log(`[getStaticPaths] ${paths.length} Seiten werden gebaut`);
  return paths;
}

const { dozentin } = Astro.props;
const city     = Array.isArray(dozentin.cities) ? dozentin.cities[0] : dozentin.cities;
const services = dozentin.services ?? [];

const hasImage    = !!dozentin.image_url;
const hasRating   = (dozentin.review_count ?? 0) > 0;
const hasServices = services.length > 0;
const hasBio      = !!dozentin.bio_short;
const hasForm     = !!dozentin.jotform_id;
const fullName    = `${dozentin.first_name} ${dozentin.last_name}`;

const primaryService = services[0]?.name ?? 'Beauty Kurs';

const seo = {
  title:
    `${fullName} – ${primaryService} ${city.name} | AVGS gefördert`,
  description:
    dozentin.bio_short ??
    `${primaryService} Einzelcoaching in ${city.name} ` +
    `mit ${fullName}. Staatlich gefördert über AVGS. ` +
    `Jetzt kostenlos starten.`,
  canonical:
    `https://dein-beauty-kurs.de/dozentinnen/${dozentin.slug}/`
};

const schema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": `${fullName} – Beauty Kurse`,
  "url": seo.canonical,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": city.name,
    "addressCountry": "DE"
  },
  ...(hasRating && {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": dozentin.rating,
      "reviewCount": dozentin.review_count
    }
  }),
  ...(hasServices && {
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Kurse",
      "itemListElement": services.map((s: any) => ({
        "@type": "Course",
        "name": s.name,
        "provider": {
          "@type": "Person",
          "name": fullName
        }
      }))
    }
  })
};
---

<SEOLayout title={seo.title} description={seo.description}
           canonical={seo.canonical} schema={schema}>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />

<style>
:root {
  --cream:   #FAF8F5;
  --black:   #1C1C1C;
  --gold:    #B8965A;
  --gold-lt: #D4AF7A;
  --rose:    #E8C4B8;
  --muted:   #7A7168;
  --border:  #E8E2D9;
  --white:   #FFFFFF;
  --serif:   'Cormorant Garamond', Georgia, serif;
  --sans:    'Jost', system-ui, sans-serif;
}
*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }
body { background:var(--cream); color:var(--black); font-family:var(--sans); }

/* LAYOUT */
.w { max-width:1140px; margin:0 auto; padding:0 32px; }
@media(max-width:640px){ .w { padding:0 20px; } }

/* HEADER */
.site-header {
  position:sticky; top:0; z-index:100;
  background:rgba(250,248,245,.95);
  backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
  padding:0;
}
.header-inner {
  display:flex; align-items:center;
  justify-content:space-between;
  height:64px;
}
.brand {
  font-family:var(--serif);
  font-size:22px; font-weight:600;
  color:var(--black); text-decoration:none;
  letter-spacing:.04em;
}
.brand span { color:var(--gold); }

/* CTA BUTTON VARIANTS */
.cta-gold {
  display:inline-block;
  background:var(--gold);
  color:var(--white);
  font-family:var(--sans);
  font-size:13px; font-weight:600;
  letter-spacing:.12em; text-transform:uppercase;
  padding:14px 32px;
  border-radius:2px;
  text-decoration:none;
  transition:background .25s, transform .2s;
}
.cta-gold:hover { background:var(--gold-lt); transform:translateY(-1px); }
.cta-outline {
  display:inline-block;
  border:1.5px solid var(--gold);
  color:var(--gold);
  font-family:var(--sans);
  font-size:13px; font-weight:600;
  letter-spacing:.12em; text-transform:uppercase;
  padding:13px 32px;
  border-radius:2px;
  text-decoration:none;
  transition:background .25s, color .25s;
}
.cta-outline:hover { background:var(--gold); color:var(--white); }
.cta-white {
  display:inline-block;
  background:var(--white);
  color:var(--black);
  font-family:var(--sans);
  font-size:13px; font-weight:600;
  letter-spacing:.12em; text-transform:uppercase;
  padding:14px 32px;
  border-radius:2px;
  text-decoration:none;
  transition:opacity .2s;
}
.cta-white:hover { opacity:.88; }
.section-cta {
  text-align:center;
  padding:48px 0 0;
}

/* HERO */
.hero {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:0;
  min-height:620px;
  padding:80px 0 0;
}
@media(max-width:860px){
  .hero { grid-template-columns:1fr; padding:48px 0 0; }
}
.hero-left {
  display:flex; flex-direction:column;
  justify-content:center;
  padding-right:64px;
  padding-bottom:80px;
}
@media(max-width:860px){ .hero-left { padding-right:0; padding-bottom:40px; } }
.hero-eyebrow {
  display:inline-flex; align-items:center; gap:8px;
  font-family:var(--sans);
  font-size:11px; font-weight:600;
  letter-spacing:.2em; text-transform:uppercase;
  color:var(--gold);
  margin-bottom:24px;
}
.hero-eyebrow::before {
  content:'';
  display:inline-block;
  width:32px; height:1px;
  background:var(--gold);
}
.hero-h1 {
  font-family:var(--serif);
  font-size:clamp(38px, 5vw, 64px);
  font-weight:600;
  line-height:1.08;
  color:var(--black);
  margin-bottom:24px;
  letter-spacing:-.01em;
}
.hero-h1 em {
  font-style:italic;
  color:var(--gold);
}
.hero-sub {
  font-family:var(--sans);
  font-size:16px; font-weight:300;
  line-height:1.8;
  color:var(--muted);
  margin-bottom:36px;
  max-width:440px;
}
.hero-trust {
  display:flex; align-items:center; gap:24px;
  flex-wrap:wrap;
  padding-top:36px;
  border-top:1px solid var(--border);
  margin-top:auto;
}
.trust-item {
  display:flex; align-items:center; gap:8px;
  font-size:13px; color:var(--muted); font-weight:400;
}
.trust-item::before {
  content:'✦';
  color:var(--gold); font-size:10px;
}
.hero-right {
  position:relative;
  display:flex; align-items:flex-end;
}
.hero-img-frame {
  width:100%; position:relative;
}
.hero-img-frame img {
  width:100%;
  height:680px;
  object-fit:cover;
  object-position:top center;
  display:block;
}
.hero-img-placeholder {
  width:100%; height:680px;
  background:linear-gradient(160deg,#EDE8E0,#D4C9BC);
  display:flex; align-items:center; justify-content:center;
  font-family:var(--serif); font-size:48px; color:rgba(255,255,255,.3);
}
@media(max-width:860px){
  .hero-img-frame img,
  .hero-img-placeholder { height:420px; }
}
.hero-cert-badge {
  position:absolute;
  bottom:32px; right:-20px;
  background:var(--black);
  color:var(--white);
  padding:20px 24px;
  border-radius:4px;
  text-align:center;
  min-width:160px;
  box-shadow:0 16px 40px rgba(0,0,0,.2);
}
@media(max-width:860px){ .hero-cert-badge { right:16px; } }
.cert-label {
  font-size:9px; font-weight:600;
  letter-spacing:.2em; text-transform:uppercase;
  color:var(--gold); display:block; margin-bottom:6px;
}
.cert-name {
  font-family:var(--serif);
  font-size:18px; font-weight:600;
  color:var(--white); display:block;
  line-height:1.3; margin-bottom:6px;
}
.cert-num {
  font-size:10px; color:rgba(255,255,255,.45);
  letter-spacing:.1em;
}
.hero-cta-wrap {
  padding:56px 0 80px;
  display:flex; justify-content:center;
  border-bottom:1px solid var(--border);
}

/* SECTION BASELINE */
.section {
  padding:96px 0;
  border-bottom:1px solid var(--border);
}
.section-header {
  text-align:center;
  margin-bottom:64px;
}
.section-eye {
  display:inline-block;
  font-size:11px; font-weight:600;
  letter-spacing:.2em; text-transform:uppercase;
  color:var(--gold); margin-bottom:16px;
}
.section-title {
  font-family:var(--serif);
  font-size:clamp(32px, 4vw, 52px);
  font-weight:600; line-height:1.1;
  color:var(--black); margin-bottom:16px;
}
.section-title em { font-style:italic; color:var(--gold); }
.section-desc {
  font-size:15px; font-weight:300;
  line-height:1.8; color:var(--muted);
  max-width:520px; margin:0 auto;
}

/* MODULE CARDS */
.module-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(320px, 1fr));
  gap:24px;
  margin-bottom:0;
}
.module-card {
  background:var(--white);
  border:1px solid var(--border);
  border-radius:4px;
  overflow:hidden;
  text-decoration:none;
  color:inherit;
  display:flex; flex-direction:column;
  transition:box-shadow .25s, transform .2s;
}
.module-card:hover {
  box-shadow:0 12px 40px rgba(184,150,90,.12);
  transform:translateY(-4px);
}
.module-card-accent {
  height:4px;
  background:linear-gradient(90deg, var(--gold), var(--rose));
}
.module-card-body {
  padding:32px 28px 24px;
  flex:1; display:flex; flex-direction:column; gap:20px;
}
.module-icon {
  font-size:24px; display:block; margin-bottom:4px;
}
.module-name {
  font-family:var(--serif);
  font-size:22px; font-weight:600;
  color:var(--black); display:block; margin-bottom:4px;
  line-height:1.2;
}
.module-tagline {
  font-size:13px; color:var(--muted); font-weight:300;
}
.module-specs {
  display:grid; grid-template-columns:1fr 1fr; gap:10px;
}
.module-spec {
  background:var(--cream);
  border:1px solid var(--border);
  border-radius:3px;
  padding:10px 14px;
}
.ms-label {
  font-size:9px; font-weight:600;
  letter-spacing:.15em; text-transform:uppercase;
  color:var(--muted); display:block; margin-bottom:3px;
}
.ms-val {
  font-size:13px; font-weight:600; color:var(--black);
}
.module-points {
  list-style:none; display:flex; flex-direction:column; gap:8px;
}
.module-points li {
  font-size:13px; font-weight:300;
  color:var(--black); padding-left:20px;
  position:relative; line-height:1.5;
}
.module-points li::before {
  content:'—';
  position:absolute; left:0;
  color:var(--gold); font-size:12px;
}
.module-outcome {
  background:linear-gradient(135deg,#F7F2EA,#FDF9F5);
  border:1px solid #E8D9C4;
  border-radius:3px; padding:14px 16px;
  font-size:13px; color:#7A5C2E;
  font-weight:500; line-height:1.5;
}
.module-card-foot {
  padding:16px 28px 24px;
  border-top:1px solid var(--border);
  display:flex; align-items:center; justify-content:space-between;
}
.mc-avgs {
  font-size:11px; font-weight:600;
  letter-spacing:.1em; text-transform:uppercase;
  color:#2D6A4F;
  background:#EAFAF2;
  border:1px solid #B7DDD0;
  padding:4px 12px; border-radius:2px;
}
.mc-link {
  font-size:12px; font-weight:600;
  letter-spacing:.1em; text-transform:uppercase;
  color:var(--gold);
}

/* GALLERY */
.gallery-grid {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:16px;
}
@media(max-width:640px){ .gallery-grid { grid-template-columns:repeat(2,1fr); gap:10px; } }
.gallery-cell { overflow:hidden; border-radius:3px; }
.gallery-cell img {
  width:100%; aspect-ratio:1;
  object-fit:cover; display:block;
  transition:transform .5s ease;
}
.gallery-cell:hover img { transform:scale(1.04); }
.gallery-ph {
  aspect-ratio:1;
  background:linear-gradient(135deg,#EDE8E0,#DDD4C8);
  display:flex; align-items:center; justify-content:center;
  font-size:24px; color:rgba(255,255,255,.4);
  border-radius:3px;
}

/* TRUST / BIO */
.trust-grid {
  display:grid;
  grid-template-columns:1fr 400px;
  gap:80px; align-items:start;
}
@media(max-width:900px){ .trust-grid { grid-template-columns:1fr; gap:48px; } }
.trust-quote {
  font-family:var(--serif);
  font-size:clamp(22px,3vw,34px);
  font-weight:500; line-height:1.4;
  color:var(--black); margin-bottom:32px;
  position:relative; padding-top:32px;
}
.trust-quote::before {
  content:'"';
  position:absolute; top:-8px; left:0;
  font-family:var(--serif);
  font-size:80px; color:var(--rose);
  line-height:1; font-weight:400;
}
.trust-bio-text {
  font-size:15px; font-weight:300;
  line-height:1.9; color:var(--muted);
  margin-bottom:32px;
}
.trust-facts {
  display:flex; flex-direction:column; gap:0;
  background:var(--white);
  border:1px solid var(--border);
  border-radius:4px; overflow:hidden;
}
.tf-row {
  display:flex; gap:20px;
  align-items:flex-start;
  padding:20px 24px;
  border-bottom:1px solid var(--border);
}
.tf-row:last-child { border-bottom:none; }
.tf-icon {
  font-size:18px; flex-shrink:0; margin-top:2px; width:28px;
}
.tf-label {
  font-size:10px; font-weight:600;
  letter-spacing:.16em; text-transform:uppercase;
  color:var(--muted); display:block; margin-bottom:4px;
}
.tf-val {
  font-size:14px; font-weight:500; color:var(--black); line-height:1.4;
}

/* FINAL CTA */
.final-cta {
  padding:120px 0;
  text-align:center;
  background:var(--black);
  position:relative; overflow:hidden;
}
.final-cta::before {
  content:'';
  position:absolute; inset:0;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(184,150,90,.12) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 30%, rgba(232,196,184,.07) 0%, transparent 60%);
  pointer-events:none;
}
.final-cta-eye {
  display:inline-block;
  font-size:11px; font-weight:600;
  letter-spacing:.25em; text-transform:uppercase;
  color:var(--gold); margin-bottom:24px;
  position:relative;
}
.final-cta-h2 {
  font-family:var(--serif);
  font-size:clamp(36px, 5vw, 64px);
  font-weight:600; line-height:1.1;
  color:var(--white);
  margin-bottom:20px; position:relative;
}
.final-cta-h2 em { font-style:italic; color:var(--gold-lt); }
.final-cta-sub {
  font-size:15px; font-weight:300;
  color:rgba(255,255,255,.5);
  margin-bottom:48px;
  max-width:460px; margin-left:auto; margin-right:auto;
  line-height:1.8; position:relative;
}
.final-cta-form { position:relative; }

/* FOOTER */
.site-footer {
  background:var(--black);
  border-top:1px solid rgba(255,255,255,.06);
  padding:32px 0;
}
.footer-inner {
  display:flex; align-items:center;
  justify-content:space-between; flex-wrap:wrap; gap:16px;
}
.footer-copy {
  font-size:13px; color:rgba(255,255,255,.3);
}
.footer-links {
  display:flex; gap:24px;
}
.footer-links a {
  font-size:13px; color:rgba(255,255,255,.4);
  text-decoration:none; transition:color .2s;
}
.footer-links a:hover { color:rgba(255,255,255,.8); }
</style>

<!-- ══════════════════════════════════
     HEADER
══════════════════════════════════ -->
<header class="site-header">
  <div class="w">
    <div class="header-inner">
      <a href="/" class="brand">
        Beauty<span>Business</span>360
      </a>
      <a href="/fachdozentin-werden/" class="cta-gold">
        Fachdozentin werden
      </a>
    </div>
  </div>
</header>

<main>

<!-- ══════════════════════════════════
     HERO
══════════════════════════════════ -->
<div class="w">
  <div class="hero">

    <div class="hero-left">
      <div class="hero-eyebrow">
        {city.name} · 1:1 Einzelcoaching
      </div>

      <h1 class="hero-h1">
        Deine Karriere in<br />
        <em>Permanent Make-up</em><br />
        beginnt hier.
      </h1>

      <p class="hero-sub">
        {hasBio
          ? dozentin.bio_short
          : `Lerne direkt von ${fullName} –
             zertifizierte Fachdozentin in ${city.name}.
             Staatlich anerkannte Ausbildung,
             vollständig gefördert über AVGS.`
        }
      </p>

      <div class="hero-trust">
        <span class="trust-item">100 % AVGS-förderbar</span>
        <span class="trust-item">Staatlich anerkannt</span>
        {hasRating &&
          <span class="trust-item">
            {dozentin.rating}/5 ({dozentin.review_count} Bewertungen)
          </span>
        }
      </div>
    </div>

    <div class="hero-right">
      <div class="hero-img-frame">
        {hasImage
          ? <img
              src={dozentin.image_url}
              alt={`${fullName} – ${primaryService} Dozentin in ${city.name}`}
              width="570" height="680"
              loading="eager"
            />
          : <div class="hero-img-placeholder">✦</div>
        }
        <div class="hero-cert-badge">
          <span class="cert-label">BeautyBusiness360</span>
          <span class="cert-name">Anerkannte<br />Fachdozentin</span>
          <span class="cert-num">REG. NR. BB360-FD</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- HERO CTA — 1 button, centered -->
<div class="hero-cta-wrap">
  <a href="#anmeldung" class="cta-gold">
    Kostenfreie Anmeldung starten
  </a>
</div>


<!-- ══════════════════════════════════
     MODUL-SEKTION
══════════════════════════════════ -->
{hasServices && (
  <section class="section">
    <div class="w">
      <div class="section-header">
        <span class="section-eye">Kurse &amp; Module</span>
        <h2 class="section-title">
          Lerne das <em>Handwerk</em><br />
          von Grund auf.
        </h2>
        <p class="section-desc">
          Alle Module als 1:1 Einzelcoaching in {city.name} –
          AVGS-förderbar, zertifiziert, sofort buchbar.
        </p>
      </div>

      <div class="module-grid">
        {services.map((s: any, i: number) => {
          const icons = ['💄','✏️','👁️','🌿','✨','🎨'];
          const icon  = icons[i % icons.length];
          const desc  = (s.description_template ?? '').replace('{city}', city.name);
          return (
            <a href={`/${city.slug}/${s.slug}/`} class="module-card">
              <div class="module-card-accent" />
              <div class="module-card-body">
                <div>
                  <span class="module-icon">{icon}</span>
                  <span class="module-name">{s.name}</span>
                  <span class="module-tagline">
                    Master Class · {city.name}
                  </span>
                </div>

                <div class="module-specs">
                  <div class="module-spec">
                    <span class="ms-label">Dauer</span>
                    <span class="ms-val">40 U. Stunden</span>
                  </div>
                  <div class="module-spec">
                    <span class="ms-label">Unterrichtsform</span>
                    <span class="ms-val">Hybridunterricht</span>
                  </div>
                  <div class="module-spec">
                    <span class="ms-label">Förderung</span>
                    <span class="ms-val">AVGS-Gutschein</span>
                  </div>
                  <div class="module-spec">
                    <span class="ms-label">Kursbeginn</span>
                    <span class="ms-val">Ab sofort</span>
                  </div>
                </div>

                <ul class="module-points">
                  <li>Intensives 1:1 Einzelcoaching</li>
                  <li>Direktes Feedback &amp; Korrekturen</li>
                  <li>Staatlich anerkanntes Zertifikat</li>
                </ul>

                <div class="module-outcome">
                  🎯 Abschluss: Professioneller Einsatz von {s.name}
                  – bereit für die selbstständige Tätigkeit
                </div>
              </div>

              <div class="module-card-foot">
                {s.avgs_eligible &&
                  <span class="mc-avgs">✓ AVGS förderbar</span>
                }
                <span class="mc-link">Kurs ansehen →</span>
              </div>
            </a>
          );
        })}
      </div>

      <!-- MODULE CTA — 1 button -->
      <div class="section-cta">
        <a href="#anmeldung" class="cta-gold">
          Kostenfreie Unterlagen erhalten
        </a>
      </div>
    </div>
  </section>
)}


