    </section>
  )}

  <div class="dv" />

  <section style="margin-bottom:72px;">
    <div class="sh">
      <span class="sh-eye">Arbeiten & Ergebnisse</span>
      <h2 class="sh-title">Einblick in die Ausbildung</h2>
      <p class="sh-sub">
        Echte Ergebnisse aus 1:1 Trainings mit {dozentin.first_name}.
      </p>
    </div>

    {(() => {
      const gallery = Array.isArray(dozentin.gallery_images)
        ? (dozentin.gallery_images as string[]).filter(Boolean).slice(0, 6)
        : [];
      return (
        <div class="gallery-grid">
          {gallery.length > 0
            ? gallery.map((img: string, i: number) => (
                <img
                  src={img}
                  alt={`${fullName} – Arbeitsprobe ${i + 1}`}
                  width="320" height="320"
                  loading="lazy"
                />
              ))
            : [1,2,3,4,5,6].map(n => (
                <div class="gallery-ph">✦</div>
              ))
          }
        </div>
      );
    })()}
  </section>

  <div class="dv" />

  <section>
    <div class="bio-grid">
      <div class="bio-body">
        <div class="sh" style="margin-bottom:24px;">
          <span class="sh-eye">Über die Dozentin</span>
          <h2 class="sh-title">{fullName}</h2>
        </div>

        {hasBio
          ? <p>{dozentin.bio_short}</p>
          : <>
              <p>
                {fullName} bietet zertifizierte 1:1 Einzelcoachings
                in {city.name} an – staatlich anerkannt und vollständig
                förderbar über den Aktivierungs- und
                Vermittlungsgutschein (AVGS) der Arbeitsagentur.
                Kein Eigenanteil, keine versteckten Kosten.
              </p>
              <p>
                Das Training findet als intensives Einzelcoaching statt:
                individuelle Korrekturen, arbeitsmarktrelevante Techniken
                und ein anerkanntes Zertifikat als Abschluss.
                Geeignet für Kosmetikerinnen und PMU Artists, die ihr
                Können gezielt vertiefen möchten.
              </p>
            </>
        }
      </div>

      <div class="bio-meta-card">
        <div class="bm-row">
          <span class="bm-icon">📍</span>
          <div>
            <span class="bm-label">Standort</span>
            <span class="bm-val">{city.name}</span>
          </div>
        </div>
        <div class="bm-row">
          <span class="bm-icon">🎓</span>
          <div>
            <span class="bm-label">Format</span>
            <span class="bm-val">1:1 Einzelcoaching</span>
          </div>
        </div>
        <div class="bm-row">
          <span class="bm-icon">✅</span>
          <div>
            <span class="bm-label">Förderung</span>
            <span class="bm-val">AVGS · 100 % kostenlos</span>
          </div>
        </div>
        {hasRating && (
          <div class="bm-row">
            <span class="bm-icon">⭐</span>
            <div>
              <span class="bm-label">Bewertung</span>
              <span class="bm-val">
                {dozentin.rating}/5 · {dozentin.review_count} Stimmen
              </span>
            </div>
          </div>
        )}
        <div class="bm-row">
          <span class="bm-icon">🏆</span>
          <div>
            <span class="bm-label">Zertifizierung</span>
            <span class="bm-val">Staatlich anerkannt</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-stripe">
    <h2>Starte deinen Kurs in {city.name}</h2>
    <p>
