---
import SEOLayout from '../../layouts/SEOLayout.astro';
import { supabase } from '../../lib/supabase';
import fs from 'node:fs';
import path from 'node:path';

export const prerender = true;

export async function getStaticPaths() {
  const { data: dozentinnen, error } = await supabase
    .from('dozentinnen')
    .select(`
      slug,
      first_name,
      last_name,
      bio_short,
      rating,
      review_count,
      avgs_certified,
      jotform_id,
      image_url,
      logo_url,
      gallery_images,
      languages,
      cities(slug, name),
      dozentin_services(
        services(slug, name, avgs_eligible, description_template)
      )
    `)
    .eq('active', true)
    .order('last_name', { ascending: true });

  if (error) {
    console.error('[getStaticPaths] Supabase error:', error.message);
    return [];
  }

  if (!dozentinnen || dozentinnen.length === 0) {
    console.error('[getStaticPaths] Keine Dozentinnen gefunden');
    return [];
  }

  console.log(`[getStaticPaths] ${dozentinnen.length} Dozentinnen geladen`);

  const paths = [];

  for (const d of dozentinnen) {
    if (!d.slug || typeof d.slug !== 'string') {
      console.warn('[getStaticPaths] Ungültiger slug:', d);
      continue;
    }

    const city = Array.isArray(d.cities) ? d.cities[0] : d.cities;
    if (!city || !city.slug) {
      console.warn('[getStaticPaths] Fehlende City für:', d.slug);
      continue;
    }

    const services = Array.isArray(d.dozentin_services)
      ? d.dozentin_services.map(ds => ds?.services ?? null).filter(Boolean)
      : [];

    console.log(`[getStaticPaths] ✓ ${d.slug} (${services.length} Services)`);

    paths.push({
      params: { slug: d.slug },
      props: {
        dozentin: {
          ...d,
          services
        }
      }
    });
  }

  console.log(`[getStaticPaths] ${paths.length} Seiten werden gebaut`);
  return paths;
}

const { dozentin } = Astro.props;
const city     = Array.isArray(dozentin.cities) ? dozentin.cities[0] : dozentin.cities;
const services = dozentin.services ?? [];

// Local WebP image lookup (slug minus trailing -city)
const localImageSlug = dozentin.slug.replace(new RegExp(`-${city.slug}$`), '');
const localImageRel  = `/images/dozentinnen/${localImageSlug}.webp`;
const localImageAbs  = path.join(process.cwd(), 'public', localImageRel);
const hasLocalImage  = fs.existsSync(localImageAbs);

const hasImage    = hasLocalImage || !!dozentin.image_url;
const heroImageSrc = hasLocalImage ? localImageRel : dozentin.image_url;
const hasRating   = (dozentin.review_count ?? 0) > 0;
const hasServices = services.length > 0;
const hasBio      = !!dozentin.bio_short;
const hasForm     = !!dozentin.jotform_id;
const fullName    = `${dozentin.first_name} ${dozentin.last_name}`;

const primaryService = services[0]?.name ?? 'Beauty Kurs';

const seo = {
  title:
    `${fullName} – ${primaryService} ${city.name} | AVGS gefördert`,
  description:
    dozentin.bio_short ??
    `${primaryService} Einzelcoaching in ${city.name} ` +
    `mit ${fullName}. Staatlich gefördert über AVGS. ` +
    `Jetzt kostenlos starten.`,
  canonical:
    `https://dein-beauty-kurs.de/dozentinnen/${dozentin.slug}/`
};

const schema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": `${fullName} – Beauty Kurse`,
  "url": seo.canonical,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": city.name,
    "addressCountry": "DE"
  },
  ...(hasRating && {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": dozentin.rating,
      "reviewCount": dozentin.review_count
    }
  }),
  ...(hasServices && {
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Kurse",
      "itemListElement": services.map((s: any) => ({
        "@type": "Course",
        "name": s.name,
        "provider": {
          "@type": "Person",
          "name": fullName
        }
      }))
    }
  })
};
---

<SEOLayout title={seo.title} description={seo.description}
           canonical={seo.canonical} schema={schema}>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

<style>
:root {
  --cream:    #FAF8F5;
  --cream-d:  #F3EEE8;
  --black:    #111111;
  --gold:     #B8965A;
  --gold-lt:  #D4AF7A;
  --gold-bg:  #FBF6EE;
  --rose:     #E8C4B8;
  --muted:    #555250;
  --border:   #E8E2D9;
  --white:    #FFFFFF;
  --serif:    'Cormorant Garamond', Georgia, 'Times New Roman', serif;
  --sans:     'Inter', system-ui, sans-serif;
  --radius:   3px;
  --shadow:   0 8px 40px rgba(184,150,90,.10);
}

*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }

html { scroll-behavior:smooth; }

body {
  background:var(--cream);
  color:var(--black);
  font-family:var(--sans);
  font-size:16px;
  font-weight:400;
  line-height:1.75;
  -webkit-font-smoothing:antialiased;
}

/* LAYOUT */
.w { max-width:1120px; margin:0 auto; padding:0 40px; }
@media(max-width:640px){ .w { padding:0 22px; } }

/* ─── HEADER ─────────────────────────────── */
.site-header {
  position:sticky; top:0; z-index:100;
  background:rgba(250,248,245,.97);
  backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
}
.header-inner {
  display:flex; align-items:center;
  justify-content:space-between;
  height:68px;
}
.brand {
  display:inline-flex; align-items:center;
  text-decoration:none;
  line-height:0;
}
.brand-logo {
  height:48px; width:auto; display:block;
}
@media(max-width:640px){ .brand-logo { height:32px; } }
.site-header .cta-gold {
  padding:10px 22px;
  font-size:11px;
}

/* ─── BUTTONS ────────────────────────────── */
.cta-gold {
  display:inline-block;
  background:var(--gold);
  color:var(--white);
  font-family:var(--sans);
  font-size:12px; font-weight:600;
  letter-spacing:.14em; text-transform:uppercase;
  padding:14px 34px;
  border:none; border-radius:var(--radius);
  text-decoration:none; cursor:pointer;
  transition:background .25s, transform .2s, box-shadow .25s;
  box-shadow:0 4px 18px rgba(184,150,90,.25);
}
.cta-gold:hover {
  background:var(--gold-lt);
  transform:translateY(-2px);
  box-shadow:0 8px 28px rgba(184,150,90,.35);
}
.cta-outline {
  display:inline-block;
  border:1.5px solid var(--gold);
  color:var(--gold);
  font-family:var(--sans);
  font-size:12px; font-weight:600;
  letter-spacing:.14em; text-transform:uppercase;
  padding:13px 34px;
  border-radius:var(--radius);
  text-decoration:none;
  transition:background .25s, color .25s;
}
.cta-outline:hover { background:var(--gold); color:var(--white); }
.cta-white {
  display:inline-block;
  background:var(--white);
  color:var(--black);
  font-family:var(--sans);
  font-size:12px; font-weight:600;
  letter-spacing:.14em; text-transform:uppercase;
  padding:14px 34px;
  border-radius:var(--radius);
  text-decoration:none;
  transition:opacity .2s, transform .2s;
  box-shadow:0 4px 20px rgba(0,0,0,.15);
}
.cta-white:hover { opacity:.9; transform:translateY(-1px); }
.section-cta { text-align:center; padding:56px 0 0; }

/* ─── HERO ───────────────────────────────── */
.hero {
  display:grid;
  grid-template-columns:55% 45%;
  gap:0;
  min-height:640px;
  padding:88px 0 0;
}
@media(max-width:860px){
  .hero { grid-template-columns:1fr; padding:56px 0 0; }
}
.hero-left {
  display:flex; flex-direction:column;
  justify-content:center;
  padding-right:72px;
  padding-bottom:88px;
}
@media(max-width:860px){
  .hero-left { padding-right:0; padding-bottom:48px; }
}
.hero-h1 {
  font-family:var(--serif);
  font-size:clamp(40px, 5.5vw, 68px);
  font-weight:600; line-height:1.06;
  color:var(--black); margin-bottom:28px;
  letter-spacing:-.02em;
}
.hero-h1 em { font-style:italic; color:var(--gold); white-space:nowrap; }
.hero-sub {
  font-size:17px; font-weight:400;
  line-height:1.85; color:var(--muted);
  margin-bottom:0; max-width:440px;
}
.hero-divider {
  width:48px; height:1px;
  background:var(--gold);
  margin:36px 0;
  opacity:.6;
}
.hero-trust-row {
  display:flex; align-items:center; gap:0;
  flex-wrap:wrap;
}
.trust-chip {
  display:flex; align-items:center; gap:8px;
  font-size:12px; font-weight:400; color:var(--muted);
  padding:10px 20px;
  border:1px solid var(--border);
  border-radius:100px;
  background:var(--white);
  margin-right:10px; margin-bottom:10px;
}
.trust-chip::before {
  content:'✓'; color:var(--gold);
  font-size:11px; font-weight:700;
}
.hero-right {
  display:flex;
  align-items:center;
  justify-content:center;
}
.hero-img-frame {
  width:clamp(320px, 78vw, 720px);
  max-width:100%;
  aspect-ratio:1 / 1;       /* matcht das quadratische Quell-Asset */
  position:relative;
  border-radius:var(--radius);
  overflow:hidden;
  background:var(--cream-d);
}
.hero-img-frame img {
  width:100%;
  height:100%;
  object-fit:contain;        /* zeigt das GANZE Bild, kein Crop */
  display:block;
}
.hero-img-placeholder {
  width:100%;
  height:100%;
  display:flex;
  align-items:center;
  justify-content:center;
  font-family:var(--serif);
  font-size:56px;
  color:rgba(184,150,90,.2);
}
.hero-cta-wrap {
  padding:64px 0 88px;
  display:flex; justify-content:center;
  border-bottom:1px solid var(--border);
}
.hero-city-link {
  display:block; text-align:center;
  margin-top:18px;
  font-size:13px; color:var(--muted);
  text-decoration:none; font-weight:400;
}
.hero-city-link:hover { color:var(--gold); }

/* ─── SECTION BASICS ─────────────────────── */
.section { padding:100px 0; border-bottom:1px solid var(--border); }
.section-header { text-align:center; margin-bottom:72px; }
.section-eye {
  display:inline-block;
  font-size:11px; font-weight:500;
  letter-spacing:.22em; text-transform:uppercase;
  color:var(--gold); margin-bottom:18px;
}
.section-title {
  font-family:var(--serif);
  font-size:clamp(34px, 4.5vw, 56px);
  font-weight:600; line-height:1.1;
  color:var(--black); margin-bottom:18px;
}
.section-title em { font-style:italic; color:var(--gold); }
.section-desc {
  font-size:16px; font-weight:400;
  line-height:1.85; color:var(--muted);
  max-width:500px; margin:0 auto;
}
.section-services-link {
  display:block; text-align:center;
  margin-top:16px;
  font-size:13px; color:var(--muted); text-decoration:none;
}
.section-services-link:hover { color:var(--gold); }

/* ─── MODULE CARDS ───────────────────────── */
.module-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(320px,1fr));
  gap:24px;
}
.module-card {
  background:var(--white);
  border:1px solid var(--border);
  border-radius:var(--radius);
  overflow:hidden;
  text-decoration:none; color:inherit;
  display:flex; flex-direction:column;
  transition:box-shadow .3s, transform .25s;
  box-shadow:0 2px 16px rgba(0,0,0,.04);
}
.module-card:hover {
  box-shadow:var(--shadow);
  transform:translateY(-5px);
}
.module-card-accent {
  height:3px;
  background:linear-gradient(90deg, var(--gold), var(--rose));
}
.module-card-img {
  display:block;width:100%;height:200px;object-fit:cover;
}
.module-card-body { padding:32px 28px 24px; flex:1; display:flex; flex-direction:column; gap:22px; }
.module-name {
  font-family:var(--serif);
  font-size:24px; font-weight:600;
  color:var(--black); display:block; line-height:1.2; margin-bottom:2px;
}
.module-tagline { font-size:13px; color:var(--gold); font-weight:500; letter-spacing:.06em; }
.module-specs {
  display:flex; flex-direction:column; gap:0;
  border:1px solid var(--border); border-radius:var(--radius); overflow:hidden;
}
.module-spec-row {
  display:flex; justify-content:space-between; align-items:center;
  padding:11px 16px;
  border-bottom:1px solid var(--border);
  font-size:13px;
}
.module-spec-row:last-child { border-bottom:none; }
.ms-label { color:var(--muted); font-weight:400; }
.ms-val   { font-weight:600; color:var(--black); text-align:right; }
.module-outcome {
  background:var(--gold-bg);
  border:1px solid #E8D9C4;
  border-radius:var(--radius); padding:14px 18px;
  font-size:13px; color:#7A5C2E; font-weight:500; line-height:1.6;
}
.module-card-foot {
  padding:20px 28px; border-top:1px solid var(--border);
  background:var(--cream);
}
.mc-avgs {
  display:block; width:100%;
  font-size:14px; font-weight:600; text-align:center;
  color:#2D6A4F; background:#EAFAF2; border:1px solid #B7DDD0;
  padding:14px 20px; border-radius:4px;
}
/* ─── CAROUSEL ───────────────────────────── */
.carousel-wrap { position:relative; }
.carousel-track {
  display:flex; gap:16px;
  overflow-x:auto; scroll-snap-type:x mandatory; scroll-behavior:smooth;
  scrollbar-width:none;
}
.carousel-track::-webkit-scrollbar { display:none; }
.carousel-slide {
  flex:0 0 calc((100% - 32px) / 3);
  scroll-snap-align:start; border-radius:var(--radius); overflow:hidden;
}
.carousel-slide img {
  width:100%; aspect-ratio:1; object-fit:cover; display:block;
  transition:transform .6s ease;
}
.carousel-slide:hover img { transform:scale(1.05); }
.carousel-ph {
  aspect-ratio:1;
  background:linear-gradient(135deg,var(--cream-d),#DDD4C8);
  display:flex; align-items:center; justify-content:center;
  font-size:24px; color:rgba(184,150,90,.25);
}
.carousel-btn {
  position:absolute; top:50%; transform:translateY(-50%);
  width:40px; height:40px; border-radius:50%;
  background:var(--white); border:1px solid var(--border);
  box-shadow:0 2px 8px rgba(0,0,0,.1);
  cursor:pointer; font-size:18px; line-height:1;
  display:flex; align-items:center; justify-content:center;
  z-index:2; transition:box-shadow .2s;
}
.carousel-btn:hover { box-shadow:0 4px 16px rgba(0,0,0,.15); }
.carousel-prev { left:-20px; }
.carousel-next { right:-20px; }
.carousel-dots {
  display:none; justify-content:center; gap:8px; margin-top:16px;
}
.carousel-dot {
  width:8px; height:8px; border-radius:50%;
  border:1.5px solid var(--muted); background:transparent;
  transition:background .2s, border-color .2s; cursor:pointer; padding:0;
}
.carousel-dot.active {
  background:var(--gold); border-color:var(--gold);
}
@media(max-width:640px){
  .carousel-slide { flex:0 0 100%; }
  .carousel-btn { display:none; }
  .carousel-dots { display:flex; }
}

/* ─── TRUST / BIO ────────────────────────── */
.trust-grid {
  display:grid; grid-template-columns:1fr 380px; gap:80px; align-items:start;
}
@media(max-width:900px){ .trust-grid { grid-template-columns:1fr; gap:48px; } }
.trust-quote-wrap { position:relative; padding-top:40px; margin-bottom:32px; }
.trust-quote-mark {
  position:absolute; top:-16px; left:-8px;
  font-family:var(--serif); font-size:96px; line-height:1;
  color:var(--rose); opacity:.5; font-weight:400;
  pointer-events:none; user-select:none;
}
.trust-quote {
  font-family:var(--serif);
  font-size:clamp(21px, 2.8vw, 32px);
  font-weight:500; line-height:1.45;
  color:var(--black);
}
.trust-bio-text {
  font-size:16px; font-weight:400; line-height:1.9; color:var(--muted);
  margin-bottom:32px;
}
.trust-facts {
  background:var(--white); border:1px solid var(--border);
  border-radius:var(--radius); overflow:hidden;
  box-shadow:0 2px 16px rgba(0,0,0,.04);
}
.tf-row {
  display:flex; gap:20px; align-items:flex-start;
  padding:20px 24px; border-bottom:1px solid var(--border);
}
.tf-row:last-child { border-bottom:none; }
.tf-icon { font-size:18px; flex-shrink:0; margin-top:2px; width:26px; }
.tf-label {
  font-size:10px; font-weight:600; letter-spacing:.16em;
  text-transform:uppercase; color:var(--muted); display:block; margin-bottom:4px;
}
.tf-val { font-size:14px; font-weight:500; color:var(--black); line-height:1.4; }

/* ─── FAQ ────────────────────────────────── */
.faq-section { padding:100px 0; border-bottom:1px solid var(--border); }
.faq-grid {
  display:grid;
  grid-template-columns:380px 1fr;
  gap:80px; align-items:start;
}
@media(max-width:900px){ .faq-grid { grid-template-columns:1fr; gap:48px; } }
.faq-sticky { position:sticky; top:96px; }
.faq-sticky-eye {
  font-size:11px; font-weight:500; letter-spacing:.22em;
  text-transform:uppercase; color:var(--gold); display:block; margin-bottom:18px;
}
.faq-sticky-title {
  font-family:var(--serif);
  font-size:clamp(28px,4vw,44px);
  font-weight:600; line-height:1.15; color:var(--black); margin-bottom:20px;
}
.faq-sticky-title em { font-style:italic; color:var(--gold); }
.faq-sticky-desc {
  font-size:15px; font-weight:400; line-height:1.8; color:var(--muted);
}
.faq-list { display:flex; flex-direction:column; gap:0; }
.faq-item {
  border-bottom:1px solid var(--border); padding:0;
}
.faq-item:first-child { border-top:1px solid var(--border); }
.faq-summary {
  display:flex; justify-content:space-between; align-items:center;
  padding:26px 0; cursor:pointer; gap:20px;
  list-style:none; font-family:var(--serif);
  font-size:clamp(16px,2vw,20px); font-weight:600; color:var(--black);
  line-height:1.3;
}
.faq-summary::-webkit-details-marker { display:none; }
.faq-summary::marker { display:none; }
.faq-icon {
  flex-shrink:0; width:28px; height:28px;
  border:1px solid var(--border); border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:16px; color:var(--gold); font-weight:300;
  transition:transform .25s, background .2s;
}
details[open] .faq-icon { transform:rotate(45deg); background:var(--gold-bg); }
.faq-answer {
  padding:0 40px 28px 0;
  font-size:15px; font-weight:400; line-height:1.9; color:var(--muted);
}
.faq-answer p + p { margin-top:12px; }
.faq-answer strong { color:var(--black); font-weight:500; }

/* ─── FINAL CTA ──────────────────────────── */
.final-cta {
  padding:128px 0;
  text-align:center;
  background:var(--black);
  position:relative; overflow:hidden;
}
.final-cta::before {
  content:'';
  position:absolute; inset:0;
  background:
    radial-gradient(ellipse at 20% 60%, rgba(184,150,90,.14) 0%, transparent 55%),
    radial-gradient(ellipse at 80% 25%, rgba(232,196,184,.07) 0%, transparent 55%);
  pointer-events:none;
}
.final-cta-eye {
  font-size:11px; font-weight:500; letter-spacing:.25em; text-transform:uppercase;
  color:var(--gold); display:block; margin-bottom:24px; position:relative;
}
.final-cta-h2 {
  font-family:var(--serif);
  font-size:clamp(38px,6vw,72px);
  font-weight:600; line-height:1.08;
  color:var(--white); margin-bottom:22px; position:relative;
}
.final-cta-h2 em { font-style:italic; color:var(--gold-lt); }
.final-cta-sub {
  font-size:15px; font-weight:300; color:rgba(255,255,255,.45);
  margin:0 auto 52px; max-width:460px; line-height:1.85; position:relative;
}
.final-cta-form { position:relative; }
.bottom-nav {
  display:flex; justify-content:center; gap:32px; flex-wrap:wrap;
  padding-top:40px; position:relative;
}
.bottom-nav-link {
  font-size:13px; font-weight:400;
  color:rgba(255,255,255,.35); text-decoration:none;
  transition:color .2s;
}
.bottom-nav-link:hover { color:rgba(255,255,255,.75); }

/* ─── FOOTER ─────────────────────────────── */
.site-footer {
  background:var(--black);
  border-top:1px solid rgba(255,255,255,.06);
  padding:32px 0;
}
.footer-inner {
  display:flex; align-items:center;
  justify-content:space-between; flex-wrap:wrap; gap:16px;
}
.footer-copy { font-size:12px; color:rgba(255,255,255,.25); }
.footer-links { display:flex; gap:24px; }
.footer-links a {
  font-size:12px; color:rgba(255,255,255,.35);
  text-decoration:none; transition:color .2s;
}
.footer-links a:hover { color:rgba(255,255,255,.75); }
</style>

<!-- ══════════════════════════════════
     HEADER
══════════════════════════════════ -->
<header class="site-header">
