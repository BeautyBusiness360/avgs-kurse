---
import SEOLayout from '../../layouts/SEOLayout.astro';
import { supabase } from '../../lib/supabase';

export const prerender = true;

export async function getStaticPaths() {
  const { data: dozentinnen, error } = await supabase
    .from('dozentinnen')
    .select(`
      slug,
      first_name,
      last_name,
      bio_short,
      rating,
      review_count,
      avgs_certified,
      jotform_id,
      image_url,
      logo_url,
      gallery_images,
      languages,
      cities(slug, name),
      dozentin_services(
        services(slug, name, avgs_eligible, description_template)
      )
    `)
    .eq('active', true)
    .order('last_name', { ascending: true });

  if (error) {
    console.error('[getStaticPaths] Supabase error:', error.message);
    return [];
  }

  if (!dozentinnen || dozentinnen.length === 0) {
    console.error('[getStaticPaths] Keine Dozentinnen gefunden');
    return [];
  }

  console.log(`[getStaticPaths] ${dozentinnen.length} Dozentinnen geladen`);

  const paths = [];

  for (const d of dozentinnen) {
    if (!d.slug || typeof d.slug !== 'string') {
      console.warn('[getStaticPaths] Ungültiger slug:', d);
      continue;
    }

    const city = Array.isArray(d.cities) ? d.cities[0] : d.cities;
    if (!city || !city.slug) {
      console.warn('[getStaticPaths] Fehlende City für:', d.slug);
      continue;
    }

    const services = Array.isArray(d.dozentin_services)
      ? d.dozentin_services.map(ds => ds?.services ?? null).filter(Boolean)
      : [];

    console.log(`[getStaticPaths] ✓ ${d.slug} (${services.length} Services)`);

    paths.push({
      params: { slug: d.slug },
      props: {
        dozentin: {
          ...d,
          services
        }
      }
    });
  }

  console.log(`[getStaticPaths] ${paths.length} Seiten werden gebaut`);
  return paths;
}

const { dozentin } = Astro.props;
const city     = Array.isArray(dozentin.cities) ? dozentin.cities[0] : dozentin.cities;
const services = dozentin.services ?? [];

const hasImage    = !!dozentin.image_url;
const hasRating   = (dozentin.review_count ?? 0) > 0;
const hasServices = services.length > 0;
const hasBio      = !!dozentin.bio_short;
const hasForm     = !!dozentin.jotform_id;
const fullName    = `${dozentin.first_name} ${dozentin.last_name}`;

const primaryService = services[0]?.name ?? 'Beauty Kurs';

const seo = {
  title:
    `${fullName} – ${primaryService} ${city.name} | AVGS gefördert`,
  description:
    dozentin.bio_short ??
    `${primaryService} Einzelcoaching in ${city.name} ` +
    `mit ${fullName}. Staatlich gefördert über AVGS. ` +
    `Jetzt kostenlos starten.`,
  canonical:
    `https://dein-beauty-kurs.de/dozentinnen/${dozentin.slug}/`
};

const schema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": `${fullName} – Beauty Kurse`,
  "url": seo.canonical,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": city.name,
    "addressCountry": "DE"
  },
  ...(hasRating && {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": dozentin.rating,
      "reviewCount": dozentin.review_count
    }
  }),
  ...(hasServices && {
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Kurse",
      "itemListElement": services.map((s: any) => ({
        "@type": "Course",
        "name": s.name,
        "provider": {
          "@type": "Person",
          "name": fullName
        }
      }))
    }
  })
};
---

<SEOLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  schema={schema}
>

<style>
  :root {
    --color-dark:    #0D1B2A;
    --color-primary: #C9A96E;
    --color-success: #2D6A4F;
    --color-text:    #1A1A1A;
    --color-muted:   #7A7A7A;
    --color-surface: #FFFFFF;
    --color-border:  rgba(0, 0, 0, 0.1);
    --radius:        12px;
  }
  *, *::before, *::after { box-sizing: border-box; }
  body { font-family: 'Inter', system-ui, -apple-system, sans-serif; margin: 0; }
  .container { max-width: 900px; margin: 0 auto; padding: 0 24px; }
</style>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300..800;1,14..32,300..800&display=swap" rel="stylesheet" />

<main class="container" style="padding-top:48px;padding-bottom:80px;">

  <!-- BLOCK 1 — BREADCRUMB -->
  <nav style="font-size:13px;color:var(--color-muted);
              margin-bottom:32px;">
    <a href={`/${city.slug}/`}>{city.name}</a>
    {hasServices &&
      <span> › <a href={`/${city.slug}/${services[0].slug}/`}>
        {services[0].name}
      </a></span>
    }
    <span> › {fullName}</span>
  </nav>

  <!-- BLOCK 2 — HERO -->
  <section style="display:grid;
                  grid-template-columns:auto 1fr;
                  gap:32px;align-items:start;
                  margin-bottom:40px;flex-wrap:wrap;">

    {hasImage && (
      <img
        src={dozentin.image_url}
        alt={`${fullName} – ${primaryService} in ${city.name}`}
        width="160"
        height="160"
        loading="eager"
        style="width:160px;height:160px;border-radius:50%;
               object-fit:cover;flex-shrink:0;
               border:3px solid var(--color-border);"
      />
    )}

    <div>
      <div style="display:inline-block;background:#f0f9f4;
                  color:var(--color-success);font-size:13px;
                  font-weight:600;padding:5px 12px;
                  border-radius:20px;margin-bottom:12px;">
        ✓ AVGS förderbar – 100 % kostenlos
      </div>

      <h1 style="font-size:clamp(22px,4vw,34px);font-weight:700;
                 line-height:1.2;margin-bottom:6px;">
        {hasServices
          ? `${primaryService} in ${city.name}`
          : `Beauty Kurs in ${city.name}`
        }
      </h1>

      <p style="font-size:17px;color:var(--color-muted);
                margin-bottom:12px;">
        1:1 Einzelcoaching mit {fullName}
      </p>

      {hasRating && (
        <p style="font-size:14px;">
          ★ {dozentin.rating}/5
          <span style="color:var(--color-muted);">
            ({dozentin.review_count} Bewertungen)
          </span>
        </p>
      )}
    </div>
  </section>

  <!-- BLOCK 3 — BIO + SERVICES -->
  <section style="margin-bottom:40px;">

    {hasBio && (
      <p style="font-size:16px;line-height:1.8;
                max-width:640px;margin-bottom:28px;
                color:var(--color-text);">
        {dozentin.bio_short}
      </p>
    )}

    {!hasBio && (
      <p style="font-size:16px;line-height:1.8;
                max-width:640px;margin-bottom:28px;
                color:var(--color-text);">
        {fullName} bietet zertifizierte 1:1 Einzelcoachings
        in {city.name} an – staatlich anerkannt und vollständig
        förderbar über den Aktivierungs- und
        Vermittlungsgutschein (AVGS) der Arbeitsagentur.
        Das bedeutet: kein Eigenanteil, maximale
        Einzelbetreuung, direktes Feedback.
      </p>
    )}

    {hasServices && (
      <div>
        <h2 style="font-size:18px;font-weight:600;
                   margin-bottom:16px;color:var(--color-dark);">
          Angebotene Kurse
        </h2>
        <div style="display:flex;flex-wrap:wrap;gap:10px;">
          {services.map((s: any) => (
            <a
              href={`/${city.slug}/${s.slug}/`}
              style="background:var(--color-surface);
                     border:1px solid var(--color-border);
                     padding:8px 18px;border-radius:20px;
                     font-size:14px;font-weight:500;
                     color:var(--color-text);text-decoration:none;"
            >
              {s.name}
              {s.avgs_eligible &&
                <span style="color:var(--color-success);
                             margin-left:6px;font-size:12px;">
                  ✓ AVGS
                </span>
              }
            </a>
          ))}
        </div>
      </div>
    )}
  </section>

  <!-- BLOCK 4 — CTA / FORMULAR -->
  <section style="background:var(--color-dark);color:white;
                  border-radius:var(--radius);
                  padding:36px;margin-bottom:40px;">

    <h2 style="font-size:22px;font-weight:700;margin-bottom:8px;">
      Jetzt kostenlos starten
    </h2>
    <p style="color:#aaaaaa;font-size:15px;margin-bottom:24px;">
      Unterlagen für die Arbeitsagentur – kostenlos herunterladen
    </p>

    {hasForm
      ? <div id="jotform-container">
          <script
            src={`https://form.jotform.com/jsform/${dozentin.jotform_id}`}
          />
        </div>
      : <a
          href={`/${city.slug}/`}
          style="display:inline-block;
                 background:var(--color-primary);
                 color:white;padding:14px 28px;
                 border-radius:var(--radius);
                 font-weight:600;font-size:16px;
                 text-decoration:none;"
        >
          Alle Kurse in {city.name} ansehen →
        </a>
    }
  </section>

  <!-- BLOCK 5 — RÜCKLINK -->
  <a
    href={`/${city.slug}/`}
    style="font-size:14px;color:var(--color-muted);
           text-decoration:none;"
  >
    ← Alle Dozentinnen und Kurse in {city.name}
  </a>

</main>
</SEOLayout>
