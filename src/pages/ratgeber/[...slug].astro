---
import { getCollection, render } from 'astro:content';
import SEOLayout from '../../layouts/SEOLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

export const prerender = true;

export async function getStaticPaths() {
  const articles = await getCollection('ratgeber');
  return articles.map(entry => ({
    params: { slug: entry.id },
    props: { entry, allArticles: articles },
  }));
}

const { entry, allArticles } = Astro.props;
const { Content } = await render(entry);
const { title, description, modul, stadt, stadtSlug, serviceSlug, relatedDozentinSlug, relatedDozentinName, publishDate, faq } = entry.data;

const canonical = `https://dein-beauty-kurs.de/ratgeber/${entry.id}/`;

const MODUL_LABELS: Record<string, string> = {
  microblading:         'Microblading',
  powderbrows:          'Powder Brows',
  wimpernverlaengerung: 'Wimpernverlängerung',
  'camouflage-removal': 'Camouflage Removal',
  'velvet-lips':        'Velvet Lips',
  fachkosmetikerin:     'Fachkosmetikerin',
};

const modulLabel = MODUL_LABELS[modul] ?? modul;

const schemas: object[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description,
    datePublished: publishDate.toISOString(),
    author: { '@type': 'Organization', name: 'BeautyBusiness360', url: 'https://dein-beauty-kurs.de/' },
    publisher: { '@type': 'Organization', name: 'BeautyBusiness360', url: 'https://dein-beauty-kurs.de/' },
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  },
];

if (faq?.length) {
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map(item => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: { '@type': 'Answer', text: item.answer },
    })),
  });
}

const querlinks = allArticles
  .filter(a => a.data.modul === modul && a.id !== entry.id)
  .slice(0, 4);
---

<SEOLayout {title} {description} {canonical} schema={schemas}>
  <SiteHeader />
  <Breadcrumbs trail={[
    { label: 'Startseite', href: '/' },
    { label: 'Ratgeber', href: '/ratgeber/' },
    { label: title },
  ]} />

  <main class="rg-wrap">
    <article class="rg-article">
      <header class="rg-header">
        <div class="rg-meta">
          <span class="rg-tag">{modulLabel}</span>
          <span class="rg-sep">·</span>
          <span class="rg-city">{stadt}</span>
          <span class="rg-sep">·</span>
          <time datetime={publishDate.toISOString().split('T')[0]}>
            {publishDate.toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
        <h1 class="rg-h1">{title}</h1>
        <p class="rg-lead">{description}</p>
      </header>

      <div class="rg-body">
        <Content />
      </div>

      {faq && faq.length > 0 && (
        <section class="rg-faq">
          <h2 class="rg-faq-title">Häufige Fragen</h2>
          <dl class="rg-faq-list">
            {faq.map(item => (
              <div class="rg-faq-item">
                <dt class="rg-faq-q">{item.question}</dt>
                <dd class="rg-faq-a">{item.answer}</dd>
              </div>
            ))}
          </dl>
        </section>
      )}

      {relatedDozentinSlug && (
        <section class="rg-cta">
          <div class="rg-cta-inner">
            <p class="rg-cta-label">Deine Dozentin in {stadt}</p>
            <h2 class="rg-cta-title">
              {relatedDozentinName ?? 'Jetzt Termin anfragen'}
            </h2>
            <p class="rg-cta-text">
              Sieh dir aktuelle Termine, Bewertungen und das Anmeldeformular direkt auf dem Profil an.
            </p>
            <div class="rg-cta-links">
              <a href={`/dozentinnen/${relatedDozentinSlug}/`} class="rg-btn rg-btn--primary">
                Zum Dozentinnen-Profil
              </a>
              <a href={`/${stadtSlug}/${serviceSlug}/`} class="rg-btn rg-btn--secondary">
                Alle Kurse in {stadt}
              </a>
            </div>
          </div>
        </section>
      )}

      {querlinks.length > 0 && (
        <nav class="rg-querlinks" aria-label="Weitere Ratgeber">
          <h2 class="rg-ql-title">Weitere {modulLabel}-Trainings</h2>
          <ul class="rg-ql-list">
            {querlinks.map(a => (
              <li>
                <a href={`/ratgeber/${a.id}/`} class="rg-ql-link">
                  <span class="rg-ql-city">{a.data.stadt}</span>
                  <span class="rg-ql-text">{a.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}
    </article>
  </main>

  <SiteFooter />
</SEOLayout>

<style>
:root {
  --rg-max: 760px;
  --gold: #C8962E;
  --gold-light: #D4AF7A;
  --black: #111111;
  --cream: #F0EAE0;
  --muted: #888;
  --sans: 'Inter', system-ui, sans-serif;
  --serif: 'Cormorant Garamond', Georgia, serif;
}

.rg-wrap {
  background: var(--black);
  min-height: 60vh;
  padding: 48px 24px 80px;
}

.rg-article {
  max-width: var(--rg-max);
  margin: 0 auto;
}

/* Header */
.rg-header { margin-bottom: 40px; }

.rg-meta {
  font-family: var(--sans);
  font-size: 11px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.rg-tag {
  color: var(--gold);
  font-weight: 600;
}

.rg-sep { color: rgba(255,255,255,.15); }

.rg-h1 {
  font-family: var(--serif);
  font-size: clamp(28px, 5vw, 44px);
  font-weight: 600;
  color: var(--cream);
  line-height: 1.18;
  margin: 0 0 16px;
}

.rg-lead {
  font-family: var(--sans);
  font-size: 17px;
  line-height: 1.6;
  color: rgba(240,234,224,.7);
  margin: 0;
}

/* Article body */
.rg-body {
  font-family: var(--sans);
  font-size: 16px;
  line-height: 1.75;
  color: rgba(240,234,224,.85);
  border-top: 1px solid rgba(255,255,255,.07);
  padding-top: 36px;
  margin-bottom: 56px;
}

.rg-body :global(h2) {
  font-family: var(--serif);
  font-size: 26px;
  font-weight: 600;
  color: var(--cream);
  margin: 2.4em 0 .7em;
  line-height: 1.25;
}

.rg-body :global(h3) {
  font-family: var(--serif);
  font-size: 20px;
  font-weight: 600;
  color: var(--cream);
  margin: 1.8em 0 .5em;
}

.rg-body :global(p) {
  margin: 0 0 1.4em;
}

.rg-body :global(ul), .rg-body :global(ol) {
  padding-left: 1.4em;
  margin: 0 0 1.4em;
}

.rg-body :global(li) {
  margin-bottom: .5em;
}

.rg-body :global(strong) {
  color: var(--cream);
  font-weight: 600;
}

.rg-body :global(a) {
  color: var(--gold-light);
  text-decoration: underline;
  text-underline-offset: 3px;
}

/* FAQ */
.rg-faq {
  border-top: 1px solid rgba(255,255,255,.07);
  padding-top: 36px;
  margin-bottom: 56px;
}

.rg-faq-title {
  font-family: var(--serif);
  font-size: 28px;
  font-weight: 600;
  color: var(--cream);
  margin: 0 0 28px;
}

.rg-faq-list { margin: 0; }

.rg-faq-item {
  border-bottom: 1px solid rgba(255,255,255,.06);
  padding: 20px 0;
}

.rg-faq-item:first-child { padding-top: 0; }

.rg-faq-q {
  font-family: var(--sans);
  font-size: 15px;
  font-weight: 600;
  color: var(--cream);
  margin: 0 0 10px;
  line-height: 1.4;
}

.rg-faq-a {
  font-family: var(--sans);
  font-size: 14px;
  line-height: 1.7;
  color: rgba(240,234,224,.75);
  margin: 0;
}

/* CTA Box */
.rg-cta {
  background: rgba(200,150,46,.08);
  border: 1px solid rgba(200,150,46,.25);
  border-radius: 12px;
  padding: 32px 36px;
  margin-bottom: 56px;
}

.rg-cta-label {
  font-family: var(--sans);
  font-size: 11px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--gold);
  margin: 0 0 8px;
}

.rg-cta-title {
  font-family: var(--serif);
  font-size: 28px;
  font-weight: 600;
  color: var(--cream);
  margin: 0 0 12px;
  line-height: 1.2;
}

.rg-cta-text {
  font-family: var(--sans);
  font-size: 14px;
  color: rgba(240,234,224,.7);
  margin: 0 0 24px;
  line-height: 1.6;
}

.rg-cta-links {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.rg-btn {
  font-family: var(--sans);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: .06em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 12px 24px;
  border-radius: 6px;
  display: inline-block;
  transition: opacity .2s;
}

.rg-btn:hover { opacity: .85; }

.rg-btn--primary {
  background: var(--gold);
  color: #fff;
}

.rg-btn--secondary {
  background: rgba(255,255,255,.07);
  color: rgba(240,234,224,.8);
  border: 1px solid rgba(255,255,255,.12);
}

/* Querlinks */
.rg-querlinks {
  border-top: 1px solid rgba(255,255,255,.07);
  padding-top: 32px;
}

.rg-ql-title {
  font-family: var(--sans);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--muted);
  margin: 0 0 18px;
}

.rg-ql-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.rg-ql-link {
  display: flex;
  align-items: baseline;
  gap: 10px;
  text-decoration: none;
  padding: 12px 16px;
  border-radius: 8px;
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.07);
  transition: border-color .2s, background .2s;
}

.rg-ql-link:hover {
  border-color: rgba(200,150,46,.35);
  background: rgba(200,150,46,.05);
}

.rg-ql-city {
  font-family: var(--sans);
  font-size: 11px;
  font-weight: 600;
  color: var(--gold);
  letter-spacing: .08em;
  text-transform: uppercase;
  flex-shrink: 0;
}

.rg-ql-text {
  font-family: var(--sans);
  font-size: 14px;
  color: rgba(240,234,224,.8);
  line-height: 1.3;
}

@media (max-width: 640px) {
  .rg-wrap { padding: 32px 20px 64px; }
  .rg-cta { padding: 24px 20px; }
  .rg-cta-links { flex-direction: column; }
  .rg-btn { text-align: center; }
}
</style>
