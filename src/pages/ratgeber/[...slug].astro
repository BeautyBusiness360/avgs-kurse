---
import { getCollection, render } from 'astro:content';
import SEOLayout from '../../layouts/SEOLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import DozentinnenGrid from '../../components/DozentinnenGrid.astro';
import GalerieGrid from '../../components/GalerieGrid.astro';
import { supabase } from '../../lib/supabase';
import { HUB_CITY_SLUG } from '../../data/location-overrides';

export const prerender = true;

export async function getStaticPaths() {
  const articles = await getCollection('ratgeber');

  const { data: allDoz } = await supabase
    .from('dozentinnen')
    .select(`
      slug, first_name, last_name,
      cities(slug, name),
      dozentin_services(services(slug, name, avgs_eligible))
    `)
    .eq('active', true);

  const dozentinnen = allDoz ?? [];

  return articles.map(entry => {
    const { stadtSlug, serviceSlug } = entry.data;

    const gridDozentinnen = dozentinnen.filter(d => {
      const effCity = HUB_CITY_SLUG[d.slug] ?? (Array.isArray(d.cities) ? d.cities[0]?.slug : d.cities?.slug);
      if (effCity !== stadtSlug) return false;
      const rows = Array.isArray(d.dozentin_services) ? d.dozentin_services : [];
      return rows.some(ds => {
        const svc = Array.isArray(ds?.services) ? ds.services[0] : ds?.services;
        return svc?.slug === serviceSlug && svc?.avgs_eligible;
      });
    });

    return {
      params: { slug: entry.id },
      props: { entry, allArticles: articles, gridDozentinnen },
    };
  });
}

const { entry, allArticles, gridDozentinnen } = Astro.props;
const { Content, headings } = await render(entry);
const {
  title, description, modul, serviceSlug,
  publishDate, faq,
} = entry.data;
const stadt     = entry.data.stadt;
const stadtSlug = entry.data.stadtSlug;
const isPillar  = !stadtSlug;

const canonical = `https://dein-beauty-kurs.de/ratgeber/${entry.id}/`;

const MODUL_LABELS: Record<string, string> = {
  microblading:         'Microblading',
  powderbrows:          'Powder Brows',
  wimpernverlaengerung: 'Wimpernverlängerung',
  'camouflage-removal': 'Camouflage & Removal',
  'velvet-lips':        'Velvet Lips',
  fachkosmetikerin:     'Fachkosmetikerin',
};
const modulLabel = MODUL_LABELS[modul] ?? modul;

// Reading time (≈ 200 words/min)
const rawBody = entry.body ?? '';
const wordCount = rawBody.split(/\s+/).filter(Boolean).length;
const readMinutes = Math.max(1, Math.ceil(wordCount / 200));

// TOC: only H2 headings, min 3 to show
const tocHeadings = headings.filter((h: { depth: number; slug: string; text: string }) => h.depth === 2);
const showToc = tocHeadings.length >= 3;

// JSON-LD schemas
const schemas: object[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description,
    datePublished: publishDate.toISOString(),
    author: { '@type': 'Organization', name: 'BeautyBusiness360', url: 'https://dein-beauty-kurs.de/' },
    publisher: { '@type': 'Organization', name: 'BeautyBusiness360', url: 'https://dein-beauty-kurs.de/' },
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  },
];

if (faq?.length) {
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map(item => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: { '@type': 'Answer', text: item.answer },
    })),
  });
}

const querlinks = allArticles
  .filter(a => a.data.modul === modul && a.id !== entry.id)
  .slice(0, 4);

---

<SEOLayout {title} {description} {canonical} schema={schemas}>
  <!-- Reading progress bar -->
  <div class="rg-progress" id="rg-progress" aria-hidden="true">
    <div class="rg-progress-bar" id="rg-progress-bar"></div>
  </div>

  <SiteHeader />
  <Breadcrumbs trail={[
    { label: 'Startseite', href: '/' },
    { label: 'Ratgeber', href: '/ratgeber/' },
    { label: title },
  ]} />

  <main class="rg-wrap">
    <div class="rg-outer">

      <!-- ── Article column ───────────────────────────────────── -->
      <article class="rg-article" id="rg-article">

        <!-- Header -->
        <header class="rg-header">
          <div class="rg-meta">
            <span class="rg-tag">{modulLabel}</span>
            {stadt && <><span class="rg-sep">·</span><span class="rg-city">{stadt}</span></>}
            <span class="rg-sep">·</span>
            <time datetime={publishDate.toISOString().split('T')[0]}>
              {publishDate.toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <span class="rg-sep">·</span>
            <span class="rg-readtime">{readMinutes} Min. Lesezeit</span>
          </div>
          <h1 class="rg-h1">{title}</h1>
          <p class="rg-lead">{description}</p>
        </header>

        <!-- Inline TOC (mobile only — sidebar TOC hidden on mobile) -->
        {showToc && (
          <nav class="rg-toc-inline" aria-label="Inhaltsverzeichnis">
            <button class="rg-toc-toggle" aria-expanded="false" aria-controls="rg-toc-inline-list">
              <span class="rg-toc-toggle-label">Inhaltsverzeichnis</span>
              <svg class="rg-toc-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </button>
            <ol class="rg-toc-list" id="rg-toc-inline-list" hidden>
              {tocHeadings.map((h: { slug: string; text: string }) => (
                <li><a href={`#${h.slug}`}>{h.text}</a></li>
              ))}
            </ol>
          </nav>
        )}

        <!-- Article body -->
        <div class="rg-body">
          <Content />
        </div>

        <!-- FAQ accordion -->
        {faq && faq.length > 0 && (
          <section class="rg-faq">
            <h2 class="rg-faq-title">Häufige Fragen</h2>
            <div class="rg-faq-list">
              {faq.map(item => (
                <details class="rg-faq-item">
                  <summary class="rg-faq-q">
                    <span>{item.question}</span>
                    <svg class="rg-faq-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                      <path d="M4.5 6.75L9 11.25L13.5 6.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  </summary>
                  <div class="rg-faq-a">{item.answer}</div>
                </details>
              ))}
            </div>
          </section>
        )}
      </article>

      <!-- ── Sidebar TOC (desktop only) ──────────────────────── -->
      {showToc && (
        <aside class="rg-toc-col" aria-label="Inhaltsverzeichnis">
          <nav class="rg-toc">
            <p class="rg-toc-heading">Inhalt</p>
            <ol class="rg-toc-nav">
              {tocHeadings.map((h: { slug: string; text: string }) => (
                <li>
                  <a href={`#${h.slug}`} class="rg-toc-link">{h.text}</a>
                </li>
              ))}
            </ol>
          </nav>
        </aside>
      )}

    </div><!-- /.rg-outer -->

    <!-- ── Full-width sections ────────────────────────────────── -->
    <div class="rg-full-width">
      <GalerieGrid module={serviceSlug} />
    </div>

    {gridDozentinnen.length > 0 && (
      <div class="rg-full-width">
        <section class="rg-grid-section">
          <p class="rg-section-eyebrow">Netzwerk</p>
          <h2 class="rg-grid-title">
            {stadt ? `Dozentinnen für dieses Training in ${stadt}` : 'Dozentinnen für dieses Training'}
          </h2>
          <DozentinnenGrid dozentinnen={gridDozentinnen} moduleFilter={serviceSlug} />
        </section>
      </div>
    )}

    {querlinks.length > 0 && (
      <div class="rg-full-width">
        <nav class="rg-querlinks" aria-label="Weitere Ratgeber">
          <p class="rg-ql-label">Weitere {modulLabel}-Ratgeber</p>
          <div class="rg-ql-slider">
            {querlinks.map(a => (
              <a href={`/ratgeber/${a.id}/`} class="rg-ql-card">
                <span class="rg-ql-city">{a.data.stadt ?? 'DE'}</span>
                <span class="rg-ql-text">{a.data.title}</span>
                <svg class="rg-ql-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </a>
            ))}
          </div>
        </nav>
      </div>
    )}
  </main>

  <SiteFooter />
</SEOLayout>

<!-- Progress bar + TOC collapse toggle -->
<script>
  // Reading progress bar
  const bar    = document.getElementById('rg-progress-bar');
  const art    = document.getElementById('rg-article');
  if (bar && art) {
    const update = () => {
      const rect  = art.getBoundingClientRect();
      const total = art.scrollHeight;
      const done  = Math.max(0, -rect.top);
      bar.style.width = Math.min(100, (done / total) * 100) + '%';
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }

  // Inline TOC toggle
  const btn = document.querySelector<HTMLButtonElement>('.rg-toc-toggle');
  const lst = document.getElementById('rg-toc-inline-list');
  if (btn && lst) {
    btn.addEventListener('click', () => {
      const open = lst.hasAttribute('hidden');
      if (open) lst.removeAttribute('hidden'); else lst.setAttribute('hidden', '');
      btn.setAttribute('aria-expanded', String(open));
      btn.classList.toggle('is-open', open);
    });
  }

  // Highlight active TOC link (sidebar) on scroll
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('.rg-toc-link'));
  if (links.length) {
    const headings = links.map(l => document.getElementById(l.hash.slice(1)));
    const activate = () => {
      let active = 0;
      for (let i = 0; i < headings.length; i++) {
        if (headings[i] && headings[i]!.getBoundingClientRect().top <= 120) active = i;
      }
      links.forEach((l, i) => l.classList.toggle('is-active', i === active));
    };
    window.addEventListener('scroll', activate, { passive: true });
    activate();
  }
</script>

<style>
/* ── Design tokens ──────────────────────────────────────────── */
:root {
  --gold:       #C8962E;
  --gold-lt:    #D4AF7A;
  --gold-dim:   rgba(200,150,46,.12);
  --gold-ring:  rgba(200,150,46,.28);
  --black:      #111111;
  --cream:      #F0EAE0;
  --muted:      #888;
  --border:     rgba(0,0,0,.08);
  --border-md:  rgba(0,0,0,.13);
  --sans:       'Inter', system-ui, sans-serif;
  --serif:      'Cormorant Garamond', Georgia, serif;
  --col:        700px;
  --side:       230px;
  --gap:        56px;
  --wrap-pad:   clamp(20px, 4vw, 60px);
}

/* ── Progress bar ───────────────────────────────────────────── */
.rg-progress {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 3px;
  z-index: 1000;
  background: rgba(0,0,0,.06);
}
.rg-progress-bar {
  height: 100%;
  width: 0;
  background: var(--gold);
  transition: width .1s linear;
}

/* ── Outer layout ──────────────────────────────────────────── */
.rg-wrap {
  --border: rgba(0,0,0,0.1);
  background: #ffffff;
  min-height: 60vh;
  padding: clamp(36px, 5vw, 64px) var(--wrap-pad) 100px;
}
.rg-outer {
  max-width: calc(var(--col) + var(--side) + var(--gap));
  margin: 0 auto;
  display: grid;
  grid-template-columns: minmax(0, var(--col)) var(--side);
  gap: var(--gap);
  align-items: start;
}
@media (max-width: 1060px) {
  .rg-outer {
    grid-template-columns: minmax(0, var(--col));
    max-width: var(--col);
    gap: 0;
  }
  .rg-toc-col { display: none; }
}

/* ── Article ────────────────────────────────────────────────── */
.rg-article { min-width: 0; }

/* ── Header ─────────────────────────────────────────────────── */
.rg-header { margin-bottom: 44px; }
.rg-meta {
  font-family: var(--sans);
  font-size: 11px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 18px;
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}
.rg-tag     { color: var(--gold); font-weight: 600; }
.rg-sep     { color: rgba(0,0,0,.2); }
.rg-city    { color: rgba(17,17,17,.6); }
.rg-readtime { color: var(--muted); }

.rg-h1 {
  font-family: var(--serif);
  font-size: clamp(28px, 5vw, 46px);
  font-weight: 600;
  color: var(--black);
  line-height: 1.15;
  margin: 0 0 18px;
  letter-spacing: -.01em;
}
.rg-lead {
  font-family: var(--sans);
  font-size: 17px;
  line-height: 1.65;
  color: rgba(17,17,17,.62);
  margin: 0;
}

/* ── Inline TOC (mobile) ────────────────────────────────────── */
.rg-toc-inline {
  border: 1px solid var(--border-md);
  border-radius: 10px;
  overflow: hidden;
  margin-bottom: 40px;
}
@media (min-width: 1061px) { .rg-toc-inline { display: none; } }

.rg-toc-toggle {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 18px;
  background: rgba(0,0,0,.03);
  border: none;
  cursor: pointer;
  color: var(--black);
  font-family: var(--sans);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: .06em;
  text-transform: uppercase;
}
.rg-toc-toggle-label { flex: 1; text-align: left; }
.rg-toc-icon {
  flex-shrink: 0;
  color: var(--gold);
  transition: transform .25s;
}
.rg-toc-toggle.is-open .rg-toc-icon { transform: rotate(180deg); }

.rg-toc-list {
  list-style: none;
  margin: 0;
  padding: 12px 0 16px;
  background: rgba(0,0,0,.015);
  counter-reset: toc;
}
.rg-toc-list li {
  counter-increment: toc;
  display: flex;
  align-items: baseline;
  gap: 8px;
  padding: 0 18px;
}
.rg-toc-list li::before {
  content: counter(toc, decimal-leading-zero);
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 600;
  color: var(--gold);
  flex-shrink: 0;
}
.rg-toc-list a {
  font-family: var(--sans);
  font-size: 13px;
  color: rgba(17,17,17,.7);
  text-decoration: none;
  line-height: 1.4;
  padding: 5px 0;
  display: block;
}
.rg-toc-list a:hover { color: var(--gold); }

/* ── Article body ───────────────────────────────────────────── */
.rg-body {
  font-family: var(--sans);
  font-size: 16px;
  line-height: 1.78;
  color: rgba(17,17,17,.82);
  border-top: 1px solid var(--border);
  padding-top: 40px;
  margin-bottom: 64px;
}
.rg-body :global(h2) {
  font-family: var(--serif);
  font-size: clamp(22px, 3vw, 28px);
  font-weight: 600;
  color: var(--black);
  margin: 2.6em 0 .65em;
  line-height: 1.22;
  letter-spacing: -.01em;
}
.rg-body :global(h2::before) {
  content: '';
  display: block;
  width: 28px;
  height: 2px;
  background: var(--gold);
  margin-bottom: 10px;
  opacity: .7;
}
.rg-body :global(h3) {
  font-family: var(--serif);
  font-size: 20px;
  font-weight: 600;
  color: var(--black);
  margin: 1.8em 0 .5em;
}
.rg-body :global(p) { margin: 0 0 1.5em; }
.rg-body :global(ul),
.rg-body :global(ol) {
  padding-left: 1.5em;
  margin: 0 0 1.5em;
}
.rg-body :global(li) { margin-bottom: .55em; }
.rg-body :global(strong) { color: var(--black); font-weight: 600; }
.rg-body :global(em) { font-style: italic; color: var(--gold); }
.rg-body :global(a) {
  color: var(--gold);
  text-decoration: underline;
  text-underline-offset: 3px;
}
.rg-body :global(a:hover) { color: #9a7020; }
.rg-body :global(blockquote) {
  border-left: 3px solid var(--gold);
  padding: 16px 20px;
  margin: 1.8em 0;
  background: var(--gold-dim);
  border-radius: 0 8px 8px 0;
  color: var(--black);
  font-style: italic;
}
.rg-body :global(blockquote p:last-child) { margin-bottom: 0; }
.rg-body :global(code) {
  font-size: .875em;
  background: rgba(0,0,0,.06);
  padding: 2px 6px;
  border-radius: 4px;
  font-family: ui-monospace, monospace;
}
.rg-body :global(hr) {
  border: none;
  border-top: 1px solid var(--border);
  margin: 2.5em 0;
}

/* ── FAQ accordion ──────────────────────────────────────────── */
.rg-faq {
  border-top: 1px solid var(--border);
  padding-top: 40px;
  margin-bottom: 64px;
}
.rg-faq-title {
  font-family: var(--serif);
  font-size: 28px;
  font-weight: 600;
  color: var(--black);
  margin: 0 0 28px;
}
.rg-faq-list { display: flex; flex-direction: column; gap: 4px; }
.rg-faq-item {
  border: 1px solid var(--border-md);
  border-radius: 10px;
  overflow: hidden;
  background: #fff;
  transition: border-color .2s;
}
.rg-faq-item[open] {
  border-color: var(--gold-ring);
  background: rgba(200,150,46,.03);
}
.rg-faq-q {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 18px 20px;
  font-family: var(--sans);
  font-size: 15px;
  font-weight: 600;
  color: var(--black);
  cursor: pointer;
  list-style: none;
  user-select: none;
  line-height: 1.4;
}
.rg-faq-q::-webkit-details-marker { display: none; }
.rg-faq-q span { flex: 1; }
.rg-faq-icon {
  flex-shrink: 0;
  color: var(--gold);
  transition: transform .25s;
}
.rg-faq-item[open] .rg-faq-icon { transform: rotate(180deg); }
.rg-faq-a {
  font-family: var(--sans);
  font-size: 14px;
  line-height: 1.72;
  color: rgba(17,17,17,.65);
  padding: 0 20px 18px;
}

/* ── Full-width container ───────────────────────────────────── */
.rg-full-width {
  max-width: 1120px;
  margin: 0 auto;
  padding: 48px 40px 0;
}
@media (max-width: 860px) {
  .rg-full-width { padding: 32px 20px 0; }
}

/* ── Grid section ───────────────────────────────────────────── */
.rg-section-eyebrow {
  font-family: var(--sans);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--gold);
  margin: 0 0 8px;
}
.rg-grid-section {
  margin-bottom: 64px;
  border-top: 1px solid var(--border);
  padding-top: 40px;
}
.rg-grid-title {
  font-family: var(--serif);
  font-size: 26px;
  font-weight: 600;
  color: var(--black);
  margin: 0 0 24px;
}

/* ── Querlinks Karten-Slider ────────────────────────────────── */
.rg-querlinks {
  border-top: 1px solid var(--border);
  padding-top: 36px;
}
.rg-ql-label {
  font-family: var(--sans);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--muted);
  margin: 0 0 16px;
}
.rg-ql-slider {
  display: flex;
  gap: 16px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  padding-bottom: 16px;
  scrollbar-width: none;
}
.rg-ql-slider::-webkit-scrollbar { display: none; }
.rg-ql-card {
  min-width: 280px;
  scroll-snap-align: start;
  flex-shrink: 0;
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  border: 1px solid rgba(0,0,0,.08);
  box-shadow: 0 2px 12px rgba(0,0,0,.06);
  text-decoration: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
  transition: box-shadow .2s, transform .2s;
}
.rg-ql-card:hover {
  box-shadow: 0 6px 24px rgba(0,0,0,.10);
  transform: translateY(-2px);
}
.rg-ql-city {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 700;
  color: var(--gold);
  letter-spacing: .1em;
  text-transform: uppercase;
  background: var(--gold-dim);
  padding: 3px 8px;
  border-radius: 4px;
  white-space: nowrap;
  align-self: flex-start;
}
.rg-ql-text {
  font-family: var(--serif);
  font-size: 16px;
  font-weight: 600;
  color: var(--black);
  line-height: 1.3;
  flex: 1;
}
.rg-ql-arrow { color: var(--muted); flex-shrink: 0; align-self: flex-end; }
.rg-ql-card:hover .rg-ql-arrow { color: var(--gold); }

/* ── Sidebar TOC ────────────────────────────────────────────── */
.rg-toc-col {
  position: sticky;
  top: 100px;
  max-height: calc(100vh - 140px);
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(200,150,46,.3) transparent;
}
.rg-toc {
  background: #111111;
  border-radius: 12px;
  padding: 24px;
}
.rg-toc-heading {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--gold);
  margin: 0 0 14px;
}
.rg-toc-nav {
  list-style: none;
  padding: 0;
  margin: 0;
  counter-reset: toc-side;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.rg-toc-nav li { counter-increment: toc-side; display: flex; align-items: baseline; gap: 8px; }
.rg-toc-nav li::before {
  content: counter(toc-side, decimal-leading-zero);
  font-family: var(--sans);
  font-size: 9px;
  font-weight: 600;
