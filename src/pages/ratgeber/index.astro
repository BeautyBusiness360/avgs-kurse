---
import { getCollection } from 'astro:content';
import SEOLayout from '../../layouts/SEOLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

export const prerender = true;

const articles = await getCollection('ratgeber');

articles.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const MODUL_LABELS: Record<string, string> = {
  microblading:         'Microblading',
  powderbrows:          'Powder Brows',
  wimpernverlaengerung: 'Wimpernverlängerung',
  'camouflage-removal': 'Camouflage Removal',
  'velvet-lips':        'Velvet Lips',
  fachkosmetikerin:     'Fachkosmetikerin',
};

const MODUL_ORDER = ['microblading', 'powderbrows', 'wimpernverlaengerung', 'camouflage-removal', 'velvet-lips', 'fachkosmetikerin'];

const byModul = new Map<string, typeof articles>();
for (const modul of MODUL_ORDER) {
  const group = articles.filter(a => a.data.modul === modul);
  if (group.length > 0) byModul.set(modul, group);
}

const canonical = 'https://dein-beauty-kurs.de/ratgeber/';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Ratgeber – AVGS-geförderte Perfektionstrainings',
  description: 'Alle Ratgeber zu staatlich geförderten Beauty-Schulungen über AVGS: Microblading, Powder Brows, Wimpernverlängerung und mehr.',
  url: canonical,
  publisher: { '@type': 'Organization', name: 'BeautyBusiness360', url: 'https://dein-beauty-kurs.de/' },
};
---

<SEOLayout
  title="Ratgeber: AVGS-geförderte Beauty-Schulungen – Microblading, Brows & mehr"
  description="Alle Ratgeber zu staatlich geförderten Perfektionstrainings über AVGS: Microblading, Powder Brows, Wimpernverlängerung, Camouflage Removal und mehr – deutschlandweit."
  {canonical}
  schema={schema}
>
  <SiteHeader />
  <Breadcrumbs trail={[
    { label: 'Startseite', href: '/' },
    { label: 'Ratgeber' },
  ]} />

  <main class="ri-wrap">
    <header class="ri-header">
      <p class="ri-eyebrow">Wissen & Förderung</p>
      <h1 class="ri-h1">Ratgeber: AVGS-geförderte Perfektionstrainings</h1>
      <p class="ri-lead">
        Du möchtest deine Technik vertiefen – vollständig gefördert über deinen AVGS-Gutschein?
        Hier findest du alle Ratgeber zu unseren AZAV-zertifizierten Schulungen.
      </p>
    </header>

    {byModul.size === 0 ? (
      <p class="ri-empty">Noch keine Artikel veröffentlicht. Bald verfügbar.</p>
    ) : (
      Array.from(byModul.entries()).map(([modul, group]) => (
        <section class="ri-section">
          <h2 class="ri-section-title">{MODUL_LABELS[modul] ?? modul}</h2>
          <ul class="ri-list">
            {group.map(entry => (
              <li class="ri-card">
                <a href={`/ratgeber/${entry.id}/`} class="ri-card-link">
                  <div class="ri-card-meta">
                    <span class="ri-card-city">{entry.data.stadt}</span>
                    <span class="ri-card-date">
                      {entry.data.publishDate.toLocaleDateString('de-DE', { year: 'numeric', month: 'short' })}
                    </span>
                  </div>
                  <h3 class="ri-card-title">{entry.data.title}</h3>
                  <p class="ri-card-desc">{entry.data.description}</p>
                  <span class="ri-card-cta">Ratgeber lesen &rsaquo;</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    )}
  </main>

  <SiteFooter />
</SEOLayout>

<style>
:root {
  --gold: #C8962E;
  --black: #111111;
  --cream: #F0EAE0;
  --muted: #888;
  --sans: 'Inter', system-ui, sans-serif;
  --serif: 'Cormorant Garamond', Georgia, serif;
}

.ri-wrap {
  background: var(--black);
  min-height: 60vh;
  padding: 56px 24px 96px;
}

.ri-header {
  max-width: 760px;
  margin: 0 auto 64px;
  text-align: center;
}

.ri-eyebrow {
  font-family: var(--sans);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .13em;
  text-transform: uppercase;
  color: var(--gold);
  margin: 0 0 14px;
}

.ri-h1 {
  font-family: var(--serif);
  font-size: clamp(28px, 5vw, 46px);
  font-weight: 600;
  color: var(--cream);
  line-height: 1.18;
  margin: 0 0 18px;
}

.ri-lead {
  font-family: var(--sans);
  font-size: 16px;
  line-height: 1.7;
  color: rgba(240,234,224,.7);
  margin: 0;
  max-width: 560px;
  margin-inline: auto;
}

.ri-empty {
  font-family: var(--sans);
  color: var(--muted);
  text-align: center;
  font-size: 15px;
}

/* Sections */
.ri-section {
  max-width: 900px;
  margin: 0 auto 56px;
}

.ri-section-title {
  font-family: var(--sans);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .13em;
  text-transform: uppercase;
  color: var(--gold);
  margin: 0 0 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid rgba(200,150,46,.2);
}

/* Cards */
.ri-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  gap: 16px;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
}

.ri-card {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 10px;
  transition: border-color .2s, transform .2s;
}

.ri-card:hover {
  border-color: rgba(200,150,46,.3);
  transform: translateY(-2px);
}

.ri-card-link {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 22px 24px;
  text-decoration: none;
  height: 100%;
  box-sizing: border-box;
}

.ri-card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.ri-card-city {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--gold);
}

.ri-card-date {
  font-family: var(--sans);
  font-size: 11px;
  color: var(--muted);
}

.ri-card-title {
  font-family: var(--serif);
  font-size: 19px;
  font-weight: 600;
  color: var(--cream);
  line-height: 1.3;
  margin: 4px 0 0;
}

.ri-card-desc {
  font-family: var(--sans);
  font-size: 13px;
  line-height: 1.6;
  color: rgba(240,234,224,.6);
  margin: 0;
  flex: 1;
}

.ri-card-cta {
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 600;
  color: var(--gold);
  letter-spacing: .05em;
  margin-top: 8px;
}

@media (max-width: 640px) {
  .ri-wrap { padding: 36px 20px 72px; }
  .ri-list { grid-template-columns: 1fr; }
}
</style>
