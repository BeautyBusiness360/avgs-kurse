---
import SEOLayout from '../../layouts/SEOLayout.astro';
import DozentinInfoBox from '../../components/DozentinInfoBox.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { CITY_DISPLAY, SERVICE_DISPLAY_NAME } from '../../data/location-overrides';
import SiteFooter from '../../components/SiteFooter.astro';
import { supabase } from '../../lib/supabase';
import fs from 'node:fs';
import path from 'node:path';

export const prerender = true;

export async function getStaticPaths() {
  const [standorteRes, staedteRes, dozRes] = await Promise.all([
    supabase.from('standorte').select('name, strasse, plz, ort, city_slug, region').order('name'),
    supabase.from('staedte').select('city_slug, stadt_name, intro_statistik, intro_quelle').order('stadt_name'),
    supabase
      .from('dozentinnen')
      .select('slug, first_name, last_name, cities(slug, name), dozentin_services(services(slug, name, avgs_eligible))')
      .eq('active', true)
      .order('last_name'),
  ]);

  const standorteAll = standorteRes.data ?? [];
  const staedteAll   = staedteRes.data ?? [];
  const dozAll       = dozRes.data ?? [];

  // Build city_slug → region lookup from standorte table
  const cityToRegion: Record<string, string> = {};
  for (const s of standorteAll) {
    if (s.city_slug && s.region) cityToRegion[s.city_slug] = s.region;
  }

  // Distinct hub regions (one page per region)
  const regions = [...new Set(standorteAll.map(s => s.region).filter(Boolean))] as string[];

  // Group dozentinnen by their region (derived via standorte mapping)
  const dozByRegion: Record<string, any[]> = {};
  for (const d of dozAll) {
    const city = Array.isArray(d.cities) ? d.cities[0] : d.cities;
    if (!city?.slug) continue;
    const region = cityToRegion[city.slug] ?? city.slug;
    if (!dozByRegion[region]) dozByRegion[region] = [];
    const dsRows = Array.isArray(d.dozentin_services) ? d.dozentin_services : [];
    const serviceNames: string[] = [];
    const serviceSlugs: string[] = [];
    const serviceAvgsEligible: boolean[] = [];
    for (const ds of dsRows) {
      const s = Array.isArray(ds?.services) ? ds.services[0] : ds?.services;
      if (!s?.slug) continue;
      serviceNames.push(SERVICE_DISPLAY_NAME[s.slug] ?? s.name);
      serviceSlugs.push(s.slug);
      serviceAvgsEligible.push(!!s.avgs_eligible);
    }
    dozByRegion[region].push({ ...d, citySlugOfDoz: city.slug, cityName: city.name, serviceNames, serviceSlugs, serviceAvgsEligible });
  }

  return regions.map(region => {
    const info = staedteAll.find(s => s.city_slug === region) ?? null;
    return {
      params: { citySlug: region },
      props: {
        citySlug:       region,
        stadtName:      info?.stadt_name ?? (region.charAt(0).toUpperCase() + region.slice(1)),
        introStatistik: info?.intro_statistik ?? null,
        introQuelle:    info?.intro_quelle ?? null,
        standorte:      standorteAll
          .filter(s => s.region === region)
          .sort((a, b) => {
            const aHub = a.city_slug === region ? 0 : 1;
            const bHub = b.city_slug === region ? 0 : 1;
            if (aHub !== bHub) return aHub - bHub;
            const ortCmp = a.ort.localeCompare(b.ort, 'de');
            if (ortCmp !== 0) return ortCmp;
            return a.name.localeCompare(b.name, 'de');
          }),
        dozentinnen:    dozByRegion[region] ?? [],
      }
    };
  });
}

interface Standort {
  name: string;
  strasse: string | null;
  plz: string | null;
  ort: string;
}
interface DozRaw {
  slug: string;
  first_name: string;
  last_name: string;
  citySlugOfDoz: string;
  cityName: string;
  serviceNames: string[];
  serviceSlugs: string[];
  serviceAvgsEligible: boolean[];
}
interface DozWithImg extends DozRaw {
  profileImg: string | null;
  localSlug: string;
}

const {
  citySlug,
  stadtName,
  introStatistik,
  introQuelle,
  standorte,
  dozentinnen,
} = Astro.props as {
  citySlug: string;
  stadtName: string;
  introStatistik: string | null;
  introQuelle: string | null;
  standorte: Standort[];
  dozentinnen: DozRaw[];
};

// Unique services offered in this city — derived from dozentinnen props (proven correct on Vercel)
const seenServiceSlugs = new Set<string>();
const cityServices: { slug: string; displayName: string; imgSrc: string | null }[] = [];
for (const d of dozentinnen) {
  for (let i = 0; i < (d.serviceSlugs ?? []).length; i++) {
    if (!(d.serviceAvgsEligible?.[i] ?? true)) continue;
    const slug = d.serviceSlugs[i];
    if (!seenServiceSlugs.has(slug)) {
      seenServiceSlugs.add(slug);
      const folder = slug.replace(/-masterclass$/, '');
      const rel = `/images/Modul-Bilder/${folder}/gallery-1.webp`;
      const imgSrc = fs.existsSync(path.join(process.cwd(), 'public', rel)) ? rel : null;
      cityServices.push({ slug, displayName: d.serviceNames[i] ?? slug, imgSrc });
    }
  }
}

// City hero image (build-time fs check)
const cityImageRel = `/images/staedte/${citySlug}.webp`;
const hasCityImage = fs.existsSync(path.join(process.cwd(), 'public', cityImageRel));

// Resolve dozentin profile images at build time (same logic as [slug].astro)
const dozentinnenWithImg: DozWithImg[] = dozentinnen.map(d => {
  const localSlug = d.slug.replace(new RegExp(`-${d.citySlugOfDoz}$`), '');
  const rel       = `/images/dozentinnen/${localSlug}/${localSlug}.webp`;
  const hasImg    = fs.existsSync(path.join(process.cwd(), 'public', rel));
  return { ...d, localSlug, profileImg: hasImg ? rel : null };
});

const hasStandorte   = standorte.length > 0;
const hasDozentinnen = dozentinnenWithImg.length > 0;

// Extract number-phrase from intro_statistik (strips "In {stadt} gibt es " prefix if present)
let introZahlSatz: string | null = null;
if (introStatistik) {
  const prefix = `In ${stadtName} gibt es `;
  introZahlSatz = introStatistik.toLowerCase().startsWith(prefix.toLowerCase())
    ? introStatistik.slice(prefix.length).replace(/[.,]\s*$/, '')
    : introStatistik.replace(/[.,]\s*$/, '');
}

const introText = citySlug === 'essen'
  ? `Geförderte Beauty-Weiterbildungen in Essen – für jedes Level: Perfektionstrainings (AVGS) für erfahrene PMU-, Microblading- & Wimpern-Profis sowie die berufliche Qualifizierung zur Fachkosmetikerin (Bildungsgutschein, §81 SGB III) für Einsteiger:innen ohne Vorkenntnisse.`
  : (introZahlSatz
      ? `In ${stadtName} gibt es ${introZahlSatz}. Doch nicht alle Studioinhaberinnen und Kosmetikerinnen beherrschen anspruchsvolle Techniken wie Permanent Make-up oder Wimpernverlängerung – diese erfordern fundierte Weiterbildung mit viel Praxis. Folgende Akademien sind anerkannt und zertifiziert:`
      : `In ${stadtName} beherrschen nicht alle Studioinhaberinnen und Kosmetikerinnen anspruchsvolle Techniken wie Permanent Make-up oder Wimpernverlängerung – diese erfordern fundierte Weiterbildung mit viel Praxis. Folgende Akademien sind anerkannt und zertifiziert:`);

const seoTitle = `Zertifizierte Kosmetikschulen in ${stadtName} – AVGS-gefördert`;
const seoDescription =
  `Staatlich geförderte Perfektionstrainings in ${stadtName}. ` +
  `100 % kostenfrei bei Bewilligung über die Agentur für Arbeit. ` +
  `Zertifizierte Dozentinnen, AZAV-anerkannte Schulungsstandorte.`;
const canonical = `https://dein-beauty-kurs.de/${citySlug}/`;

const essenFaqItems = citySlug === 'essen' ? [
  {
    q: 'Brauche ich Vorkenntnisse für die Fachkosmetikerin-Qualifizierung?',
    a: 'Nein. Die berufliche Qualifizierung zur Fachkosmetikerin richtet sich ausdrücklich an Einsteiger:innen ohne Vorkenntnisse. Voraussetzung ist lediglich ein Schulabschluss sowie der Bezug von Leistungen der Agentur für Arbeit oder des Jobcenters (Bildungsgutschein nach §81 SGB III).',
  },
  {
    q: 'Was kostet die Fachkosmetikerin-Qualifizierung in Essen?',
    a: 'Bei Bewilligung eines Bildungsgutscheins (§81 SGB III) durch die Agentur für Arbeit oder das Jobcenter ist die Qualifizierung für dich vollständig kostenfrei. Der Bildungsgutschein übernimmt die gesamten Lehrgangsgebühren zu 100 % – ohne Eigenanteil.',
  },
  {
    q: 'Was ist der Unterschied zwischen der Fachkosmetikerin-Qualifizierung und dem Perfektionstraining?',
    a: 'Das Perfektionstraining (AVGS) richtet sich an erfahrene Fachkräfte mit Vorkenntnissen in PMU, Microblading oder Wimpernverlängerung, die ihre Technik gezielt vertiefen möchten. Die berufliche Qualifizierung zur Fachkosmetikerin ist dagegen ein umfassender Grundlagenlehrgang (640 UE) für Einsteiger:innen ohne Vorkenntnisse – gefördert über Bildungsgutschein (§81 SGB III), nicht über AVGS.',
  },
] : [];

const faqItems = [
  ...essenFaqItems,
  {
    q: `Sind die Kurse in ${stadtName} wirklich kostenlos?`,
    a: `Ja. Bei Bewilligung durch die Agentur für Arbeit werden die Perfektionstrainings zu 100 % über den Aktivierungs- und Vermittlungsgutschein (AVGS) finanziert. Für dich entstehen dabei keinerlei Kosten – weder Eigenanteil noch versteckte Gebühren. Die gesamte Förderung läuft direkt über die Agentur für Arbeit, sodass du dich voll auf deine fachliche Weiterentwicklung konzentrieren kannst.`,
  },
  {
    q: `Wer kann den AVGS-Gutschein in ${stadtName} beantragen?`,
    a: `Den AVGS können nicht nur arbeitssuchende Personen beantragen, sondern auch Angestellte und Selbstständige – und zwar unabhängig davon, ob aktuell Leistungen bezogen werden. Entscheidend ist, dass die Weiterbildung deine berufliche Situation verbessert oder sichert. Ein Termin bei der Agentur für Arbeit klärt, ob der Gutschein in deinem Fall bewilligt wird. Gerne beraten wir dich vorab, wie du den Antrag richtig stellst.`,
  },
  {
    q: `Wo finden die Schulungen in ${stadtName} statt?`,
    a: `Die Perfektionstrainings werden an einem der zertifizierten Schulungsstandorte im Großraum ${stadtName} durchgeführt. Alle Standorte sind anerkannt und für geförderte Weiterbildungen zugelassen. Die genauen Adressen findest du weiter oben auf dieser Seite – so kannst du den für dich am besten erreichbaren Standort auswählen.`,
  },
  {
    q: `Wer kann an den Kursen in ${stadtName} teilnehmen?`,
    a: `Die Perfektionstrainings richten sich an erfahrene Teilnehmerinnen aus der Beauty-Branche, die ihre Technik gezielt weiterentwickeln möchten. Es handelt sich ausdrücklich nicht um Einsteigerkurse – praktische Vorerfahrung im jeweiligen Fachbereich wird vorausgesetzt. Ob arbeitssuchend, angestellt oder selbstständig: Teilnehmen kann jede, die ihre bestehenden Fähigkeiten auf ein professionelles Niveau bringen will.`,
  },
  {
    q: `Welche Bereiche kann ich in ${stadtName} lernen?`,
    a: `Je nach Fachdozentin kannst du unterschiedliche Schwerpunkte wählen – darunter PMU Augenbrauen, PMU Lippen, Microblading, Wimpernverlängerung sowie Removal & Camouflage. Jede Dozentin bringt ihre eigene Spezialisierung mit, sodass du gezielt die Technik vertiefen kannst, die für deinen beruflichen Weg am wichtigsten ist. Die jeweiligen Schwerpunkte findest du direkt bei den Fachdozentinnen auf dieser Seite.`,
  },
  {
    q: `Wie melde ich mich für einen Kurs in ${stadtName} an?`,
    a: `Der Ablauf ist unkompliziert: Du wählst eine Fachdozentin aus, füllst das Formular auf ihrer Profilseite aus und wirst anschließend persönlich beraten. Danach wird gemeinsam mit dir der AVGS bei der Agentur für Arbeit beantragt. Sobald der Gutschein bewilligt ist, kann dein Perfektionstraining starten – kostenfrei und individuell auf dich abgestimmt.`,
  },
  {
    q: `Wie kann ich selbst staatlich geförderte Kurse als Fachdozentin unterrichten?`,
    a: `Du bist erfahrene Fachkraft im Bereich Permanent Make-up, Microblading oder Wimpernverlängerung und möchtest dein Wissen weitergeben? Als anerkannte Fachdozentin kannst du Teilnehmerinnen in staatlich geförderten Perfektionstrainings unterrichten – flexibel, an einem zertifizierten Schulungsstandort und ohne eigenen Schulungsraum. In einer kostenlosen Info-Veranstaltung erfährst du, wie der Einstieg funktioniert und welche Voraussetzungen du mitbringst. Mehr dazu erfährst du unter dein-beauty-kurs.de/fachdozentin-werden.`,
    aHtml: `Du bist erfahrene Fachkraft im Bereich Permanent Make-up, Microblading oder Wimpernverlängerung und möchtest dein Wissen weitergeben? Als anerkannte Fachdozentin kannst du Teilnehmerinnen in staatlich geförderten Perfektionstrainings unterrichten – flexibel, an einem zertifizierten Schulungsstandort und ohne eigenen Schulungsraum. In einer kostenlosen Info-Veranstaltung erfährst du, wie der Einstieg funktioniert und welche Voraussetzungen du mitbringst. Mehr dazu erfährst du unter <a href="https://dein-beauty-kurs.de/fachdozentin-werden" style="color:var(--gold);">dein-beauty-kurs.de/fachdozentin-werden</a>.`,
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a },
  })),
};
---

<SEOLayout
  title={seoTitle}
  description={seoDescription}
  canonical={canonical}
  schema={faqSchema}
>

<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%"   stop-color="#F9E29C"/>
      <stop offset="35%"  stop-color="#E6B84F"/>
      <stop offset="65%"  stop-color="#C8962E"/>
      <stop offset="100%" stop-color="#9A6E1E"/>
    </linearGradient>
  </defs>
</svg>

<style>
:root {
  --cream:    #FAF8F5;
  --cream-d:  #F3EEE8;
  --black:    #111111;
  --gold:     #C8962E;
  --gold-lt:  #D4AF7A;
  --gold-bg:  #FBF6EE;
  --rose:     #E8C4B8;
  --muted:    #555250;
  --border:   #E8E2D9;
  --white:    #FFFFFF;
  --serif:    'Cormorant Garamond', Georgia, 'Times New Roman', serif;
  --sans:     'Inter', system-ui, sans-serif;
  --radius:   3px;
  --shadow:   0 8px 40px rgba(184,150,90,.10);
}

*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }
html { scroll-behavior:smooth; }
body {
  background:var(--cream);
  color:var(--black);
  font-family:var(--sans);
  font-size:16px;
  font-weight:400;
  line-height:1.75;
  -webkit-font-smoothing:antialiased;
}

/* ─── LAYOUT ─────────────────────────── */
.w { max-width:1120px; margin:0 auto; padding:0 40px; }
@media(max-width:640px){ .w { padding:0 22px; } }

/* ─── BUTTONS ────────────────────────── */
.cta-gold {
  display:inline-block;
  background:var(--gold);
  color:var(--white);
  font-family:var(--sans);
  font-size:12px; font-weight:600;
  letter-spacing:.14em; text-transform:uppercase;
  padding:14px 34px;
  border:none; border-radius:var(--radius);
  text-decoration:none; cursor:pointer;
  transition:background .25s, transform .2s, box-shadow .25s;
  box-shadow:0 4px 18px rgba(184,150,90,.25);
}
.cta-gold:hover { background:var(--gold-lt); transform:translateY(-2px); box-shadow:0 8px 28px rgba(184,150,90,.35); }
.cta-white {
  display:inline-block;
  background:var(--white);
  color:var(--black);
  font-family:var(--sans);
  font-size:12px; font-weight:600;
  letter-spacing:.14em; text-transform:uppercase;
  padding:14px 34px;
  border-radius:var(--radius);
  text-decoration:none;
  transition:opacity .2s, transform .2s;
  box-shadow:0 4px 20px rgba(0,0,0,.15);
}
.cta-white:hover { opacity:.9; transform:translateY(-1px); }

/* ─── HERO ───────────────────────────── */
.hero {
  display:grid;
  grid-template-columns:55% 45%;
  gap:0;
  min-height:600px;
  padding:88px 0 64px;
  align-items:center;
}
@media(max-width:860px){
  .hero { grid-template-columns:1fr; padding:56px 0 40px; min-height:auto; }
}
.hero-left {
  display:flex; flex-direction:column;
  justify-content:center;
  padding-right:72px;
}
@media(max-width:860px){ .hero-left { padding-right:0; margin-bottom:36px; } }
.hero-h1 {
  font-family:var(--serif);
  font-size:clamp(40px, 5.5vw, 68px);
  font-weight:600; line-height:1.06;
  color:var(--black); margin-bottom:28px;
  letter-spacing:-.02em;
}
.hero-h1 em { font-style:italic; color:var(--gold); }
.hero-sub {
  font-size:17px; font-weight:400;
  line-height:1.85; color:var(--muted);
  margin-bottom:0; max-width:440px;
}
.hero-divider {
  width:48px; height:1px;
  background:var(--gold);
  margin:32px 0;
  opacity:.6;
}
.hero-trust-list {
  font-size:13px; font-weight:500;
  color:#8B6914; line-height:2.2;
}
.hero-right { display:flex; align-items:center; justify-content:center; }
.hero-city-frame {
  width:100%;
  aspect-ratio:3 / 2;
  border-radius:var(--radius);
  overflow:hidden;
  background:linear-gradient(135deg, var(--cream-d), #DDD4C8);
  display:flex; align-items:center; justify-content:center;
}
.hero-city-frame img {
  width:100%; height:100%;
  object-fit:cover; display:block;
}

/* ─── SECTIONS ───────────────────────── */
.section { padding:96px 0; border-bottom:1px solid var(--border); }
.section-header { margin-bottom:64px; }
.section-eye {
  display:inline-block;
  font-size:11px; font-weight:500;
  letter-spacing:.22em; text-transform:uppercase;
  color:var(--gold); margin-bottom:18px;
}
.section-title {
  font-family:var(--serif);
  font-size:clamp(36px, 5vw, 60px);
  font-weight:600; line-height:1.08;
  color:var(--black); margin-bottom:18px;
}
.section-title em { font-style:italic; color:var(--gold); }
.section-desc {
  font-size:16px; font-weight:400;
  line-height:1.85; color:var(--muted);
}

/* ─── INTRO ──────────────────────────── */
.intro-wrap { max-width:780px; margin-bottom:48px; }
@media(min-width:768px){ .intro-wrap { max-width:none; } }
.intro-text {
  font-size:17px; line-height:1.95;
  color:var(--muted); margin-bottom:0;
}
.intro-quelle {
  margin-top:16px;
  font-size:12px; color:rgba(85,82,80,.55);
  letter-spacing:.04em;
}

/* ─── STANDORT CARDS ─────────────────── */
.standort-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(280px,1fr));
  gap:24px;
}
.standort-card {
  background:var(--white);
  border:1px solid var(--border);
  border-radius:var(--radius);
  overflow:hidden;
  box-shadow:0 2px 16px rgba(0,0,0,.04);
  transition:box-shadow .3s, transform .25s;
}
.standort-card:hover { box-shadow:var(--shadow); transform:translateY(-4px); }
.standort-top { height:3px; background:linear-gradient(90deg, var(--gold), var(--rose)); }
.standort-body { padding:28px 24px 24px; display:flex; flex-direction:column; gap:10px; }
.standort-badge {
  align-self:flex-start;
  margin-top:6px;
  font-size:10px; font-weight:600;
  letter-spacing:.16em; text-transform:uppercase;
  color:var(--gold);
  border:1px solid var(--gold);
  border-radius:var(--radius); padding:4px 10px;
}
.standort-name {
  font-family:var(--serif);
  font-size:21px; font-weight:600;
  color:var(--black); line-height:1.2;
  display:block;
}
.standort-addr {
  font-size:14px; color:var(--muted);
  line-height:1.75; display:block;
}

/* ─── MASTERCLASS KARTEN ─────────────── */
.mc-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(260px,1fr));
  gap:20px;
}
.mc-card {
  display:flex; flex-direction:column;
  text-decoration:none; color:inherit;
  background:var(--white);
  border:1px solid var(--border);
  border-radius:var(--radius);
  overflow:hidden;
  box-shadow:0 2px 16px rgba(0,0,0,.04);
  transition:box-shadow .3s, transform .25s;
}
.mc-card:hover { transform:translateY(-4px); box-shadow:var(--shadow); }
.mc-card-img {
  width:100%; height:180px;
  object-fit:cover; display:block;
  border-radius:var(--radius) var(--radius) 0 0;
  transition:transform .5s ease;
}
.mc-card:hover .mc-card-img { transform:scale(1.04); }
.mc-card-img-wrap {
  width:100%; height:180px; overflow:hidden;
  border-radius:var(--radius) var(--radius) 0 0;
  background:var(--cream-d);
}
.mc-card-top { height:3px; background:linear-gradient(90deg, var(--gold), var(--rose)); flex-shrink:0; }
.mc-card-body {
  padding:20px 22px 20px;
  display:flex; flex-direction:column; gap:12px; flex:1;
}
@media(max-width:640px){
  .mc-card-img-wrap { height:158px; }
  .mc-card-img { height:158px; }
}
.mc-card-eye {
  font-size:10px; font-weight:600;
  letter-spacing:.16em; text-transform:uppercase;
  color:#7A5C2E;
  background:var(--gold-bg); border:1px solid #E8D9C4;
  border-radius:var(--radius); padding:4px 10px;
  align-self:flex-start;
}
.mc-card-name {
  font-family:var(--serif);
  font-size:20px; font-weight:600;
  color:var(--black); line-height:1.25;
}
.mc-card-link {
  font-size:12px; font-weight:600;
  letter-spacing:.1em; text-transform:uppercase;
  color:var(--gold); margin-top:auto; padding-top:4px;
}
.mc-card:hover .mc-card-link { color:var(--gold-lt); }

/* ─── DOZENTINNEN GRID ───────────────── */
.doz-grid {
  display:grid;
  grid-template-columns:repeat(3, 1fr);
  gap:28px;
}
@media(max-width:767px){ .doz-grid { grid-template-columns:1fr; gap:16px; } }
.doz-card {
  text-decoration:none; color:inherit;
  display:flex; flex-direction:column;
  background:var(--white);
  border:1px solid var(--border);
  border-radius:var(--radius);
  overflow:hidden;
  box-shadow:0 2px 16px rgba(0,0,0,.04);
  transition:box-shadow .3s, transform .25s;
}
.doz-card:hover { transform:translateY(-5px); box-shadow:var(--shadow); }
.doz-img-wrap {
  width:100%; aspect-ratio:1;
  overflow:hidden;
  background:var(--cream-d);
}
.doz-img-wrap img {
  width:100%; height:100%;
  object-fit:cover; display:block;
  transition:transform .5s ease;
}
.doz-card:hover .doz-img-wrap img { transform:scale(1.05); }
.doz-img-ph {
  width:100%; height:100%;
  display:flex; align-items:center; justify-content:center;
  font-size:36px; color:rgba(184,150,90,.2);
}
/* ─── FAQ ────────────────────────────── */
.faq-section { padding:100px 0; border-bottom:1px solid var(--border); margin-top:37px; }
@media(max-width:767px){ .faq-section { margin-top:21px; } }
.faq-grid {
  display:grid;
  grid-template-columns:380px 1fr;
  gap:80px; align-items:start;
}
@media(max-width:900px){ .faq-grid { grid-template-columns:1fr; gap:48px; } }
.faq-sticky { position:sticky; top:24px; }
@media(max-width:900px){ .faq-sticky { position:static; } }
.faq-sticky-eye {
  font-size:11px; font-weight:500; letter-spacing:.22em;
  text-transform:uppercase; color:var(--gold); display:block; margin-bottom:18px;
}
.faq-sticky-title {
  font-family:var(--serif);
  font-size:clamp(28px,4vw,44px);
  font-weight:600; line-height:1.15; color:var(--black); margin-bottom:20px;
}
.faq-sticky-title em { font-style:italic; color:var(--gold); }
.faq-sticky-desc { font-size:15px; font-weight:400; line-height:1.8; color:var(--muted); }
.faq-list { display:flex; flex-direction:column; gap:0; }
.faq-item { border-bottom:1px solid var(--border); padding:0; }
.faq-item:first-child { border-top:1px solid var(--border); }
.faq-summary {
  display:flex; justify-content:space-between; align-items:center;
  padding:26px 0; cursor:pointer; gap:20px;
  list-style:none; font-family:var(--sans);
  font-size:clamp(15px,2vw,18px); font-weight:500; color:var(--black);
  line-height:1.3;
}
.faq-summary::-webkit-details-marker { display:none; }
.faq-summary::marker { display:none; }
.faq-icon {
  flex-shrink:0; width:28px; height:28px;
  border:1px solid var(--border); border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:16px; color:var(--gold); font-weight:300;
  transition:transform .25s, background .2s;
}
details[open] .faq-icon { transform:rotate(45deg); background:var(--gold-bg); }
.faq-answer {
  padding:0 40px 28px 0;
  font-size:15px; font-weight:400; line-height:1.9; color:var(--muted);
}

/* ─── ESSEN: PERFEKTIONSTRAINING TRACK NOTE ─ */
.pt-track-note {
  margin-bottom:32px;
  padding:16px 20px;
  background:var(--gold-bg); border:1px solid #E8D9C4; border-radius:var(--radius);
}
.pt-track-badge {
  display:inline-block;
  font-size:10px; font-weight:600;
  letter-spacing:.16em; text-transform:uppercase;
  color:var(--gold); border:1px solid var(--gold);
  border-radius:var(--radius); padding:4px 10px;
  margin-bottom:10px;
}
.pt-track-desc { font-size:14px; color:var(--muted); line-height:1.7; margin-bottom:8px; }
.pt-track-route { font-size:13px; color:var(--muted); }
.pt-track-route a { color:var(--gold); text-decoration:underline; text-underline-offset:2px; }

/* ─── ESSEN: FACHKOSMETIKERIN SEKTION ─ */
.fachkos-badge {
  display:inline-block;
  font-size:10px; font-weight:600;
  letter-spacing:.16em; text-transform:uppercase;
  color:#1A5E3A; background:#E6F4EC; border:1px solid #A8D5B5;
  border-radius:var(--radius); padding:5px 12px;
  margin-bottom:12px;
}
.fachkos-eye {
  font-size:13px; font-weight:500;
  color:var(--muted); margin-bottom:16px; display:block;
}
.fachkos-inner {
  display:grid; grid-template-columns:280px 1fr; gap:48px; align-items:start;
}
@media(max-width:767px){ .fachkos-inner { grid-template-columns:1fr; gap:28px; } }
.fachkos-img-wrap {
  border-radius:var(--radius); overflow:hidden;
  aspect-ratio:1; background:var(--cream-d);
}
.fachkos-img-wrap img { width:100%; height:100%; object-fit:cover; display:block; }
.fachkos-list {
  list-style:none; display:flex; flex-direction:column; gap:10px;
  margin-bottom:28px;
}
.fachkos-list li {
  font-size:15px; color:var(--muted); line-height:1.6;
  padding-left:20px; position:relative;
}
.fachkos-list li::before {
  content:'◆'; position:absolute; left:0;
  color:var(--gold); font-size:9px; top:5px;
}
.fachkos-routing {
  margin-top:16px; font-size:13px; color:var(--muted);
}
.fachkos-routing a { color:var(--gold); text-decoration:underline; text-underline-offset:2px; }

/* ─── FINAL CTA ──────────────────────── */
.final-cta {
  padding:128px 0;
  text-align:center;
  background:var(--black);
  position:relative; overflow:hidden;
}
.final-cta::before {
  content:'';
  position:absolute; inset:0;
  background:
    radial-gradient(ellipse at 20% 60%, rgba(184,150,90,.14) 0%, transparent 55%),
    radial-gradient(ellipse at 80% 25%, rgba(232,196,184,.07) 0%, transparent 55%);
  pointer-events:none;
}
.final-cta-eye {
  font-size:11px; font-weight:500; letter-spacing:.25em; text-transform:uppercase;
  color:var(--gold); display:block; margin-bottom:24px; position:relative;
}
.final-cta-h2 {
  font-family:var(--serif);
  font-size:clamp(38px,6vw,72px);
  font-weight:600; line-height:1.08;
  color:var(--white); margin-bottom:22px; position:relative;
}
.final-cta-h2 em { font-style:italic; color:var(--gold-lt); }
.final-cta-sub {
  font-size:15px; font-weight:300; color:rgba(255,255,255,.45);
  margin:0 auto 52px; max-width:460px; line-height:1.85; position:relative;
}

</style>


<main>

<Breadcrumbs trail={[
  { label: 'Startseite', href: '/' },
  { label: stadtName },
]} />

<!-- ══════════════════════════════════
     HERO
══════════════════════════════════ -->
<div class="w">
  <div class="hero">

    <div class="hero-left">
      <h1 class="hero-h1">
        Zertifizierte<br />
        Kosmetikschulen<br />
        in <em>{stadtName}</em>
      </h1>

      <p class="hero-sub">
        Staatlich geförderte Perfektionstrainings –
        100&thinsp;% kostenfrei bei Bewilligung
        über die Agentur für Arbeit.
      </p>

      <div class="hero-divider"></div>

      <div class="hero-trust-list">
        ◆ 100&thinsp;% kostenfrei bei Bewilligung<br />
        ◆ AZAV-zertifizierte Standorte<br />
        ◆ Anerkannte Fachdozentinnen
      </div>
    </div>

    <div class="hero-right">
      <div class="hero-city-frame">
        {hasCityImage
          ? <img
              src={cityImageRel}
              alt={`Zertifizierte Kosmetikschulen in ${stadtName}`}
              width="660" height="440"
              loading="eager"
              decoding="async"
            />
          : <span style="font-family:var(--serif);font-size:56px;color:rgba(184,150,90,.15);">✦</span>
        }
      </div>
    </div>

  </div>
</div>


<!-- ══════════════════════════════════
     STANDORTE (inkl. Intro-Text)
══════════════════════════════════ -->
{hasStandorte && (
  <section class="section" style="border-bottom:none;padding-bottom:0;padding-top:58px;">
    <div class="w">
      <div class="section-header" style="text-align:left;margin-bottom:28px;">
        <span class="section-eye">Schulungsstandorte</span>
        <h2 class="section-title">
          Zertifizierte Schulungsstandorte in <em>{stadtName}</em>
        </h2>
      </div>

      <div class="intro-wrap">
        <p class="intro-text">{introText}</p>
        {introZahlSatz && introQuelle && <p class="intro-quelle">Quelle: {introQuelle}</p>}
      </div>

      <div class="standort-grid">
        {standorte.map(s => (
          <div class="standort-card">
            <div class="standort-top"></div>
            <div class="standort-body">
              <strong class="standort-name">{s.name}</strong>
              <span class="standort-addr">
                {s.strasse && <>{s.strasse}<br /></>}
                {s.plz} {s.ort}
              </span>
              <span class="standort-badge">Zertifizierter Schulungsstandort</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}


<!-- ══════════════════════════════════
     MASTERCLASSES
══════════════════════════════════ -->
{cityServices.length > 0 && (
  <section class="section" style="border-bottom:none;padding-bottom:0;">
    <div class="w">
      <div class="section-header" style="text-align:left;margin-bottom:40px;">
        <span class="section-eye">Staatlich gefördert</span>
        <h2 class="section-title">
          MasterClasses in <em>{stadtName}</em>
        </h2>
        <p class="section-desc">
          Diese Perfektionstrainings werden aktuell in {stadtName} angeboten –
          100&thinsp;% förderfähig über AVGS-Gutschein.
        </p>
      </div>
      {citySlug === 'essen' && (
        <div class="pt-track-note">
          <span class="pt-track-badge">Für erfahrene Fachkräfte mit Vorkenntnissen · AVGS</span>
          <p class="pt-track-desc">Diese Perfektionstrainings setzen praktische Vorerfahrung in PMU, Microblading oder Wimpernverlängerung voraus. Förderung über AVGS (Aktivierungs- und Vermittlungsgutschein der Agentur für Arbeit).</p>
          <p class="pt-track-route">Einsteiger:in / arbeitssuchend ohne Vorkenntnisse? → <a href="#fachkosmetikerin">Zur beruflichen Qualifizierung zur Fachkosmetikerin</a></p>
        </div>
      )}
      <div class="mc-grid">
        {cityServices.map(s => (
          <a href={`/${citySlug}/${s.slug}/`} class="mc-card">
            <div class="mc-card-img-wrap">
              {s.imgSrc && (
                <img
                  src={s.imgSrc}
                  alt={s.displayName}
                  class="mc-card-img"
                  loading="lazy"
                  decoding="async"
                  width="400" height="180"
                />
              )}
            </div>
            <div class="mc-card-top"></div>
            <div class="mc-card-body">
              <span class="mc-card-eye">AVGS-gefördert</span>
              <span class="mc-card-name">{s.displayName}</span>
              <span class="mc-card-link">Modul ansehen →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}


<!-- ══════════════════════════════════
     FACHDOZENTINNEN
══════════════════════════════════ -->
{hasDozentinnen && (
  <section class="section" id="dozentinnen" style="border-bottom:none;padding-bottom:0;">
    <div class="w">
      <div class="section-header" style="text-align:left;">
        <span class="section-eye">Fachdozentinnen</span>
        <h2 class="section-title">
          Unsere Fachdozentinnen in <em>{stadtName}</em>
        </h2>
        <p class="section-desc">
          Genau dafür gibt es unsere staatlich geförderten Perfektionstrainings:
          anerkannt, zertifiziert und über den AVGS der Agentur für Arbeit zu
          100 % förderbar – im persönlichen Einzelunterricht bei folgenden
          Fachdozentinnen in {stadtName}:
        </p>
      </div>

      <div class="doz-grid">
        {dozentinnenWithImg.map(d => (
          <a href={`/dozentinnen/${d.slug}/`} class="doz-card">
            <div class="doz-img-wrap">
              {d.profileImg
                ? <img
                    src={d.profileImg}
                    alt={`${d.first_name} ${d.last_name}`}
                    width="240" height="240"
                    loading="lazy"
                  />
                : <div class="doz-img-ph">✦</div>
              }
            </div>
            <DozentinInfoBox
              name={`${d.first_name} ${d.last_name}`}
              standort={CITY_DISPLAY[d.slug] ?? d.cityName}
              fachgebiete={d.serviceNames}
            />
          </a>
        ))}
      </div>
    </div>
  </section>
)}


<!-- ══════════════════════════════════
     ESSEN: FACHKOSMETIKERIN-QUALIFIZIERUNG
══════════════════════════════════ -->
{citySlug === 'essen' && (
  <section class="section" id="fachkosmetikerin" style="border-bottom:none;padding-bottom:0;">
    <div class="w">
      <div class="section-header" style="text-align:left;margin-bottom:32px;">
        <span class="fachkos-badge">Für Einsteiger:innen · Bildungsgutschein</span>
        <span class="fachkos-eye">Geförderte berufliche Weiterbildung nach §81 SGB III</span>
        <h2 class="section-title">
          Berufliche Qualifizierung zur <em>Fachkosmetikerin</em>
        </h2>
      </div>
      <div class="fachkos-inner">
        <div class="fachkos-img-wrap">
          <img
            src="/images/dozentinnen/christina-dentsa/christina-dentsa.webp"
            alt="Christina Dentsa – Christina Beauty School Essen"
            width="400" height="400"
            loading="lazy" decoding="async"
          />
        </div>
        <div>
          <ul class="fachkos-list">
            <li>640 UE (Vollzeit, 4 Module à 160 UE)</li>
            <li>Hybrid (Präsenz + Live-Online)</li>
            <li>Beginn: 07.09.2026</li>
            <li>Zielgruppe: Arbeitssuchende, auch ohne Vorkenntnisse</li>
            <li>100 % förderfähig über Bildungsgutschein (Agentur für Arbeit / Jobcenter)</li>
            <li>Abschluss: trägerinternes Zertifikat „Fachkosmetikerin"</li>
            <li>Träger (AZAV): Christina Beauty School (Christina Dentsa)</li>
          </ul>
          <a
            href="https://form.jotform.com/261074759721462"
            class="cta-gold"
            target="_blank" rel="noopener"
          >Infos &amp; Anmeldung →</a>
          <p class="fachkos-routing">
            Erfahrene Fachkraft mit PMU- / Microblading- / Wimpern-Vorkenntnissen?
            → <a href="#dozentinnen">Zu den AVGS-Perfektionstrainings</a>
          </p>
        </div>
      </div>
    </div>
  </section>
)}


<!-- ══════════════════════════════════
     FAQ
══════════════════════════════════ -->
<section class="faq-section" id="faq">
  <div class="w">
    <div class="faq-grid">

      <div class="faq-sticky">
        <span class="faq-sticky-eye">Häufige Fragen</span>
        <h2 class="faq-sticky-title">
          Alles, was du über<br />
          <em>deine Weiterbildung</em><br />
          wissen möchtest.
        </h2>
        <p class="faq-sticky-desc">
          Du hast Fragen zu Kosten, Voraussetzungen oder dem Ablauf
          der Kurse in {stadtName}? Hier findest du die wichtigsten Antworten.
        </p>
      </div>

      <div class="faq-list">
        {faqItems.map(item => (
          <details class="faq-item">
            <summary class="faq-summary">
              {item.q}
              <span class="faq-icon">+</span>
            </summary>
            <div class="faq-answer">
              {item.aHtml ? <p set:html={item.aHtml} /> : <p>{item.a}</p>}
            </div>
          </details>
        ))}
      </div>

    </div>
  </div>
</section>


<!-- ══════════════════════════════════
     FINAL CTA
══════════════════════════════════ -->
<section class="final-cta">
  <div class="w">
    <span class="final-cta-eye">Start in deine Weiterbildung</span>
    <h2 class="final-cta-h2">
      Bereit für dein<br />
      <em>nächstes Level?</em>
    </h2>
    <p class="final-cta-sub">
      Wähle deine Dozentin aus und starte dein AVGS-gefördertes
      Perfektionstraining in {stadtName} –
      kostenfrei bei Bewilligung.
    </p>
    <a href="#dozentinnen" class="cta-white">Dozentinnen entdecken →</a>
  </div>
</section>

</main>


<SiteFooter variant="full" activeCity={citySlug} />

</SEOLayout>
