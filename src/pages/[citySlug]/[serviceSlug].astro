---
import SEOLayout from '../../layouts/SEOLayout.astro';
import { supabase } from '../../lib/supabase';

export const prerender = true;

export async function getStaticPaths() {
  console.log('[city-service getStaticPaths] Start');

  // Query directly from dozentinnen with active=true enforced at DB level.
  // Avoids 3-level deep nesting (cities→dozentinnen→dozentin_services→services)
  // which can silently drop rows due to PostgREST embedded-resource limits.
  const { data: dozentinnen, error } = await supabase
    .from('dozentinnen')
    .select(`
      slug,
      first_name,
      last_name,
      rating,
      review_count,
      avgs_certified,
      cities(slug, name),
      dozentin_services(
        services(slug, name, category, avgs_eligible, description_template)
      )
    `)
    .eq('active', true);

  if (error || !dozentinnen) {
    console.error('[city-service getStaticPaths] Fehler:', error);
    return [];
  }

  console.log(`[city-service] ${dozentinnen?.length ?? 0} Dozentinnen geladen`);

  const pageMap = new Map();

  for (const dozentin of dozentinnen) {
    // cities is many-to-one: Supabase returns object, guard for array just in case
    const city = Array.isArray(dozentin.cities)
      ? dozentin.cities[0]
      : dozentin.cities;
    if (!city?.slug) continue;

    const dsRows = Array.isArray(dozentin.dozentin_services)
      ? dozentin.dozentin_services
      : [];

    for (const ds of dsRows) {
      // services is many-to-one: Supabase returns object, guard for array just in case
      const service = Array.isArray(ds?.services)
        ? ds.services[0]
        : ds?.services;
      if (!service?.slug) continue;

      const key = `${city.slug}__${service.slug}`;

      if (!pageMap.has(key)) {
        pageMap.set(key, {
          city: { slug: city.slug, name: city.name },
          service,
          dozentinnen: []
        });
      }

      pageMap.get(key).dozentinnen.push({
        slug: dozentin.slug,
        first_name: dozentin.first_name,
        last_name: dozentin.last_name,
        rating: dozentin.rating,
        review_count: dozentin.review_count,
        avgs_certified: dozentin.avgs_certified
      });
    }
  }

  const paths = Array.from(pageMap.values()).map(({ city, service, dozentinnen }) => ({
    params: {
      citySlug: city.slug,
      serviceSlug: service.slug
    },
    props: { city, service, dozentinnen }
  }));

  console.log(`[city-service] ${paths.length} Seiten werden gebaut`);
  return paths;
}

const { city, service, dozentinnen } = Astro.props;

const description = (service.description_template ?? '')
  .replace('{city}', city.name);

const seo = {
  title: `${service.name} ${city.name} | 1:1 Einzelcoaching – AVGS gefördert`,
  description: description || `${service.name} Einzelcoaching in ${city.name}. AVGS gefördert.`,
  canonical: `https://dein-beauty-kurs.de/${city.slug}/${service.slug}`
};

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `${service.name} in ${city.name}`,
  "url": seo.canonical,
  "numberOfItems": dozentinnen.length,
  "itemListElement": dozentinnen.map((d, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://dein-beauty-kurs.de/dozentinnen/${d.slug}`,
    "name": `${d.first_name} ${d.last_name}`
  }))
};
---

<SEOLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  schema={schema}
>
  <section>
    <h1>{service.name} in {city.name}</h1>
    <p>1:1 Einzelcoaching – für fortgeschrittene Teilnehmer</p>
    {service.avgs_eligible && (
      <p>✅ Förderbar über Arbeitsagentur (AVGS) – 100% kostenlos</p>
    )}
  </section>

  {description && (
    <section>
      <p>{description}</p>
    </section>
  )}

  <section>
    <h2>
      {dozentinnen.length === 1
        ? `Deine Dozentin für ${service.name} in ${city.name}`
        : `${dozentinnen.length} Dozentinnen für ${service.name} in ${city.name}`}
    </h2>

    {dozentinnen.map(d => (
      <article>
        <h3>
          <a href={`/dozentinnen/${d.slug}`}>
            {d.first_name} {d.last_name}
          </a>
        </h3>

        {d.review_count > 0 && (
          <p>⭐ {d.rating}/5 ({d.review_count} Bewertungen)</p>
        )}

        {d.avgs_certified && <p>✅ AVGS zertifiziert</p>}

        <a href={`/dozentinnen/${d.slug}`}>
          Profil & Unterlagen →
        </a>
      </article>
    ))}
  </section>

  <section>
    <a href={`/${city.slug}`}>← Alle Kurse in {city.name}</a>
  </section>
</SEOLayout>