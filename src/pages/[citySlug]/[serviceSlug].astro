---
import SEOLayout from '../../layouts/SEOLayout.astro';
import DozentinInfoBox from '../../components/DozentinInfoBox.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { CITY_DISPLAY } from '../../data/location-overrides';
import { supabase } from '../../lib/supabase';
import fs from 'node:fs';
import path from 'node:path';

export const prerender = true;

export async function getStaticPaths() {
  console.log('[city-service getStaticPaths] Start');

  const { data: dozentinnen, error } = await supabase
    .from('dozentinnen')
    .select(`
      slug,
      first_name,
      last_name,
      rating,
      review_count,
      avgs_certified,
      cities(slug, name),
      dozentin_services(
        services(slug, name, category, avgs_eligible, description_template)
      )
    `)
    .eq('active', true);

  if (error || !dozentinnen) {
    console.error('[city-service getStaticPaths] Fehler:', error);
    return [];
  }

  console.log(`[city-service] ${dozentinnen?.length ?? 0} Dozentinnen geladen`);

  const pageMap = new Map();

  for (const dozentin of dozentinnen) {
    const city = Array.isArray(dozentin.cities)
      ? dozentin.cities[0]
      : dozentin.cities;
    if (!city?.slug) continue;

    const dsRows = Array.isArray(dozentin.dozentin_services)
      ? dozentin.dozentin_services
      : [];

    for (const ds of dsRows) {
      const service = Array.isArray(ds?.services)
        ? ds.services[0]
        : ds?.services;
      if (!service?.slug) continue;

      const key = `${city.slug}__${service.slug}`;

      if (!pageMap.has(key)) {
        pageMap.set(key, {
          city: { slug: city.slug, name: city.name },
          service,
          dozentinnen: []
        });
      }

      pageMap.get(key).dozentinnen.push({
        slug:           dozentin.slug,
        first_name:     dozentin.first_name,
        last_name:      dozentin.last_name,
        rating:         dozentin.rating,
        review_count:   dozentin.review_count,
        avgs_certified: dozentin.avgs_certified,
      });
    }
  }

  const paths = Array.from(pageMap.values()).map(({ city, service, dozentinnen }) => ({
    params: { citySlug: city.slug, serviceSlug: service.slug },
    props:  { city, service, dozentinnen }
  }));

  console.log(`[city-service] ${paths.length} Seiten werden gebaut`);
  return paths;
}

const { city, service, dozentinnen } = Astro.props;

// ── Modul-Bild ────────────────────────────────────────────────────────────────
const MODULE_IMAGES: Record<string, string> = {
  'powderbrows-ombrebrows-masterclass': '/images/Modul-Bilder/augenbrauen.webp',
  'velvet-lips-lipstick-masterclass':   '/images/Modul-Bilder/lippen.webp',
  'microblading-masterclass':           '/images/Modul-Bilder/microblading.webp',
  'wimpernverlaengerung-masterclass':   '/images/Modul-Bilder/wimpern.webp',
  'camouflage-removal-masterclass':     '/images/Modul-Bilder/entfernung.webp',
};
const moduleImageRel = MODULE_IMAGES[service.slug] ?? null;
const hasModuleImage = moduleImageRel
  ? fs.existsSync(path.join(process.cwd(), 'public', moduleImageRel))
  : false;

// ── Profilbilder der Dozentinnen (build-time) ─────────────────────────────────
const dozentinnenWithImg = (dozentinnen as any[]).map(d => {
  const localSlug = d.slug.replace(new RegExp(`-${city.slug}$`), '');
  const rel       = `/images/dozentinnen/${localSlug}/${localSlug}.webp`;
  const hasImg    = fs.existsSync(path.join(process.cwd(), 'public', rel));
  return { ...d, profileImg: hasImg ? rel : null };
});

// ── FAQ ───────────────────────────────────────────────────────────────────────
const faqItems = [
  {
    q: `Ist ${service.name} in ${city.name} wirklich kostenlos?`,
    a: `Ja. Bei Bewilligung durch die Agentur für Arbeit wird das Perfektionstraining zu 100 % über den Aktivierungs- und Vermittlungsgutschein (AVGS) finanziert. Für dich entstehen dabei keinerlei Kosten – weder Eigenanteil noch versteckte Gebühren.`,
  },
  {
    q: `Wer kann den AVGS-Gutschein für dieses Modul beantragen?`,
    a: `Den AVGS können nicht nur arbeitssuchende Personen beantragen, sondern auch Angestellte und Selbstständige – unabhängig davon, ob aktuell Leistungen bezogen werden. Entscheidend ist, dass die Weiterbildung deine berufliche Situation verbessert oder sichert. Ein Termin bei der Agentur für Arbeit klärt, ob der Gutschein in deinem Fall bewilligt wird.`,
  },
  {
    q: `[PLATZHALTER] Welche Inhalte umfasst ${service.name}?`,
    a: `[PLATZHALTER – Modul-spezifische Antwort zu Kursinhalten, Techniken und Ablauf wird hier ergänzt.]`,
  },
  {
    q: `Welche Voraussetzungen brauche ich für die Teilnahme?`,
    a: `Das Perfektionstraining richtet sich an erfahrene Teilnehmerinnen aus der Beauty-Branche, die ihre Technik gezielt weiterentwickeln möchten. Es handelt sich ausdrücklich nicht um einen Einsteigerkurs – praktische Vorerfahrung im jeweiligen Fachbereich wird vorausgesetzt.`,
  },
  {
    q: `Wie melde ich mich für ${service.name} in ${city.name} an?`,
    a: `Du wählst eine Fachdozentin aus, füllst das Formular auf ihrer Profilseite aus und wirst persönlich beraten. Danach wird gemeinsam mit dir der AVGS bei der Agentur für Arbeit beantragt. Sobald der Gutschein bewilligt ist, kann dein Perfektionstraining starten – kostenfrei und individuell auf dich abgestimmt.`,
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a },
  })),
};

// ── SEO ───────────────────────────────────────────────────────────────────────
const seoTitle       = `${service.name} in ${city.name} | AVGS gefördert – BeautyBusiness360`;
const seoDescription = (service.description_template ?? '').replace('{city}', city.name)
                     || `${service.name} in ${city.name}. Staatlich gefördert über AVGS – 100 % kostenfrei bei Bewilligung.`;
const canonical      = `https://dein-beauty-kurs.de/${city.slug}/${service.slug}/`;
---

<SEOLayout title={seoTitle} description={seoDescription}
           canonical={canonical} schema={faqSchema}>

<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%"   stop-color="#F9E29C"/>
      <stop offset="35%"  stop-color="#E6B84F"/>
      <stop offset="65%"  stop-color="#C8962E"/>
      <stop offset="100%" stop-color="#9A6E1E"/>
    </linearGradient>
  </defs>
</svg>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

<style>
:root {
  --cream:    #FAF8F5;
  --cream-d:  #F3EEE8;
  --black:    #111111;
  --gold:     #C8962E;
  --gold-lt:  #D4AF7A;
  --gold-bg:  #FBF6EE;
  --rose:     #E8C4B8;
  --muted:    #555250;
  --border:   #E8E2D9;
  --white:    #FFFFFF;
  --serif:    'Cormorant Garamond', Georgia, 'Times New Roman', serif;
  --sans:     'Inter', system-ui, sans-serif;
  --radius:   3px;
  --shadow:   0 8px 40px rgba(184,150,90,.10);
}

*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }
html { scroll-behavior:smooth; }
body {
  background:var(--cream);
  color:var(--black);
  font-family:var(--sans);
  font-size:16px;
  font-weight:400;
  line-height:1.75;
  -webkit-font-smoothing:antialiased;
}

/* ─── LAYOUT ─────────────────────────── */
.w { max-width:1120px; margin:0 auto; padding:0 40px; }
@media(max-width:640px){ .w { padding:0 22px; } }

/* ─── BUTTONS ────────────────────────── */
.cta-gold {
  display:inline-block;
  background:var(--gold);
  color:var(--white);
  font-family:var(--sans);
  font-size:12px; font-weight:600;
  letter-spacing:.14em; text-transform:uppercase;
  padding:14px 34px;
  border:none; border-radius:var(--radius);
  text-decoration:none; cursor:pointer;
  transition:background .25s, transform .2s, box-shadow .25s;
  box-shadow:0 4px 18px rgba(184,150,90,.25);
}
.cta-gold:hover { background:var(--gold-lt); transform:translateY(-2px); box-shadow:0 8px 28px rgba(184,150,90,.35); }
.cta-white {
  display:inline-block;
  background:var(--white);
  color:var(--black);
  font-family:var(--sans);
  font-size:12px; font-weight:600;
  letter-spacing:.14em; text-transform:uppercase;
  padding:14px 34px;
  border-radius:var(--radius);
  text-decoration:none;
  transition:opacity .2s, transform .2s;
  box-shadow:0 4px 20px rgba(0,0,0,.15);
}
.cta-white:hover { opacity:.9; transform:translateY(-1px); }

/* ─── HERO ───────────────────────────── */
.hero {
  display:grid;
  grid-template-columns:55% 45%;
  gap:0;
  min-height:580px;
  padding:88px 0 64px;
  align-items:center;
}
@media(max-width:860px){
  .hero { grid-template-columns:1fr; padding:52px 0 40px; min-height:auto; }
}
.hero-left {
  display:flex; flex-direction:column;
  justify-content:center;
  padding-right:72px;
}
@media(max-width:860px){ .hero-left { padding-right:0; margin-bottom:36px; } }
.hero-h1 {
  font-family:var(--serif);
  font-size:clamp(36px, 5vw, 60px);
  font-weight:600; line-height:1.08;
  color:var(--black); margin-bottom:24px;
  letter-spacing:-.02em;
}
.hero-h1 em { font-style:italic; color:var(--gold); }
.hero-sub {
  font-size:17px; font-weight:400;
  line-height:1.85; color:var(--muted);
  margin-bottom:0; max-width:440px;
}
.hero-divider {
  width:48px; height:1px;
  background:var(--gold);
  margin:28px 0;
  opacity:.6;
}
.hero-trust-list {
  font-size:13px; font-weight:500;
  color:#8B6914; line-height:2.2;
}
.hero-scroll-link {
  display:inline-block; margin-top:24px;
  font-size:13px; font-weight:500;
  color:var(--gold); text-decoration:none;
  letter-spacing:.04em;
  transition:opacity .2s, transform .2s;
}
.hero-scroll-link:hover { opacity:.75; transform:translateY(2px); }
.hero-right { display:flex; align-items:center; justify-content:center; }
.hero-img-frame {
  width:100%;
  aspect-ratio:1 / 1;
  border-radius:var(--radius);
  overflow:hidden;
  background:linear-gradient(135deg, var(--cream-d), #DDD4C8);
  display:flex; align-items:center; justify-content:center;
}
.hero-img-frame img {
  width:100%; height:100%;
  object-fit:cover; display:block;
}

/* ─── SECTIONS ───────────────────────── */
.section { padding:96px 0; border-bottom:1px solid var(--border); }
.section-header { margin-bottom:56px; }
.section-eye {
  display:inline-block;
  font-size:11px; font-weight:500;
  letter-spacing:.22em; text-transform:uppercase;
  color:var(--gold); margin-bottom:18px;
}
.section-title {
  font-family:var(--serif);
  font-size:clamp(34px, 4.5vw, 56px);
  font-weight:600; line-height:1.1;
  color:var(--black); margin-bottom:18px;
}
.section-title em { font-style:italic; color:var(--gold); }
.section-desc {
  font-size:16px; font-weight:400;
  line-height:1.85; color:var(--muted);
  max-width:680px;
}

/* ─── CAROUSEL / GALERIE ─────────────── */
.gallery-section { padding:80px 0; border-bottom:1px solid var(--border); }
.carousel-wrap { position:relative; }
.carousel-track {
  display:flex; gap:16px;
  overflow-x:auto; scroll-snap-type:x mandatory; scroll-behavior:smooth;
  scrollbar-width:none;
}
.carousel-track::-webkit-scrollbar { display:none; }
.carousel-slide {
  flex:0 0 calc((100% - 32px) / 3);
  scroll-snap-align:start; border-radius:var(--radius); overflow:hidden;
}
.carousel-slide img {
  width:100%; aspect-ratio:1; object-fit:cover; display:block;
  transition:transform .6s ease;
}
.carousel-slide:hover img { transform:scale(1.05); }
.carousel-ph {
  aspect-ratio:1;
  background:linear-gradient(135deg,var(--cream-d),#DDD4C8);
  display:flex; align-items:center; justify-content:center;
  font-size:24px; color:rgba(184,150,90,.25);
}
.carousel-btn {
  position:absolute; top:50%; transform:translateY(-50%);
  width:40px; height:40px; border-radius:50%;
  background:var(--white); border:1px solid var(--border);
  box-shadow:0 2px 8px rgba(0,0,0,.1);
  cursor:pointer; font-size:18px; line-height:1;
  display:flex; align-items:center; justify-content:center;
  z-index:2; transition:box-shadow .2s;
}
.carousel-btn:hover { box-shadow:0 4px 16px rgba(0,0,0,.15); }
.carousel-prev { left:-20px; }
.carousel-next { right:-20px; }
.carousel-dots {
  display:none; justify-content:center; gap:8px; margin-top:16px;
}
.carousel-dot {
  width:8px; height:8px; border-radius:50%;
  border:1.5px solid var(--muted); background:transparent;
  transition:background .2s, border-color .2s; cursor:pointer; padding:0;
}
.carousel-dot.active { background:var(--gold); border-color:var(--gold); }
@media(max-width:640px){
  .carousel-slide { flex:0 0 100%; }
  .carousel-btn { display:none; }
  .carousel-dots { display:flex; }
}

/* ─── DOZENTINNEN GRID ───────────────── */
.doz-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(280px,1fr));
  gap:28px;
}
.doz-card {
  text-decoration:none; color:inherit;
  display:flex; flex-direction:column;
  background:var(--white);
  border:1px solid var(--border);
  border-radius:var(--radius);
  overflow:hidden;
  box-shadow:0 2px 16px rgba(0,0,0,.04);
  transition:box-shadow .3s, transform .25s;
}
.doz-card:hover { transform:translateY(-5px); box-shadow:var(--shadow); }
.doz-img-wrap {
  width:100%; aspect-ratio:1;
  overflow:hidden;
  background:var(--cream-d);
}
.doz-img-wrap img {
  width:100%; height:100%;
  object-fit:cover; display:block;
  transition:transform .5s ease;
}
.doz-card:hover .doz-img-wrap img { transform:scale(1.05); }
.doz-img-ph {
  width:100%; height:100%;
  display:flex; align-items:center; justify-content:center;
  font-size:36px; color:rgba(184,150,90,.2);
}

/* ─── FAQ ────────────────────────────── */
.faq-section { padding:100px 0; border-bottom:1px solid var(--border); margin-top:37px; }
@media(max-width:767px){ .faq-section { margin-top:21px; } }
.faq-grid {
  display:grid;
  grid-template-columns:380px 1fr;
  gap:80px; align-items:start;
}
@media(max-width:900px){ .faq-grid { grid-template-columns:1fr; gap:48px; } }
.faq-sticky { position:sticky; top:24px; }
@media(max-width:900px){ .faq-sticky { position:static; } }
.faq-sticky-eye {
  font-size:11px; font-weight:500; letter-spacing:.22em;
  text-transform:uppercase; color:var(--gold); display:block; margin-bottom:18px;
}
.faq-sticky-title {
  font-family:var(--serif);
  font-size:clamp(28px,4vw,44px);
  font-weight:600; line-height:1.15; color:var(--black); margin-bottom:20px;
}
.faq-sticky-title em { font-style:italic; color:var(--gold); }
.faq-sticky-desc { font-size:15px; font-weight:400; line-height:1.8; color:var(--muted); }
.faq-list { display:flex; flex-direction:column; gap:0; }
.faq-item { border-bottom:1px solid var(--border); padding:0; }
.faq-item:first-child { border-top:1px solid var(--border); }
.faq-summary {
  display:flex; justify-content:space-between; align-items:center;
  padding:26px 0; cursor:pointer; gap:20px;
  list-style:none; font-family:var(--sans);
  font-size:clamp(15px,2vw,18px); font-weight:500; color:var(--black);
  line-height:1.3;
}
.faq-summary::-webkit-details-marker { display:none; }
.faq-summary::marker { display:none; }
.faq-icon {
  flex-shrink:0; width:28px; height:28px;
  border:1px solid var(--border); border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:16px; color:var(--gold); font-weight:300;
  transition:transform .25s, background .2s;
}
details[open] .faq-icon { transform:rotate(45deg); background:var(--gold-bg); }
.faq-answer {
  padding:0 40px 28px 0;
  font-size:15px; font-weight:400; line-height:1.9; color:var(--muted);
}

/* ─── FINAL CTA ──────────────────────── */
.final-cta {
  padding:128px 0;
  text-align:center;
  background:var(--black);
  position:relative; overflow:hidden;
}
.final-cta::before {
  content:'';
  position:absolute; inset:0;
  background:
    radial-gradient(ellipse at 20% 60%, rgba(184,150,90,.14) 0%, transparent 55%),
    radial-gradient(ellipse at 80% 25%, rgba(232,196,184,.07) 0%, transparent 55%);
  pointer-events:none;
}
.final-cta-eye {
  font-size:11px; font-weight:500; letter-spacing:.25em; text-transform:uppercase;
  color:var(--gold); display:block; margin-bottom:24px; position:relative;
}
.final-cta-h2 {
  font-family:var(--serif);
  font-size:clamp(38px,6vw,72px);
  font-weight:600; line-height:1.08;
  color:var(--white); margin-bottom:22px; position:relative;
}
.final-cta-h2 em { font-style:italic; color:var(--gold-lt); }
.final-cta-sub {
  font-size:15px; font-weight:300; color:rgba(255,255,255,.45);
  margin:0 auto 52px; max-width:460px; line-height:1.85; position:relative;
}
</style>


<main>

<!-- ══════════════════════════════════
     HERO
══════════════════════════════════ -->
<div class="w">
  <div class="hero">

    <div class="hero-left">
      <h1 class="hero-h1">
        <em>{service.name}</em><br />
        in {city.name}
      </h1>

      <p class="hero-sub">
        Staatlich gefördertes Perfektionstraining –
        100&thinsp;% kostenfrei bei Bewilligung
        über die Agentur für Arbeit.
      </p>

      <div class="hero-divider"></div>

      <div class="hero-trust-list">
        ◆ Förderfähig über AVGS-Gutschein<br />
        ◆ AZAV-zertifizierte Schulungsstandorte<br />
        ◆ Anerkannte Fachdozentinnen in {city.name}<br />
        ◆ Echtes 1:1-Einzeltraining – eine Fachdozentin, eine Teilnehmerin
      </div>

      <a href="#dozentinnen" class="hero-scroll-link">
        ↓ Deine Fachdozentinnen in {city.name}
      </a>
    </div>

    <div class="hero-right">
      <div class="hero-img-frame">
        {hasModuleImage && moduleImageRel
          ? <img
              src={moduleImageRel}
              alt={`${service.name} in ${city.name}`}
              width="560" height="560"
              loading="eager"
              decoding="async"
            />
          : <span style="font-family:var(--serif);font-size:56px;color:rgba(184,150,90,.15);">✦</span>
        }
      </div>
    </div>

  </div>
</div>


<!-- ══════════════════════════════════
     GALERIE
══════════════════════════════════ -->
<section class="gallery-section">
  <div class="w">
    <div class="section-header" style="text-align:left;margin-bottom:40px;">
      <span class="section-eye">Ergebnisse &amp; Einblicke</span>
      <h2 class="section-title">
        Galerie – <em>{service.name}</em>
      </h2>
      <p class="section-desc" style="max-width:none;margin:0;">
        Eindrücke aus unseren AVGS-geförderten Perfektionstrainings in {city.name}.
      </p>
    </div>

    <div class="carousel-wrap">
      <button class="carousel-btn carousel-prev" aria-label="Vorheriges Bild">&#8592;</button>
      <div class="carousel-track" id="gallery-track">
        {[1,2,3,4,5,6].map((_: number) => (
          <div class="carousel-slide">
            <div class="carousel-ph">✦</div>
          </div>
        ))}
      </div>
      <button class="carousel-btn carousel-next" aria-label="Nächstes Bild">&#8594;</button>
      <div class="carousel-dots" id="gallery-dots" aria-hidden="true"></div>
    </div>
  </div>
</section>


<!-- ══════════════════════════════════
     FACHDOZENTINNEN
══════════════════════════════════ -->
<section class="section" id="dozentinnen" style="border-bottom:none;padding-bottom:0;">
  <div class="w">
    <div class="section-header" style="text-align:left;">
      <span class="section-eye">Fachdozentinnen</span>
      <h2 class="section-title">
        {service.name}<br />
        in <em>{city.name}</em>
      </h2>
      <p class="section-desc" style="max-width:none;">
        Genau dafür gibt es unsere staatlich geförderten Perfektionstrainings:
        anerkannt, zertifiziert und über den AVGS der Agentur für Arbeit zu
        100&thinsp;% förderbar – im persönlichen Einzelunterricht bei folgenden
        Fachdozentinnen in {city.name}:
      </p>
    </div>

    <div class="doz-grid">
      {dozentinnenWithImg.map((d: any) => (
        <a href={`/dozentinnen/${d.slug}/`} class="doz-card">
          <div class="doz-img-wrap">
            {d.profileImg
              ? <img
                  src={d.profileImg}
                  alt={`${d.first_name} ${d.last_name}`}
                  width="280" height="280"
                  loading="lazy"
                />
              : <div class="doz-img-ph">✦</div>
            }
          </div>
          <DozentinInfoBox
            name={`${d.first_name} ${d.last_name}`}
            standort={CITY_DISPLAY[d.slug] ?? city.name}
