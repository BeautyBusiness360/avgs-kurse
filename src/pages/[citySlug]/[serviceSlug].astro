---
import SEOLayout from '../../layouts/SEOLayout.astro';
import { supabase } from '../../lib/supabase';

export const prerender = true;

export async function getStaticPaths() {
  console.log('[city-service getStaticPaths] Start');

  const { data: dozentinnen, error } = await supabase
    .from('dozentinnen')
    .select(`
      slug,
      first_name,
      last_name,
      rating,
      review_count,
      avgs_certified,
      cities(slug, name),
      dozentin_services(
        services(slug, name, category, avgs_eligible, description_template)
      )
    `)
    .eq('active', true);

  if (error || !dozentinnen) {
    console.error('[city-service getStaticPaths] Fehler:', error);
    return [];
  }

  console.log(`[city-service] ${dozentinnen?.length ?? 0} Dozentinnen geladen`);

  const pageMap = new Map();

  for (const dozentin of dozentinnen) {
    const city = Array.isArray(dozentin.cities)
      ? dozentin.cities[0]
      : dozentin.cities;
    if (!city?.slug) continue;

    const dsRows = Array.isArray(dozentin.dozentin_services)
      ? dozentin.dozentin_services
      : [];

    for (const ds of dsRows) {
      const service = Array.isArray(ds?.services)
        ? ds.services[0]
        : ds?.services;
      if (!service?.slug) continue;

      const key = `${city.slug}__${service.slug}`;

      if (!pageMap.has(key)) {
        pageMap.set(key, {
          city: { slug: city.slug, name: city.name },
          service,
          dozentinnen: []
        });
      }

      pageMap.get(key).dozentinnen.push({
        slug:           dozentin.slug,
        first_name:     dozentin.first_name,
        last_name:      dozentin.last_name,
        rating:         dozentin.rating,
        review_count:   dozentin.review_count,
        avgs_certified: dozentin.avgs_certified
      });
    }
  }

  const paths = Array.from(pageMap.values()).map(({ city, service, dozentinnen }) => ({
    params: { citySlug: city.slug, serviceSlug: service.slug },
    props:  { city, service, dozentinnen }
  }));

  console.log(`[city-service] ${paths.length} Seiten werden gebaut`);
  return paths;
}

const { city, service, dozentinnen } = Astro.props;

const MODULE_IMAGES: Record<string, string> = {
  'powderbrows-ombrebrows-masterclass': '/images/Modul-Bilder/augenbrauen.webp',
  'velvet-lips-lipstick-masterclass':   '/images/Modul-Bilder/lippen.webp',
  'microblading-masterclass':           '/images/Modul-Bilder/microblading.webp',
  'wimpernverlaengerung-masterclass':   '/images/Modul-Bilder/wimpern.webp',
  'camouflage-removal-masterclass':     '/images/Modul-Bilder/entfernung.webp',
};
const moduleImage = MODULE_IMAGES[service.slug] ?? null;

const seo = {
  title:       `${service.name} in ${city.name} | AVGS gefördert – BeautyBusiness360`,
  description: (service.description_template ?? '').replace('{city}', city.name)
               || `${service.name} in ${city.name}. Staatlich gefördert über AVGS.`,
  canonical:   `https://dein-beauty-kurs.de/${city.slug}/${service.slug}/`
};

const schema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": `${service.name} in ${city.name}`,
  "url": seo.canonical,
  "provider": {
    "@type": "Organization",
    "name": "BeautyBusiness360",
    "url": "https://dein-beauty-kurs.de"
  }
};
---

<SEOLayout title={seo.title} description={seo.description}
           canonical={seo.canonical} schema={schema}>

<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%"   stop-color="#F9E29C"/>
      <stop offset="35%"  stop-color="#E6B84F"/>
      <stop offset="65%"  stop-color="#C8962E"/>
      <stop offset="100%" stop-color="#9A6E1E"/>
    </linearGradient>
  </defs>
</svg>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

<style>
:root {
  --cream:    #FAF8F5;
  --cream-d:  #F3EEE8;
  --black:    #111111;
  --gold:     #C8962E;
  --gold-lt:  #D4AF7A;
  --gold-bg:  #FBF6EE;
  --rose:     #E8C4B8;
  --muted:    #555250;
  --border:   #E8E2D9;
  --white:    #FFFFFF;
  --serif:    'Cormorant Garamond', Georgia, 'Times New Roman', serif;
  --sans:     'Inter', system-ui, sans-serif;
  --radius:   3px;
  --shadow:   0 8px 40px rgba(184,150,90,.10);
}

*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }
html { scroll-behavior:smooth; }
body {
  background:var(--cream);
  color:var(--black);
  font-family:var(--sans);
  font-size:16px; font-weight:400; line-height:1.75;
  -webkit-font-smoothing:antialiased;
}

.w { max-width:1120px; margin:0 auto; padding:0 40px; }
@media(max-width:640px){ .w { padding:0 22px; } }

/* ─── HERO ─── */
.hero {
  display:grid;
  grid-template-columns:55% 45%;
  gap:0; min-height:540px; padding:80px 0 64px;
}
@media(max-width:860px){ .hero { grid-template-columns:1fr; padding:48px 0 36px; } }
.hero-left {
  display:flex; flex-direction:column; justify-content:center;
  padding-right:72px;
}
@media(max-width:860px){ .hero-left { padding-right:0; padding-bottom:28px; } }
.hero-h1 {
  font-family:var(--serif);
  font-size:clamp(40px, 5.5vw, 68px);
  font-weight:600; line-height:1.06;
  color:var(--black); margin-bottom:24px; letter-spacing:-.02em;
}
.hero-h1 em { font-style:italic; color:var(--gold); white-space:nowrap; }
.hero-sub {
  font-size:17px; font-weight:400;
  line-height:1.85; color:var(--muted);
  max-width:440px;
}
.hero-avgs {
  margin-top:20px;
  font-size:13px; font-weight:500; color:#8B6914; line-height:2;
}
.hero-divider { width:48px; height:1px; background:var(--gold); margin:24px 0 0; opacity:.6; }
.hero-right { display:flex; align-items:center; justify-content:center; }
.hero-img-frame {
  width:clamp(280px, 78vw, 640px); max-width:100%;
  aspect-ratio:1 / 1; position:relative;
  border-radius:var(--radius); overflow:hidden; background:var(--cream-d);
}
.hero-img-frame img { width:100%; height:100%; object-fit:contain; display:block; }
.hero-img-placeholder {
  width:100%; height:100%;
  display:flex; align-items:center; justify-content:center;
  font-family:var(--serif); font-size:56px;
  color:rgba(184,150,90,.2);
}
.hero-sep { border:none; border-top:1px solid var(--border); margin:0; }

/* ─── SECTION BASICS ─── */
.section { padding:80px 0; border-bottom:1px solid var(--border); }
.section-header { margin-bottom:52px; }
.section-eye {
  display:inline-block; font-size:11px; font-weight:500;
  letter-spacing:.22em; text-transform:uppercase; color:var(--gold); margin-bottom:16px;
}
.section-title {
  font-family:var(--serif); font-size:clamp(36px, 5vw, 56px);
  font-weight:600; line-height:1.06; color:var(--black); margin-bottom:16px;
}
.section-title em { font-style:italic; color:var(--gold); }
.section-desc { font-size:16px; font-weight:400; line-height:1.85; color:var(--muted); }

/* ─── DOZENTINNEN CARDS ─── */
.module-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(300px,1fr));
  gap:24px;
}
.module-card {
  background:var(--white); border:1px solid var(--border); border-radius:var(--radius);
  overflow:hidden; text-decoration:none; color:inherit;
  display:flex; flex-direction:column;
  transition:box-shadow .3s, transform .25s;
  box-shadow:0 2px 16px rgba(0,0,0,.04);
}
.module-card:hover { box-shadow:var(--shadow); transform:translateY(-4px); }
.module-card-accent { height:3px; background:linear-gradient(90deg, var(--gold), var(--rose)); }
.module-card-body { padding:28px 24px 20px; flex:1; display:flex; flex-direction:column; gap:18px; }
.module-name { font-family:var(--serif); font-size:22px; font-weight:600; color:var(--black); display:block; line-height:1.2; margin-bottom:2px; }
.module-tagline { font-size:13px; color:var(--gold); font-weight:500; letter-spacing:.06em; }
.module-specs { display:flex; flex-direction:column; gap:0; border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; }
.module-spec-row { display:flex; justify-content:space-between; align-items:center; padding:10px 14px; border-bottom:1px solid var(--border); font-size:13px; }
.module-spec-row:last-child { border-bottom:none; }
.ms-label { color:var(--muted); font-weight:400; }
.ms-val   { font-weight:600; color:var(--black); text-align:right; }
.module-cta {
  display:block; text-align:center;
  background:var(--gold-bg); border:1px solid #E8D9C4; border-radius:var(--radius);
  padding:13px 18px; font-size:13px; color:#7A5C2E; font-weight:600; letter-spacing:.04em;
  transition:background .2s;
}
.module-card:hover .module-cta { background:#F0E4CE; }

/* ─── CAROUSEL ─── */
.carousel-wrap { position:relative; }
.carousel-track { display:flex; gap:16px; overflow-x:auto; scroll-snap-type:x mandatory; scroll-behavior:smooth; scrollbar-width:none; }
.carousel-track::-webkit-scrollbar { display:none; }
.carousel-slide { flex:0 0 calc((100% - 32px) / 3); scroll-snap-align:start; border-radius:var(--radius); overflow:hidden; }
.carousel-slide img { width:100%; aspect-ratio:1; object-fit:cover; display:block; transition:transform .6s ease; }
.carousel-slide:hover img { transform:scale(1.05); }
.carousel-ph { aspect-ratio:1; background:linear-gradient(135deg,var(--cream-d),#DDD4C8); display:flex; align-items:center; justify-content:center; font-size:24px; color:rgba(184,150,90,.25); }
.carousel-btn { position:absolute; top:50%; transform:translateY(-50%); width:40px; height:40px; border-radius:50%; background:var(--white); border:1px solid var(--border); box-shadow:0 2px 8px rgba(0,0,0,.1); cursor:pointer; font-size:18px; line-height:1; display:flex; align-items:center; justify-content:center; z-index:2; transition:box-shadow .2s; }
.carousel-btn:hover { box-shadow:0 4px 16px rgba(0,0,0,.15); }
.carousel-prev { left:-20px; }
.carousel-next { right:-20px; }
.carousel-dots { display:none; justify-content:center; gap:8px; margin-top:16px; }
.carousel-dot { width:8px; height:8px; border-radius:50%; border:1.5px solid var(--muted); background:transparent; transition:background .2s, border-color .2s; cursor:pointer; padding:0; }
.carousel-dot.active { background:var(--gold); border-color:var(--gold); }
@media(max-width:640px){ .carousel-slide { flex:0 0 100%; } .carousel-btn { display:none; } .carousel-dots { display:flex; } }

/* ─── FAQ ─── */
.faq-section { padding:80px 0; border-bottom:1px solid var(--border); }
.faq-grid { display:grid; grid-template-columns:340px 1fr; gap:80px; align-items:start; }
@media(max-width:900px){ .faq-grid { grid-template-columns:1fr; gap:40px; } }
.faq-sticky { position:sticky; top:24px; }
@media(max-width:900px){ .faq-sticky { position:static; } }
.faq-sticky-eye { font-size:11px; font-weight:500; letter-spacing:.22em; text-transform:uppercase; color:var(--gold); display:block; margin-bottom:16px; }
.faq-sticky-title { font-family:var(--serif); font-size:clamp(26px,3.5vw,40px); font-weight:600; line-height:1.15; color:var(--black); margin-bottom:16px; }
.faq-sticky-title em { font-style:italic; color:var(--gold); }
.faq-sticky-desc { font-size:15px; font-weight:400; line-height:1.8; color:var(--muted); }
.faq-list { display:flex; flex-direction:column; }
.faq-item { border-bottom:1px solid var(--border); }
.faq-item:first-child { border-top:1px solid var(--border); }
.faq-summary { display:flex; justify-content:space-between; align-items:center; padding:24px 0; cursor:pointer; gap:20px; list-style:none; font-family:var(--sans); font-size:clamp(14px,2vw,17px); font-weight:500; color:var(--black); line-height:1.3; }
.faq-summary::-webkit-details-marker { display:none; }
.faq-summary::marker { display:none; }
.faq-icon { flex-shrink:0; width:26px; height:26px; border:1px solid var(--border); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:15px; color:var(--gold); font-weight:300; transition:transform .25s, background .2s; }
details[open] .faq-icon { transform:rotate(45deg); background:var(--gold-bg); }
.faq-answer { padding:0 36px 24px 0; font-size:15px; font-weight:400; line-height:1.9; color:var(--muted); }

/* ─── BACK LINK ─── */
.back-link-wrap { padding:48px 0; text-align:center; }
.back-link { font-size:14px; color:var(--muted); text-decoration:none; transition:color .2s; }
.back-link:hover { color:var(--gold); }

/* ─── FOOTER ─── */
.site-footer { background:var(--black); border-top:1px solid rgba(255,255,255,.06); padding:32px 0; }
.footer-inner { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px; }
.footer-copy { font-size:12px; color:rgba(255,255,255,.25); }
.footer-links { display:flex; gap:24px; }
.footer-links a { font-size:12px; color:rgba(255,255,255,.35); text-decoration:none; transition:color .2s; }
.footer-links a:hover { color:rgba(255,255,255,.75); }

/* placeholder */
.ph-block { background:var(--cream-d); border:1.5px dashed var(--border); border-radius:var(--radius); padding:10px 16px; color:var(--muted); font-size:12px; font-style:italic; display:inline-block; }
</style>


<main>

<!-- ══════════════════════════════════
     1) INFO + BILD
══════════════════════════════════ -->
<div class="w">
  <div class="hero">

    <div class="hero-left">
      <h1 class="hero-h1">
        <em>{service.name}</em><br />
        in {city.name}
      </h1>

      <p class="hero-sub">
        <span class="ph-block">Platzhalter-Text – Untertext zum Modul, ca. 2–3 Sätze.</span>
      </p>

      <div class="hero-avgs">
        ✓&nbsp;100&thinsp;% AVGS-gefördert &nbsp;·&nbsp; AZAV-zertifiziert
      </div>

      <div class="hero-divider"></div>
    </div>

    <div class="hero-right">
      {moduleImage
        ? (
          <div class="hero-img-frame">
            <img
              src={moduleImage}
              alt={`${service.name} in ${city.name}`}
              width="560" height="560"
              loading="eager"
              decoding="async"
            />
          </div>
        )
        : (
          <div class="hero-img-frame">
            <div class="hero-img-placeholder">✦</div>
          </div>
        )
      }
    </div>

  </div>
</div>
<hr class="hero-sep" />


<!-- ══════════════════════════════════
     2) BILDERGALERIE (Platzhalter)
══════════════════════════════════ -->
<section class="section">
  <div class="w">
    <div class="section-header">
      <span class="section-eye"><span class="ph-block">PLATZHALTER – Galerie Eyebrow</span></span>
      <h2 class="section-title">
        <span class="ph-block" style="font-size:18px;font-family:var(--sans);">PLATZHALTER – Galerie H2</span>
      </h2>
    </div>

    <div class="carousel-wrap">
      <button class="carousel-btn carousel-prev" aria-label="Vorheriges Bild">&#8592;</button>
      <div class="carousel-track" id="gallery-track">
        {[1,2,3,4,5,6].map((_: number) => (
          <div class="carousel-slide">
            <div class="carousel-ph">✦</div>
          </div>
        ))}
      </div>
      <button class="carousel-btn carousel-next" aria-label="Nächstes Bild">&#8594;</button>
      <div class="carousel-dots" id="gallery-dots" aria-hidden="true"></div>
    </div>
  </div>
</section>


<!-- ══════════════════════════════════
     3) DOZENTINNEN IN DIESER STADT
══════════════════════════════════ -->
<section class="section">
  <div class="w">
    <div class="section-header">
      <span class="section-eye">Anerkannte Akademien</span>
      <h2 class="section-title">
        Deine Dozentinnen<br />
        in <em>{city.name}</em>
      </h2>
      <p class="section-desc">
        <span class="ph-block">Platzhalter-Text – Einleitung zur Dozentinnenliste.</span>
      </p>
    </div>

    <div class="module-grid">
      {dozentinnen.map((d: any) => (
        <a href={`/dozentinnen/${d.slug}/`} class="module-card">
          <div class="module-card-accent" />
          <div class="module-card-body">
            <div>
              <span class="module-name">{d.first_name} {d.last_name}</span>
              <span class="module-tagline">{service.name} · {city.name}</span>
            </div>

            <div class="module-specs">
              {d.avgs_certified && (
                <div class="module-spec-row">
                  <span class="ms-label">Zertifizierung</span>
                  <span class="ms-val">AVGS-zertifiziert</span>
                </div>
              )}
              {(d.review_count ?? 0) > 0 && (
                <div class="module-spec-row">
                  <span class="ms-label">Bewertungen</span>
                  <span class="ms-val">★ {d.rating}/5 ({d.review_count})</span>
                </div>
              )}
              <div class="module-spec-row">
                <span class="ms-label">Förderung</span>
                <span class="ms-val">100 % AVGS</span>
              </div>
            </div>

            <div class="module-cta">Zur Dozentin →</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>


<!-- ══════════════════════════════════
     4) FAQ (Platzhalter)
══════════════════════════════════ -->
<section class="faq-section" id="faq">
  <div class="w">
    <div class="faq-grid">

      <div class="faq-sticky">
        <span class="faq-sticky-eye">Häufige Fragen</span>
        <h2 class="faq-sticky-title">
          <span class="ph-block" style="font-size:16px;font-family:var(--sans);">PLATZHALTER –</span><br />
          <em>FAQ-Titel</em>
        </h2>
        <p class="faq-sticky-desc">
          <span class="ph-block">Platzhalter-Text – Einleitung zum FAQ-Block.</span>
        </p>
      </div>

      <div class="faq-list">
        {(['PLATZHALTER – Frage 1?', 'PLATZHALTER – Frage 2?', 'PLATZHALTER – Frage 3?', 'PLATZHALTER – Frage 4?'] as string[]).map(q => (
          <details class="faq-item">
            <summary class="faq-summary">
              {q}
              <span class="faq-icon">+</span>
            </summary>
            <div class="faq-answer">
              <p>Platzhalter-Antwort – wird in einem späteren Schritt befüllt.</p>
            </div>
          </details>
        ))}
      </div>

    </div>
  </div>
</section>


<!-- ══════════════════════════════════
     5) RÜCKLINK
══════════════════════════════════ -->
<div class="back-link-wrap">
  <div class="w">
    <a href={`/${city.slug}/`} class="back-link">← Alle anerkannten Akademien in {city.name}</a>
  </div>
</div>

</main>


<!-- ══════════════════════════════════
     FOOTER
══════════════════════════════════ -->
<footer class="site-footer">
  <div class="w">
    <div class="footer-inner">
      <span class="footer-copy">© 2026 BeautyBusiness360</span>
      <div class="footer-links">
        <a href="/impressum/">Impressum</a>
        <a href="/datenschutz/">Datenschutzerklärung</a>
      </div>
    </div>
  </div>
</footer>

<script>
  const track = document.getElementById('gallery-track') as HTMLElement | null;
  const dotsWrap = document.getElementById('gallery-dots') as HTMLElement | null;
  if (track) {
    const prev = track.closest('.carousel-wrap')?.querySelector('.carousel-prev');
    const next = track.closest('.carousel-wrap')?.querySelector('.carousel-next');
    const slides = Array.from(track.querySelectorAll('.carousel-slide')) as HTMLElement[];
    const step = () => (slides[0]?.offsetWidth ?? 0) + 16;

    const dots: HTMLButtonElement[] = slides.map((_, i) => {
      const d = document.createElement('button');
      d.className = 'carousel-dot' + (i === 0 ? ' active' : '');
      d.setAttribute('aria-label', `Bild ${i + 1}`);
      d.addEventListener('click', () => track.scrollTo({ left: step() * i, behavior: 'smooth' }));
      dotsWrap?.appendChild(d);
      return d;
    });

    const updateDots = () => {
      const idx = Math.round(track.scrollLeft / (step() || 1));
      dots.forEach((d, i) => d.classList.toggle('active', i === idx));
    };

    track.addEventListener('scroll', updateDots, { passive: true });
    prev?.addEventListener('click', () => track.scrollBy({ left: -step() * 3, behavior: 'smooth' }));
    next?.addEventListener('click', () => track.scrollBy({ left:  step() * 3, behavior: 'smooth' }));
  }
</script>

</SEOLayout>
